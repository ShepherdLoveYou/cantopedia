site/public/pagefind/

# Drafts (must be promoted via `pipeline validate` before commit)
data/**/*.yaml.draft
site/smoke-out/
site/contrast-out/
site/probe-out/

# Playwright probe screenshot outputs (transient — not source)
site/probe-*.png
