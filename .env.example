# Cantopedia pipeline secrets — copy to .env (which is gitignored) and fill.
# NEVER commit the real .env file. Add real secrets via `gh secret set` for CI.

# Pexels API key — used by `pipeline images --search-pexels` to find food
# photography under the Pexels license (free for commercial / non-commercial,
# attribution recommended).  https://www.pexels.com/api/
PEXELS_API_KEY=

# Unsplash access key — used by `pipeline images --search-unsplash`. Unsplash
# license: free for commercial / non-commercial.  https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# USDA FoodData Central API key — free, signup at https://fdc.nal.usda.gov/api-key-signup.html
# Without a key the pipeline falls back to anonymous "DEMO_KEY" with stricter rate limits.
USDA_API_KEY=

# Anthropic API key — used by `pipeline synthesize` (Claude API) for first-draft
# methods. Optional; if absent, all dishes stay at method_status: stub or draft.
# v0.1-alpha note: synthesize layer is NOT enabled; methods are hand-authored.
ANTHROPIC_API_KEY=
