---
interface Props {
  title: string;
  locale?: 'zh' | 'en' | 'yue';
  description?: string;
  showNav?: boolean;
}
const { title, locale = 'zh', description, showNav = true } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const dict = {
  zh: { yue: '粵', zh: '中', en: 'En', tag_browse: '瀏覽', tag_search: '搜尋', tag_about: '關於' },
  en: { yue: '粵', zh: '中', en: 'En', tag_browse: 'Browse', tag_search: 'Search', tag_about: 'About' },
  yue: { yue: '粵', zh: '中', en: 'En', tag_browse: '瀏覽', tag_search: '搵', tag_about: '關於' },
}[locale];
---
<!doctype html>
<html lang={locale === 'yue' ? 'yue-Hant' : locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <title>{title} · 粵食典 Cantopedia</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,500;0,600&family=Noto+Sans+SC:wght@300;400;500;700&family=Noto+Serif+SC:wght@400;500;600;700&family=Open+Sans:wght@300;400;600;700&display=swap" />
  </head>
  <body>
    {showNav && (
      <nav class="metro-nav">
        <a class="brand" href={`${base}/${locale}`}>
          <span class="brand-seal">粵</span>
          <span class="brand-name">食典 · Cantopedia</span>
        </a>
        <div class="pivot">
          {(['zh', 'yue', 'en'] as const).map((loc) => (
            <a class={`pivot-tab ${loc === locale ? 'active' : ''}`} href={`${base}/${loc}`}>{dict[loc]}</a>
          ))}
        </div>
      </nav>
    )}
    <main>
      <slot />
    </main>
    <style is:global>
      :root {
        /* Metro / W3CSS Metro palette */
        --m-red: #e51400;
        --m-pink: #f472d0;
        --m-magenta: #ff0097;
        --m-purple: #9f00a7;
        --m-violet: #76608a;
        --m-indigo: #6a00ff;
        --m-blue: #2d89ef;
        --m-blue-dark: #2b5797;
        --m-cyan: #1ba1e2;
        --m-teal: #00aba9;
        --m-green: #008a00;
        --m-lime: #8cbf26;
        --m-yellow: #d8c100;
        --m-orange: #f09609;
        --m-orange-dark: #da532c;
        --m-brown: #a05000;
        --m-crimson: #a20025;
        --m-mauve: #76608a;
        --m-steel: #647687;
        --m-ink: #1d1d1d;

        /* Surface */
        --bg: #f5f5f5;
        --plate: #ebebeb;
        --plate-dark: #cccccc;
        --ink: #1d1d1d;
        --ink-dim: #555;
        --rule: #d8d8d8;
        --seal: #B71C1C;

        /* Type stacks — Segoe UI primary (Microsoft Metro) with serif Chinese for body */
        --sans: "Segoe UI", "Open Sans", system-ui, -apple-system, "Helvetica Neue", Arial, sans-serif;
        --sans-zh: "Noto Sans SC", "Microsoft YaHei", "PingFang SC", sans-serif;
        --serif-zh: "Noto Serif SC", "Source Han Serif SC", "Songti SC", serif;
        --serif-en: "Crimson Pro", "Iowan Old Style", Georgia, serif;
        --mono: ui-monospace, "Cascadia Mono", Menlo, Consolas, monospace;
        --meta: var(--sans);
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; background: var(--bg); color: var(--ink); }
      body {
        font-family: var(--sans), var(--sans-zh);
        font-size: 16px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      main { max-width: 1200px; margin: 0 auto; padding: 1.5rem 1.5rem 6rem; }
      h1 { font-family: var(--sans), var(--sans-zh); font-weight: 300; font-size: 3rem; line-height: 1.1; letter-spacing: -0.02em; margin: 0 0 0.5rem; }
      h2 { font-family: var(--sans), var(--sans-zh); font-weight: 300; font-size: 2rem; margin: 2.5rem 0 1rem; line-height: 1.2; }
      h3 { font-family: var(--sans), var(--sans-zh); font-weight: 600; font-size: 1.125rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--ink-dim); margin: 1.5rem 0 0.75rem; }
      h4 { font-family: var(--sans), var(--sans-zh); font-weight: 600; font-size: 1rem; margin: 1rem 0 0.5rem; }
      a { color: var(--m-blue); text-decoration: none; transition: color 0.1s; }
      a:hover { color: var(--m-red); }
      hr { border: 0; border-top: 1px solid var(--rule); margin: 1.5rem 0; }
      .meta { font-family: var(--meta); color: var(--ink-dim); font-size: 0.8125rem; }
      ol, ul { padding-left: 1.5rem; }
      li { margin: 0.25rem 0; }
      table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
      th, td { text-align: left; padding: 0.625rem 0.875rem; border-bottom: 1px solid var(--rule); }
      th { font-family: var(--sans); font-weight: 600; color: var(--ink-dim); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; }
      code { font-family: var(--mono); background: var(--plate); padding: 0.125rem 0.375rem; font-size: 0.875em; }
      blockquote { margin: 1.25rem 0; padding-left: 1.25rem; border-left: 3px solid var(--m-blue); color: var(--ink-dim); }
      .badge { display: inline-block; font-family: var(--sans); font-size: 0.6875rem; padding: 0.1875rem 0.625rem; border: 1px solid var(--rule); color: var(--ink-dim); margin-right: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
      .badge--seal { background: var(--m-red); color: white; border-color: var(--m-red); }
      .badge--warn { background: var(--m-yellow); border-color: var(--m-yellow); color: #4a3800; }
      .badge--green { background: var(--m-green); color: white; border-color: var(--m-green); }
      footer { max-width: 1200px; margin: 4rem auto 2rem; padding: 2rem 1.5rem 0; border-top: 1px solid var(--rule); font-family: var(--meta); font-size: 0.8125rem; color: var(--ink-dim); text-align: center; }

      .metro-nav {
        background: var(--m-ink);
        color: white;
        padding: 0.75rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: sticky;
        top: 0;
        z-index: 50;
      }
      .brand { display: flex; align-items: center; gap: 0.75rem; color: white !important; }
      .brand:hover { color: white !important; }
      .brand-seal {
        display: inline-flex; align-items: center; justify-content: center;
        width: 32px; height: 32px;
        background: var(--m-red);
        color: white;
        font-weight: 700; font-size: 18px;
        font-family: var(--serif-zh);
      }
      .brand-name { font-family: var(--sans), var(--sans-zh); font-weight: 300; font-size: 1.125rem; letter-spacing: 0.02em; }
      .pivot { display: flex; gap: 0.25rem; }
      .pivot-tab {
        font-family: var(--sans), var(--sans-zh);
        font-size: 0.875rem;
        padding: 0.375rem 0.875rem;
        color: rgba(255,255,255,0.6) !important;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 600;
        transition: color 0.1s, background 0.1s;
      }
      .pivot-tab:hover { color: white !important; background: rgba(255,255,255,0.08); }
      .pivot-tab.active { color: white !important; border-bottom: 2px solid var(--m-red); }

      .plate { background: var(--plate); padding: 1.25rem 1.5rem; margin: 1.5rem 0; border-left: 3px solid var(--m-blue); }
    </style>
  </body>
</html>
