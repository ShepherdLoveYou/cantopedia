---
interface Props {
  title: string;
  locale?: 'zh' | 'en' | 'yue';
  description?: string;
}
const { title, locale = 'zh', description } = Astro.props;
---
<!doctype html>
<html lang={locale === 'yue' ? 'yue-Hant' : locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
    <title>{title} · 粵食典 Cantopedia</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,500;0,600;1,400&family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@400;500;600&family=Noto+Serif+SC:wght@400;500;600;700&display=swap" />
  </head>
  <body>
    <main>
      <slot />
    </main>
    <style is:global>
      :root {
        --bg: #FDFBF7;
        --ink: #2B1810;
        --ink-dim: #6B5544;
        --rule: #E5DCC9;
        --seal: #B71C1C;
        --plate: #F8F2E4;
        --serif-zh: "Noto Serif SC", "Source Han Serif SC", "Songti SC", serif;
        --serif-en: "Crimson Pro", "EB Garamond", Georgia, serif;
        --display: "Cormorant Garamond", "Noto Serif SC", serif;
        --mono: ui-monospace, "Cascadia Mono", Menlo, Consolas, monospace;
        --meta: "Inter", system-ui, -apple-system, sans-serif;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; background: var(--bg); color: var(--ink); }
      body {
        font-family: var(--serif-en), var(--serif-zh);
        font-size: 18px;
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      main { max-width: 760px; margin: 0 auto; padding: 4rem 1.5rem 6rem; }
      h1, h2, h3, h4 { font-family: var(--display), var(--serif-zh); font-weight: 600; line-height: 1.25; }
      h1 { font-size: 2.5rem; margin: 0 0 0.5rem; }
      h2 { font-size: 1.75rem; margin: 3rem 0 1rem; border-bottom: 1px solid var(--rule); padding-bottom: 0.5rem; }
      h3 { font-size: 1.25rem; margin: 1.75rem 0 0.5rem; color: var(--ink-dim); }
      a { color: var(--seal); text-decoration: none; border-bottom: 1px solid color-mix(in srgb, var(--seal) 30%, transparent); }
      a:hover { border-bottom-color: var(--seal); }
      hr { border: 0; border-top: 1px solid var(--rule); margin: 2rem 0; }
      .meta { font-family: var(--meta); color: var(--ink-dim); font-size: 0.875rem; }
      .seal-accent { color: var(--seal); }
      .plate { background: var(--plate); padding: 1.25rem 1.5rem; border-radius: 4px; border-left: 3px solid var(--seal); margin: 1.5rem 0; }
      ol, ul { padding-left: 1.5rem; }
      li { margin: 0.5rem 0; }
      table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
      th, td { text-align: left; padding: 0.625rem 0.75rem; border-bottom: 1px solid var(--rule); }
      th { font-family: var(--meta); font-weight: 600; color: var(--ink-dim); font-size: 0.8125rem; text-transform: uppercase; letter-spacing: 0.05em; }
      code { font-family: var(--mono); background: var(--plate); padding: 0.125rem 0.375rem; border-radius: 3px; font-size: 0.875em; }
      blockquote { margin: 1.25rem 0; padding-left: 1.25rem; border-left: 3px solid var(--rule); font-style: italic; color: var(--ink-dim); }
      .badge { display: inline-block; font-family: var(--meta); font-size: 0.75rem; padding: 0.125rem 0.5rem; border-radius: 999px; border: 1px solid var(--rule); color: var(--ink-dim); margin-right: 0.5rem; }
      .badge--seal { background: var(--seal); color: white; border-color: var(--seal); }
      .badge--warn { background: #FFF4D6; border-color: #E8C46C; color: #6B4D00; }
      footer { max-width: 760px; margin: 4rem auto 2rem; padding: 2rem 1.5rem 0; border-top: 1px solid var(--rule); font-family: var(--meta); font-size: 0.8125rem; color: var(--ink-dim); text-align: center; }
    </style>
  </body>
</html>
