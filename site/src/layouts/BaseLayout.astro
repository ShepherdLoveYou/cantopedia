---
import { ClientRouter } from 'astro:transitions';
import { getCollection } from 'astro:content';
import CategoryIcon from '~/components/CategoryIcon.astro';

interface Props {
  title: string;
  locale?: 'zh' | 'en' | 'yue';
  description?: string;
  showNav?: boolean;
  ogImage?: string;
}
const { title, locale = 'zh', description, showNav = true, ogImage } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://shepherdloveyou.github.io').toString();

// Locale switcher should stay on the same page, not jump to home.
// Build the equivalent URL in each locale by swapping the locale segment.
function localeHref(targetLocale: 'zh' | 'yue' | 'en'): string {
  // Astro.url.pathname includes the base. Strip it, then replace the locale segment.
  const path = Astro.url.pathname.replace(/\/$/, '');
  const baseStripped = base ? path.replace(new RegExp('^' + base.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')), '') : path;
  const parts = baseStripped.split('/').filter(Boolean);
  // Expected shape: [<locale>, ...rest]
  if (parts.length === 0 || !['zh', 'yue', 'en'].includes(parts[0])) {
    return `${base}/${targetLocale}`;
  }
  parts[0] = targetLocale;
  return `${base}/${parts.join('/')}`;
}
const ogImageUrl = ogImage ?? `${site}${base}/og-default.svg`;
const ogDescription = description ?? (locale === 'en'
  ? '66 dishes from a Hong Kong-style café menu — tri-lingual, citation-traceable, MIT/CC BY-SA.'
  : '六張港式茶餐廳水牌 · 66 道菜 · 粵 / 中 / English 三語可溯源');
const pageTitle = `${title} · 粵食典 Cantopedia`;

const categories = await getCollection('category');
const dishes = await getCollection('dish');
const categoryCounts = new Map<string, number>();
for (const d of dishes) {
  const id = d.data.category.id;
  categoryCounts.set(id, (categoryCounts.get(id) ?? 0) + 1);
}
const drawerCategories = categories
  .filter((c) => (categoryCounts.get(c.id) ?? 0) > 0)
  .sort((a, b) => a.data.sort_order - b.data.sort_order);

type CatId = 'appetizer' | 'soup-wonton' | 'rice' | 'noodle' | 'soup-noodle' | 'baked-rice' | 'congee' | 'main';

const dict = {
  zh: { yue: '粵語', zh: '中文', en: 'English', tag_browse: '瀏覽分類', tag_search: '搜尋', tag_about: '關於', menu: '選單', theme: '主題', light: '明', dark: '暗', auto: '自動', pieces: '道', github: '原始碼' },
  en: { yue: '粵語', zh: '中文', en: 'English', tag_browse: 'Browse categories', tag_search: 'Search', tag_about: 'About', menu: 'Menu', theme: 'Theme', light: 'Light', dark: 'Dark', auto: 'Auto', pieces: 'dishes', github: 'Source' },
  yue: { yue: '粵語', zh: '中文', en: 'English', tag_browse: '瀏覽分類', tag_search: '搵', tag_about: '關於', menu: '選單', theme: '主題', light: '明', dark: '暗', auto: '自動', pieces: '道', github: '原始碼' },
}[locale];
---
<!doctype html>
<html lang={locale === 'yue' ? 'yue-Hant' : locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <script is:inline data-astro-rerun>
      // `data-astro-rerun` makes Astro re-execute this on every ClientRouter
      // navigation so the theme follows the user's saved choice on every page.
      (function () {
        try {
          const saved = localStorage.getItem('cantopedia-theme') || 'auto';
          const dark = saved === 'dark' || (saved === 'auto' && matchMedia('(prefers-color-scheme: dark)').matches);
          document.documentElement.dataset.theme = dark ? 'dark' : 'light';
          document.documentElement.dataset.themeChoice = saved;
        } catch (e) {
          document.documentElement.dataset.theme = 'light';
          document.documentElement.dataset.themeChoice = 'auto';
        }
      })();
    </script>
    <title>{pageTitle}</title>
    <meta name="description" content={ogDescription} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={locale === 'en' ? 'en_US' : locale === 'yue' ? 'yue_Hant' : 'zh_Hant'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,500;0,600&family=Noto+Sans+SC:wght@200;300;400;500;700&family=Noto+Serif+SC:wght@400;500;600;700&family=Open+Sans:wght@200;300;400;600;700&display=swap" />
    {/* MetroUI 4 — CSS-only experiment. Loaded BEFORE our own styles so
        our :root vars and selectors override Metro's defaults. */}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/metro4@4.5.12/build/css/metro-all.min.css" />
    <ClientRouter />
  </head>
  <body>
    <div class="loading-bar" id="loading-bar" transition:persist></div>
    {showNav && (
      <nav class="metro-nav" transition:persist>
        <button class="hamburger" id="hamburger" type="button" aria-controls="nav-drawer" aria-expanded="false" aria-label={dict.menu}>
          <span class="hamburger-bar"></span>
          <span class="hamburger-bar"></span>
          <span class="hamburger-bar"></span>
        </button>
        <a class="brand" href={`${base}/${locale}`}>
          <span class="brand-name">CANTOPEDIA</span>
        </a>
        <div class="locale-switcher">
          {(['zh', 'yue', 'en'] as const).map((loc) => (
            <a class={`pivot-tab ${loc === locale ? 'active' : ''}`} data-loc={loc} href={localeHref(loc)}>{loc === 'zh' ? '中' : loc === 'yue' ? '粵' : 'EN'}</a>
          ))}
        </div>
      </nav>
    )}
    {showNav && (
      <>
        <div class="drawer-scrim" id="drawer-scrim" transition:persist></div>
        <aside class="nav-drawer" id="nav-drawer" aria-hidden="true" transition:persist>
          <div class="drawer-inner">
            <div class="drawer-brand">
              <span class="brand-seal" aria-hidden="true">粵</span>
              <span class="drawer-brand-name">食典<br /><small>Cantopedia</small></span>
            </div>

            <a class="drawer-search-link" href={`${base}/${locale}/search`}>
              <span class="drawer-search-icon" aria-hidden="true">🔎</span>
              <span class="drawer-search-text">{dict.tag_search}</span>
            </a>

            <div class="drawer-section-label">{dict.tag_browse}</div>
            <nav class="drawer-cats">
              {drawerCategories.map((cat) => {
                const nm = locale === 'en' ? cat.data.names.en : cat.data.names.yue_hant;
                const count = categoryCounts.get(cat.id) ?? 0;
                return (
                  <a class="drawer-cat" href={`${base}/${locale}/browse/${cat.id}`} data-cat={cat.id}>
                    <span class="drawer-cat-icon"><CategoryIcon cat={cat.id as CatId} size={22} /></span>
                    <span class="drawer-cat-name">{nm}</span>
                    <span class="drawer-cat-count">{count}</span>
                  </a>
                );
              })}
            </nav>

            <hr class="drawer-rule" />

            <div class="drawer-section-label">{locale === 'en' ? 'Language' : '語言'}</div>
            <div class="drawer-locales">
              {(['zh', 'yue', 'en'] as const).map((loc) => (
                <a class={`drawer-locale ${loc === locale ? 'active' : ''}`} data-loc={loc} href={localeHref(loc)}>{dict[loc]}</a>
              ))}
            </div>

            <hr class="drawer-rule" />

            <div class="drawer-section-label">{dict.theme}</div>
            <div class="drawer-themes" role="radiogroup" aria-label={dict.theme}>
              <button class="drawer-theme" type="button" data-theme-choice="light" aria-label={dict.light}><span aria-hidden="true">☀</span> {dict.light}</button>
              <button class="drawer-theme" type="button" data-theme-choice="dark" aria-label={dict.dark}><span aria-hidden="true">☾</span> {dict.dark}</button>
              <button class="drawer-theme" type="button" data-theme-choice="auto" aria-label={dict.auto}><span aria-hidden="true">⚙</span> {dict.auto}</button>
            </div>

            <div class="drawer-foot">
              <a href="https://github.com/ShepherdLoveYou/cantopedia">{dict.github} →</a>
            </div>
          </div>
        </aside>
      </>
    )}
    <main>
      <slot />
    </main>
    <script>
      // WP10-style top loading bar — animates during page transitions
      const bar = document.getElementById('loading-bar');
      if (bar) {
        document.addEventListener('astro:before-preparation', () => {
          bar.classList.add('loading');
        });
        document.addEventListener('astro:page-load', () => {
          bar.classList.remove('loading');
        });
      }

      // Locale switcher: nav + drawer are transition:persist, so the .active
      // class baked at first render stays stuck on the original locale. On
      // every page-load, recompute current locale from the URL and refresh
      // .active state on all [data-loc] elements. Also update each switcher
      // link's href so it points to the equivalent page in the target locale.
      function refreshLocaleSwitchers() {
        const path = location.pathname.replace(/\/$/, '');
        // Read the configured base from any existing locale link so we don't
        // hardcode "/cantopedia" — supports alternate deployment roots.
        const sample = document.querySelector<HTMLAnchorElement>('[data-loc]');
        const sampleHref = sample?.getAttribute('href') ?? '';
        const baseMatch = sampleHref.match(/^(\/[^/]*)?\/(zh|yue|en)\b/);
        const sitebase = (baseMatch?.[1] ?? '').replace(/\/$/, '');
        const baseStripped = sitebase ? path.replace(new RegExp('^' + sitebase.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')), '') : path;
        const parts = baseStripped.split('/').filter(Boolean);
        const current = (['zh', 'yue', 'en'].includes(parts[0]) ? parts[0] : 'zh') as 'zh' | 'yue' | 'en';
        const rest = parts.slice(1).join('/');
        document.querySelectorAll<HTMLAnchorElement>('[data-loc]').forEach((a) => {
          const target = a.dataset.loc as 'zh' | 'yue' | 'en';
          a.classList.toggle('active', target === current);
          a.href = `${sitebase}/${target}${rest ? '/' + rest : ''}`;
        });
      }
      document.addEventListener('astro:page-load', refreshLocaleSwitchers);
      refreshLocaleSwitchers();

      // Prevent FOUC of light theme on ClientRouter nav: set data-theme on
      // the INCOMING document before its body is rendered.
      document.addEventListener('astro:before-swap', (e) => {
        try {
          const newDoc = (e as any).newDocument as Document | undefined;
          if (!newDoc) return;
          const choice = localStorage.getItem('cantopedia-theme') || 'auto';
          const dark = choice === 'dark' || (choice === 'auto' && matchMedia('(prefers-color-scheme: dark)').matches);
          newDoc.documentElement.dataset.theme = dark ? 'dark' : 'light';
          newDoc.documentElement.dataset.themeChoice = choice;
        } catch {}
      });

      // Direction-aware horizontal pivot — popstate => "back", else
      // "forward". Also gates the children opacity-fade cascade via
      // data-cascade so it plays AFTER the VT snapshot settles (otherwise
      // the cascade would run behind the pseudo and the user wouldn't see it).
      (function setupNavDirection() {
        let isBack = false;
        window.addEventListener('popstate', () => { isBack = true; });
        document.addEventListener('astro:before-preparation', () => {
          document.documentElement.dataset.nav = isBack ? 'back' : 'forward';
          isBack = false;
          document.documentElement.dataset.cascade = 'pause';
        });
        document.addEventListener('astro:page-load', () => {
          if (!document.documentElement.dataset.nav) {
            document.documentElement.dataset.nav = 'forward';
          }
          void document.documentElement.offsetHeight;
          document.documentElement.dataset.cascade = 'go';
        });
        if (!document.documentElement.dataset.cascade) {
          document.documentElement.dataset.cascade = 'go';
        }
        if (!document.documentElement.dataset.nav) {
          document.documentElement.dataset.nav = 'forward';
        }
      })();

      // 3D tilt press — directional rotation toward press point (max 3deg + scale 0.96).
      // Released on pointerup/cancel/leave. Doc-level delegation; per-tile setProperty.
      (function setupTiltPress() {
        const MAX = 3;
        function press(tile: HTMLElement, x: number, y: number) {
          const r = tile.getBoundingClientRect();
          const dx = (x - r.left - r.width / 2) / (r.width / 2);
          const dy = (y - r.top - r.height / 2) / (r.height / 2);
          tile.style.setProperty('--tilt-x', (-dy * MAX).toFixed(2) + 'deg');
          tile.style.setProperty('--tilt-y', (dx * MAX).toFixed(2) + 'deg');
          tile.classList.add('pressing');
        }
        function release() {
          document.querySelectorAll('.wp-tile.pressing').forEach((t) => t.classList.remove('pressing'));
        }
        document.addEventListener('pointerdown', (e) => {
          const t = (e.target as Element | null)?.closest('.wp-tile') as HTMLElement | null;
          if (t) press(t, e.clientX, e.clientY);
        });
        ['pointerup', 'pointercancel', 'pointerleave'].forEach((ev) => document.addEventListener(ev, release));
      })();
    </script>

    <script>
      // Drawer + theme — instantiated on every page load; uses focus-trap (MIT) for a11y.
      import { createFocusTrap } from 'focus-trap';

      // Re-apply theme on every page-load — even when the drawer is already
      // wired and setup() short-circuits. The inline pre-paint script sets
      // <html data-theme> on each nav; this ensures the aria-pressed state
      // on the theme buttons stays in sync too.
      function reapplyTheme() {
        try {
          const choice = localStorage.getItem('cantopedia-theme') || 'auto';
          const dark = choice === 'dark' || (choice === 'auto' && matchMedia('(prefers-color-scheme: dark)').matches);
          document.documentElement.dataset.theme = dark ? 'dark' : 'light';
          document.documentElement.dataset.themeChoice = choice;
          document.querySelectorAll<HTMLButtonElement>('[data-theme-choice]').forEach((b) => {
            b.setAttribute('aria-pressed', b.dataset.themeChoice === choice ? 'true' : 'false');
          });
        } catch {}
      }

      function setup() {
        const drawer = document.getElementById('nav-drawer');
        const scrim = document.getElementById('drawer-scrim');
        const burger = document.getElementById('hamburger');
        if (!drawer || !scrim || !burger) return;
        // Always re-sync the theme even when wired (theme can be changed on
        // a different page; <html> attr or button aria can drift).
        reapplyTheme();
        // Drawer markup persists across ClientRouter navigations (transition:persist),
        // so guard against attaching duplicate listeners — without this, two clicks
        // worth of handlers fire per click and the drawer toggles itself shut.
        if (burger.dataset.wired === '1') return;
        burger.dataset.wired = '1';

        let trap: ReturnType<typeof createFocusTrap> | null = null;

        function open() {
          drawer!.classList.add('open');
          scrim!.classList.add('open');
          drawer!.setAttribute('aria-hidden', 'false');
          burger!.setAttribute('aria-expanded', 'true');
          if (!trap) {
            trap = createFocusTrap(drawer!, {
              onDeactivate: () => burger!.focus(),
              clickOutsideDeactivates: true,
              escapeDeactivates: true,
              returnFocusOnDeactivate: true,
              fallbackFocus: drawer!,
            });
          }
          trap.activate();
        }
        function close() {
          drawer!.classList.remove('open');
          scrim!.classList.remove('open');
          drawer!.setAttribute('aria-hidden', 'true');
          burger!.setAttribute('aria-expanded', 'false');
          trap?.deactivate();
        }
        function toggle() {
          drawer!.classList.contains('open') ? close() : open();
        }

        burger.addEventListener('click', toggle);
        scrim.addEventListener('click', close);
        drawer.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
        document.addEventListener('astro:before-preparation', close);

        // Theme toggle wiring
        const buttons = drawer.querySelectorAll<HTMLButtonElement>('[data-theme-choice]');
        function applyChoice(choice: string) {
          const dark = choice === 'dark' || (choice === 'auto' && matchMedia('(prefers-color-scheme: dark)').matches);
          document.documentElement.dataset.theme = dark ? 'dark' : 'light';
          document.documentElement.dataset.themeChoice = choice;
          try { localStorage.setItem('cantopedia-theme', choice); } catch {}
          buttons.forEach((b) => b.setAttribute('aria-pressed', b.dataset.themeChoice === choice ? 'true' : 'false'));
        }
        const current = document.documentElement.dataset.themeChoice || 'auto';
        applyChoice(current);
        buttons.forEach((b) => b.addEventListener('click', () => applyChoice(b.dataset.themeChoice!)));
      }

      setup();
      document.addEventListener('astro:page-load', setup);
    </script>
    <style is:global>
      :root {
        /* Metro / W3CSS Metro palette */
        --m-red: #e51400;
        --m-pink: #f472d0;
        --m-magenta: #ff0097;
        --m-purple: #9f00a7;
        --m-violet: #76608a;
        --m-indigo: #6a00ff;
        --m-blue: #2d89ef;
        --m-blue-dark: #2b5797;
        --m-cyan: #1ba1e2;
        --m-teal: #00aba9;
        --m-green: #008a00;
        --m-lime: #8cbf26;
        --m-yellow: #d8c100;
        --m-orange: #f09609;
        --m-orange-dark: #da532c;
        --m-brown: #a05000;
        --m-crimson: #a20025;
        --m-mauve: #76608a;
        --m-steel: #647687;
        --m-ink: #1d1d1d;

        /* Theme tokens (light default) */
        --t-bg: #f5f5f5;
        --t-plate: #ebebeb;
        --t-plate-dark: #cccccc;
        --t-ink: #1d1d1d;
        --t-ink-dim: #555;
        --t-rule: #d8d8d8;
        --t-card: #ffffff;
        --t-nav-bg: rgba(29, 29, 29, 0.72);
        --t-nav-ink: #ffffff;
        --t-drawer-bg: rgba(20, 20, 22, 0.78);
        --t-drawer-ink: #ffffff;
        --t-drawer-dim: rgba(255,255,255,0.6);
        --t-acrylic-fallback: rgba(20, 20, 22, 0.94);
        --t-scrim: rgba(0,0,0,0.45);

        /* Surface aliases (forward to theme tokens for back-compat) */
        --bg: var(--t-bg);
        --plate: var(--t-plate);
        --plate-dark: var(--t-plate-dark);
        --ink: var(--t-ink);
        --ink-dim: var(--t-ink-dim);
        --rule: var(--t-rule);
        --seal: #B71C1C;

        /* Type stacks — Segoe UI primary (Microsoft Metro) with serif Chinese for body */
        --sans: "Segoe UI", "Open Sans", system-ui, -apple-system, "Helvetica Neue", Arial, sans-serif;
        --sans-zh: "Noto Sans SC", "Microsoft YaHei", "PingFang SC", sans-serif;
        --serif-zh: "Noto Serif SC", "Source Han Serif SC", "Songti SC", serif;
        --serif-en: "Crimson Pro", "Iowan Old Style", Georgia, serif;
        --mono: ui-monospace, "Cascadia Mono", Menlo, Consolas, monospace;
        --meta: var(--sans);

        /* Damped, WP10-mobile-feel easing — softer than @fluentui/tokens' Office-app curves.
           - decelerate: slow start, soft glide-to-stop (no wall)
           - accelerate: gentle start, builds momentum
           - spring: slight overshoot then settle, for press release
           - easy-ease: symmetric in/out for flips & cross-fades */
        --fluent-curve-decelerate-mid: cubic-bezier(0.16, 1, 0.3, 1);
        --fluent-curve-accelerate-mid: cubic-bezier(0.55, 0, 0.9, 0.3);
        --fluent-curve-easy-ease:      cubic-bezier(0.4, 0, 0.2, 1);
        --fluent-curve-spring:         cubic-bezier(0.34, 1.4, 0.55, 1);
        --fluent-duration-fast:        180ms;
        --fluent-duration-normal:      280ms;
        --fluent-duration-gentle:      420ms;
        --fluent-duration-rich:        560ms;
      }

      html[data-theme="dark"] {
        --t-bg: #0e0e10;
        --t-plate: #1a1a1c;
        --t-plate-dark: #25252a;
        --t-ink: #f0f0f0;
        --t-ink-dim: #9a9a9a;
        --t-rule: #2a2a2c;
        --t-card: #161618;
        --t-nav-bg: rgba(10, 10, 12, 0.78);
        --t-nav-ink: #f0f0f0;
        --t-drawer-bg: rgba(8, 8, 10, 0.82);
        --t-acrylic-fallback: rgba(8, 8, 10, 0.96);
      }

      html, body { background: var(--t-bg); color: var(--t-ink); transition: background-color var(--fluent-duration-gentle) ease, color var(--fluent-duration-gentle) ease; }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; background: var(--bg); color: var(--ink); }
      body {
        font-family: var(--sans), var(--sans-zh);
        font-size: 16px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      main { max-width: 1200px; margin: 0 auto; padding: 1.5rem 1.5rem 6rem; }
      h1 { font-family: var(--sans), var(--sans-zh); font-weight: 400; font-size: 3rem; line-height: 1.1; letter-spacing: -0.02em; margin: 0 0 0.5rem; }
      h2 { font-family: var(--sans), var(--sans-zh); font-weight: 400; font-size: 2rem; margin: 2.5rem 0 1rem; line-height: 1.2; }
      h3 { font-family: var(--sans), var(--sans-zh); font-weight: 500; font-size: 1.25rem; text-transform: none; letter-spacing: 0.01em; color: var(--ink); margin: 2rem 0 0.75rem; }
      h4 { font-family: var(--sans), var(--sans-zh); font-weight: 500; font-size: 1.0625rem; margin: 1.25rem 0 0.5rem; letter-spacing: 0.01em; }
      a { color: var(--m-blue); text-decoration: none; transition: color 0.1s; }
      a:hover { color: var(--m-red); }
      hr { border: 0; border-top: 1px solid var(--rule); margin: 1.5rem 0; }
      .meta { font-family: var(--meta); color: var(--ink-dim); font-size: 0.9rem; font-weight: 300; }
      ol, ul { padding-left: 1.5rem; }
      li { margin: 0.25rem 0; }
      table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
      th, td { text-align: left; padding: 0.625rem 0.875rem; border-bottom: 1px solid var(--rule); }
      th { font-family: var(--sans); font-weight: 500; color: var(--ink-dim); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.18em; }
      code { font-family: var(--mono); background: var(--plate); padding: 0.125rem 0.375rem; font-size: 0.875em; }
      blockquote { margin: 1.25rem 0; padding-left: 1.25rem; border-left: 3px solid var(--m-blue); color: var(--ink-dim); }
      .badge { display: inline-block; font-family: var(--sans); font-size: 0.78rem; padding: 0.25rem 0.75rem; border: 1px solid var(--rule); color: var(--ink-dim); margin-right: 0.5rem; text-transform: uppercase; letter-spacing: 0.18em; font-weight: 500; }
      .badge--seal { background: var(--m-red); color: white; border-color: var(--m-red); }
      .badge--warn { background: var(--m-yellow); border-color: var(--m-yellow); color: #4a3800; }
      .badge--green { background: var(--m-green); color: white; border-color: var(--m-green); }
      /* WP10 Mobile footer — solid dark panel (matches the status bar at
         top), small uppercase letter-spaced text, thin red Metro stripe
         on the left as accent. Full-bleed via negative margin so it
         breaks out of main's max-width. */
      footer {
        view-transition-name: site-footer;
        margin: 4rem calc(-50vw + 50%) 0;
        padding: 1.75rem 1.5rem 2rem 2.75rem;
        max-width: none !important;
        background: #000;
        color: rgba(255,255,255,0.7);
        text-align: left;
        font-family: var(--sans);
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        line-height: 1.85;
        border-top: 0;
        position: relative;
      }
      footer::before {
        content: '';
        position: absolute;
        left: 1.5rem; top: 1.75rem; bottom: 2rem;
        width: 3px;
        background: var(--m-red);
      }
      html[data-theme="light"] footer { background: #1d1d1d; color: rgba(255,255,255,0.7); }
      footer a { color: #fff !important; text-decoration: none; }
      footer a:hover { color: var(--m-red) !important; }

      /* WP10 Mobile status bar — slim, solid (no acrylic on the bar itself),
         app name in small uppercase letter-spaced text. The drawer keeps its
         acrylic; the bar is flat per WP10 status bar convention. */
      .metro-nav {
        background: #000;
        color: #fff;
        padding: 0 0.75rem;
        height: 40px;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        position: sticky;
        top: 0;
        z-index: 50;
        /* Own view-transition-name so the status bar is animated independently
           of the root pivot. Without this it travels with the page slide and
           appears to resize / jiggle on mobile. */
        view-transition-name: status-bar;
      }
      ::view-transition-old(status-bar),
      ::view-transition-new(status-bar) {
        animation: none;   /* nav is persisted; no cross-fade needed */
      }
      .loading-bar { view-transition-name: loading-bar; }
      ::view-transition-old(loading-bar),
      ::view-transition-new(loading-bar) { animation: none; }
      html[data-theme="light"] .metro-nav { background: #1d1d1d; }
      .metro-nav .brand {
        flex: 1;
        justify-content: center;
        display: flex;
        align-items: center;
        color: #fff !important;
        text-decoration: none;
      }
      .metro-nav .brand-name {
        font-family: var(--sans);
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.32em;
        text-transform: uppercase;
        color: #fff;
      }
      .hamburger {
        appearance: none;
        background: transparent;
        border: 0;
        width: 32px; height: 32px;
        display: inline-flex; flex-direction: column; justify-content: center; align-items: center;
        gap: 4px;
        cursor: pointer;
        padding: 0;
        color: #fff;
      }
      .hamburger-bar {
        display: block; width: 18px; height: 1.5px;
        background: currentColor;
        transition: transform var(--fluent-duration-normal) var(--fluent-curve-easy-ease),
                    opacity var(--fluent-duration-fast) ease;
      }
      .hamburger[aria-expanded="true"] .hamburger-bar:nth-child(1) { transform: translateY(5.5px) rotate(45deg); }
      .hamburger[aria-expanded="true"] .hamburger-bar:nth-child(2) { opacity: 0; }
      .hamburger[aria-expanded="true"] .hamburger-bar:nth-child(3) { transform: translateY(-5.5px) rotate(-45deg); }
      .brand { display: flex; align-items: center; gap: 0.75rem; color: white !important; }
      .brand:hover { color: white !important; }
      .brand-seal {
        display: inline-flex; align-items: center; justify-content: center;
        width: 32px; height: 32px;
        background: var(--m-red);
        color: white;
        font-weight: 700; font-size: 18px;
        font-family: var(--serif-zh);
      }
      .brand-name { font-family: var(--sans), var(--sans-zh); font-weight: 300; font-size: 1.125rem; letter-spacing: 0.02em; }
      .locale-switcher { display: flex; gap: 0; align-items: center; }
      .pivot-tab {
        font-family: var(--sans);
        font-size: 0.7rem;
        padding: 0.55rem 0.6rem;
        color: rgba(255,255,255,0.5) !important;
        letter-spacing: 0.22em;
        font-weight: 500;
        text-transform: uppercase;
        text-decoration: none;
        position: relative;
        transition: color var(--fluent-duration-fast) ease;
      }
      .pivot-tab:hover { color: #fff !important; }
      .pivot-tab.active { color: #fff !important; }
      .pivot-tab.active::after {
        content: '';
        position: absolute;
        left: 0.6rem; right: 0.6rem;
        bottom: 0.35rem;
        height: 2px;
        background: var(--m-red);
      }

      .plate { background: var(--plate); padding: 1.25rem 1.5rem; margin: 1.5rem 0; border-left: 3px solid var(--m-blue); }

      /* ===== WP10-style top loading bar ===== */
      .loading-bar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        z-index: 100;
        pointer-events: none;
        background: transparent;
        overflow: hidden;
      }
      .loading-bar::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 30%;
        height: 100%;
        background: linear-gradient(90deg, transparent, var(--m-red), transparent);
        animation: none;
        opacity: 0;
        transition: opacity 0.1s;
      }
      .loading-bar.loading::before {
        opacity: 1;
        animation: wp-loading 1.4s ease-in-out infinite;
      }
      @keyframes wp-loading {
        0%   { transform: translateX(-100%); }
        100% { transform: translateX(400%); }
      }

      /* ===== View Transitions (WP10 hub-slide / pane-pan feel) =====
         Root cross-fade ONLY; per-tile shared-element morph + Continuum
         children cascade do the visible work. Layered slide-out + cascade
         used to fight each other and felt jerky. */
      /* WP10 PIVOT/HUB horizontal slide: forward nav slides old LEFT off,
         new comes IN from the RIGHT. Back nav reverses. Feels like one
         continuous hub with panels — not page-to-page navigation. */
      ::view-transition-old(root) {
        animation: vt-pivot-out-left 340ms cubic-bezier(0.4, 0, 0.6, 1) forwards;
      }
      ::view-transition-new(root) {
        animation: vt-pivot-in-right 500ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }
      html[data-nav="back"] ::view-transition-old(root) {
        animation-name: vt-pivot-out-right;
      }
      html[data-nav="back"] ::view-transition-new(root) {
        animation-name: vt-pivot-in-left;
      }
      @keyframes vt-pivot-out-left {
        0%   { transform: translateX(0);     opacity: 1; }
        100% { transform: translateX(-22%);  opacity: 0; }
      }
      @keyframes vt-pivot-in-right {
        0%   { transform: translateX(22%);   opacity: 0; }
        100% { transform: translateX(0);     opacity: 1; }
      }
      @keyframes vt-pivot-out-right {
        0%   { transform: translateX(0);     opacity: 1; }
        100% { transform: translateX(22%);   opacity: 0; }
      }
      @keyframes vt-pivot-in-left {
        0%   { transform: translateX(-22%);  opacity: 0; }
        100% { transform: translateX(0);     opacity: 1; }
      }

      /* Progressive opacity-only reveal on the incoming page's content.
         Pure fade — no transform, no blur — so it never visually "jumps".
         Runs after the VT pseudo settles via the data-cascade gate. */
      main > * {
        animation: fade-in-soft 520ms cubic-bezier(0.16, 1, 0.3, 1) both;
        animation-play-state: paused;
      }
      html[data-cascade="go"] main > * { animation-play-state: running; }
      main > *:nth-child(1) { animation-delay: 0ms; }
      main > *:nth-child(2) { animation-delay: 70ms; }
      main > *:nth-child(3) { animation-delay: 140ms; }
      main > *:nth-child(4) { animation-delay: 210ms; }
      main > *:nth-child(5) { animation-delay: 280ms; }
      main > *:nth-child(n+6) { animation-delay: 340ms; }
      @keyframes fade-in-soft {
        from { opacity: 0; }
        to   { opacity: 1; }
      }
      @media (prefers-reduced-motion: reduce) {
        main > * { animation: none !important; }
      }

      /* ===== WP10 tile press effect (3D directional tilt toward press point) ===== */
      .wp-tile {
        transition: transform 380ms var(--fluent-curve-spring);
        will-change: transform;
        user-select: none;
        -webkit-tap-highlight-color: transparent;
        --tilt-x: 0deg;
        --tilt-y: 0deg;
      }
      .wp-tile.pressing {
        transform: perspective(800px)
                   rotateX(var(--tilt-x))
                   rotateY(var(--tilt-y))
                   scale(0.96);
        transition: transform 140ms cubic-bezier(0.4, 0.05, 0.6, 0.95);
      }

      /* Reduce motion friendly */
      @media (prefers-reduced-motion: reduce) {
        ::view-transition-old(root), ::view-transition-new(root) { animation: none; }
        .wp-tile.pressing { transform: scale(0.97); }
        .loading-bar.loading::before { animation: none; opacity: 0.5; }
      }

      /* Sharper typography hierarchy — more WP10 (extreme weight contrast) */
      h1 { font-weight: 300; letter-spacing: -0.025em; }
      h2 { font-weight: 300; letter-spacing: -0.015em; }

      /* Pivot horizontal slide — only when <html> has nav-prev / nav-next */
      html.nav-next::view-transition-old(root) {
        animation: slide-out-left var(--fluent-duration-gentle) var(--fluent-curve-accelerate-mid) both;
      }
      html.nav-next::view-transition-new(root) {
        animation: slide-in-right var(--fluent-duration-gentle) var(--fluent-curve-decelerate-mid) both;
      }
      html.nav-prev::view-transition-old(root) {
        animation: slide-out-right var(--fluent-duration-gentle) var(--fluent-curve-accelerate-mid) both;
      }
      html.nav-prev::view-transition-new(root) {
        animation: slide-in-left var(--fluent-duration-gentle) var(--fluent-curve-decelerate-mid) both;
      }

      @keyframes slide-out-left  { to   { transform: translateX(-12%); opacity: 0; } }
      @keyframes slide-in-right  { from { transform: translateX( 12%); opacity: 0; } }
      @keyframes slide-out-right { to   { transform: translateX( 12%); opacity: 0; } }
      @keyframes slide-in-left   { from { transform: translateX(-12%); opacity: 0; } }

      @media (prefers-reduced-motion: reduce) {
        ::view-transition-old(*),
        ::view-transition-new(*) {
          animation: none !important;
        }
      }

      /* ===== Drawer + scrim ===== */
      .drawer-scrim {
        position: fixed; inset: 0;
        background: var(--t-scrim);
        opacity: 0; pointer-events: none;
        transition: opacity var(--fluent-duration-normal) var(--fluent-curve-easy-ease);
        z-index: 90;
      }
      .drawer-scrim.open { opacity: 1; pointer-events: auto; }

      .nav-drawer {
        position: fixed; top: 0; bottom: 0; left: 0;
        width: clamp(260px, 78vw, 320px);
        background: var(--t-drawer-bg);
        backdrop-filter: blur(24px) saturate(180%);
        -webkit-backdrop-filter: blur(24px) saturate(180%);
        color: var(--t-drawer-ink);
        transform: translateX(-100%);
        transition: transform var(--fluent-duration-gentle) var(--fluent-curve-easy-ease);
        z-index: 100;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
        box-shadow: 2px 0 16px rgba(0,0,0,0.35);
      }
      @supports not (backdrop-filter: blur(1px)) {
        .nav-drawer { background: var(--t-acrylic-fallback); }
      }
      .nav-drawer.open { transform: translateX(0); }
      .nav-drawer[aria-hidden="true"] a, .nav-drawer[aria-hidden="true"] button { tab-index: -1; }
      .drawer-inner { padding: 1.25rem 1rem 2rem; display: flex; flex-direction: column; gap: 0.5rem; }

      .drawer-brand { display: flex; align-items: center; gap: 0.75rem; padding: 0.25rem 0 0.75rem; }
      .drawer-brand-name { font-family: var(--sans), var(--sans-zh); font-weight: 300; font-size: 1.5rem; line-height: 1.1; }
      .drawer-brand-name small { display: block; font-size: 0.7rem; opacity: 0.6; letter-spacing: 0.16em; text-transform: uppercase; }

      .drawer-section-label {
        font-family: var(--sans);
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.22em;
        color: var(--t-drawer-dim);
        margin: 1rem 0 0.4rem;
        font-weight: 400;
      }

      .drawer-search-link {
        display: flex; align-items: center; gap: 0.6rem;
        padding: 0.65rem 0.5rem;
        margin: 0.25rem 0 0.5rem;
        color: var(--t-drawer-ink) !important;
        text-decoration: none;
        border: 1px solid rgba(255,255,255,0.14);
        background: rgba(255,255,255,0.04);
        font-family: var(--sans), var(--sans-zh);
        font-weight: 300;
        font-size: 0.95rem;
        transition: background var(--fluent-duration-fast) ease;
      }
      .drawer-search-link:hover { background: rgba(255,255,255,0.10); }
      .drawer-search-icon { font-size: 0.95rem; }

      .drawer-cats { display: flex; flex-direction: column; }
      .drawer-cat {
        display: grid;
        grid-template-columns: 28px 1fr auto;
        gap: 0.75rem;
        align-items: center;
        padding: 0.5rem 0.5rem;
        color: var(--t-drawer-ink) !important;
        text-decoration: none;
        border-left: 3px solid transparent;
        transition: background var(--fluent-duration-fast) ease, border-color var(--fluent-duration-fast) ease;
      }
      .drawer-cat:hover { background: rgba(255,255,255,0.06); border-left-color: var(--m-red); color: var(--t-drawer-ink) !important; }
      .drawer-cat-icon { display: inline-flex; }
      .drawer-cat-name { font-family: var(--sans), var(--sans-zh); font-size: 1.05rem; font-weight: 300; }
      .drawer-cat-count {
        font-family: var(--sans);
        font-size: 0.82rem;
        opacity: 0.7;
        padding: 1px 6px;
        background: rgba(255,255,255,0.10);
        letter-spacing: 0.04em;
      }

      .drawer-rule { border: 0; border-top: 1px solid rgba(255,255,255,0.10); margin: 0.5rem 0; }

      .drawer-locales { display: flex; gap: 0.25rem; }
      .drawer-locale {
        flex: 1;
        text-align: center;
        padding: 0.6rem 0.25rem;
        font-family: var(--sans), var(--sans-zh);
        font-size: 0.9rem;
        font-weight: 300;
        color: var(--t-drawer-dim) !important;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.04);
      }
      .drawer-locale.active { color: var(--t-drawer-ink) !important; background: rgba(255,255,255,0.14); border-color: var(--m-red); }

      .drawer-themes { display: flex; gap: 0.25rem; }
      .drawer-theme {
        flex: 1;
        appearance: none;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.12);
        color: var(--t-drawer-dim);
        padding: 0.6rem 0.25rem;
        font-family: var(--sans), var(--sans-zh);
        font-size: 0.88rem;
        font-weight: 300;
        cursor: pointer;
        transition: background var(--fluent-duration-fast) ease, color var(--fluent-duration-fast) ease;
      }
      .drawer-theme:hover { background: rgba(255,255,255,0.10); color: var(--t-drawer-ink); }
      .drawer-theme[aria-pressed="true"] { background: rgba(255,255,255,0.18); color: var(--t-drawer-ink); border-color: var(--m-red); }

      .drawer-foot { margin-top: 1.75rem; font-size: 0.9rem; opacity: 0.75; font-weight: 300; }
      .drawer-foot a { color: var(--t-drawer-ink); }

      /* The horizontal root pivot (::view-transition-old/new) is the only
         page-to-page motion now. The per-child Continuum cascade was layering
         a second horizontal motion on top, causing jump + double-motion as
         children snapped in at staggered times. Removed for clean WP10
         hub-swipe feel. */

      @media (prefers-reduced-motion: reduce) {
        .nav-drawer, .drawer-scrim, .hamburger-bar { transition: none !important; }
        main > * { animation: none !important; }
      }
    </style>
  </body>
</html>
