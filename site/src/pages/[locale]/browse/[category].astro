---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import CategoryPivot from '~/components/CategoryPivot.astro';
import { commonsThumb } from '~/lib/commonsImage';
import { tileColor as tileColorFor } from '~/lib/categoryColors';

export async function getStaticPaths() {
  const cats = await getCollection('category');
  const paths = [];
  for (const locale of ['zh', 'en', 'yue'] as const) {
    for (const cat of cats) {
      paths.push({ params: { locale, category: cat.id }, props: { cat } });
    }
  }
  return paths;
}

const { locale } = Astro.params as { locale: 'zh' | 'en' | 'yue' };
const { cat } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allDishes = await getCollection('dish');
const dishes = allDishes
  .filter((d) => d.data.category.id === cat.id)
  .sort((a, b) => a.data.menu_no - b.data.menu_no);

const tileColor = tileColorFor(cat.id);

const catName = locale === 'en' ? cat.data.names.en : cat.data.names.yue_hant;
const catDesc = locale === 'en'
  ? (cat.data.description.en ?? cat.data.description.zh)
  : locale === 'yue'
    ? (cat.data.description.yue ?? cat.data.description.zh)
    : cat.data.description.zh;

const dict = {
  zh: { back: '← 回到首頁', menu_no: '菜單編號', complete: '已完成', draft: '草稿', stub: '配料表' },
  en: { back: '← Home', menu_no: 'Menu #', complete: 'complete', draft: 'draft', stub: 'ingredients only' },
  yue: { back: '← 返首頁', menu_no: '菜單編號', complete: '已完成', draft: '草稿', stub: '配料表' },
}[locale];
---
<BaseLayout title={catName} locale={locale}>
  <CategoryPivot currentId={cat.id} locale={locale} />

  <header class="cat-hero" style={`background: ${tileColor}; view-transition-name: tile-${cat.id};`}>
    <div class="cat-no">{dishes.length}</div>
    <h1 class="cat-name">{catName}</h1>
    <p class="cat-desc">{catDesc}</p>
    <p class="cat-langs">
      · {cat.data.names.zh} · {cat.data.names.en}
    </p>
  </header>

  <div class="dish-grid">
    {dishes.map((dish) => {
      const dishName = locale === 'en' ? dish.data.names.en : dish.data.names.yue_hant;
      const statusClass =
        dish.data.method_status === 'complete' ? 'badge--seal' :
        dish.data.method_status === 'draft' ? 'badge--warn' : '';
      const statusLabel =
        dish.data.method_status === 'complete' ? dict.complete :
        dish.data.method_status === 'draft' ? dict.draft : dict.stub;
      const heroImg = dish.data.images?.[0];
      const thumb = heroImg ? commonsThumb(heroImg.path, 800) : null;
      return (
        <a class={`dish-card wp-tile ${thumb ? 'has-back' : ''}`}
           href={`${base}/${locale}/dishes/${dish.id}`}
           style={`--cat-color: ${tileColor}; view-transition-name: dish-${dish.id};`}>
          <div class="card-face card-front">
            <div class="card-no">#{String(dish.data.menu_no).padStart(2, '0')}</div>
            <div class="card-name">{dishName}</div>
            <div class="card-jyut">{dish.data.names.jyutping}</div>
            <div class="card-zh-en">· {dish.data.names.zh} · {dish.data.names.en}</div>
            <div class="card-foot">
              <span class={`badge ${statusClass}`}>{statusLabel}</span>
              <span class="card-ings meta">{dish.data.ingredients.length} ingredients</span>
            </div>
          </div>
          {thumb && (
            <div class="card-face card-back" aria-hidden="true">
              <img class="card-photo" src={thumb} alt="" loading="lazy" decoding="async" />
            </div>
          )}
        </a>
      );
    })}
  </div>

  <footer>
    <a href={`${base}/${locale}`}>{dict.back}</a>
  </footer>
</BaseLayout>

<style>
  main { max-width: 980px !important; }

  /* Category hero — color band kept as morph target from homepage tile, flattened. */
  .cat-hero {
    color: white;
    padding: 2rem 2rem 1.75rem;
    margin: 0.5rem 0 2.5rem;
    position: relative;
  }
  .cat-no {
    font-family: var(--sans);
    font-size: clamp(2.25rem, 8vw, 3.5rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.02em;
  }
  .cat-name {
    font-family: var(--sans), var(--sans-zh);
    font-size: clamp(1.3rem, 4.5vw, 2rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    margin: 0.25rem 0 0.5rem;
    color: white;
    line-height: 1.1;
    overflow-wrap: break-word;
    word-break: break-word;
    hyphens: auto;
  }
  .cat-desc { font-family: var(--sans), var(--sans-zh); font-size: 0.95rem; font-weight: 400; margin: 0.5rem 0 0; opacity: 0.92; max-width: 60ch; }
  .cat-langs { font-family: var(--meta); font-size: 0.8rem; opacity: 0.8; margin-top: 0.75rem; letter-spacing: 0.04em; }

  .dish-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
  }
  @media (max-width: 900px) { .dish-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .dish-grid { grid-template-columns: 1fr; } }

  /* Start Screen size rhythm — every 5th card spans 2 columns (and the
     7th in each set of 10 spans 2 rows) so a long category list still
     looks lively. Stripe + transparent look from prior revision kept. */
  .dish-card:nth-child(5n+1) { grid-column: span 2; }
  .dish-card:nth-child(10n+7) { grid-row: span 2; }
  @media (max-width: 900px) {
    .dish-card:nth-child(5n+1) { grid-column: span 2; }
    .dish-card:nth-child(10n+7) { grid-row: auto; }
  }
  @media (max-width: 520px) {
    .dish-card:nth-child(5n+1) { grid-column: span 1; }
  }

  /* WP10 Live Tile dish-card — solid cat-color front, photo back, X-axis flip.
     Same dynamics as the homepage WIDE tile but applied to every dish-card
     that has a photo. Staggered phase via JS. */
  .dish-card {
    background: var(--cat-color);
    color: white !important;
    text-decoration: none;
    display: block;
    position: relative;
    overflow: hidden;
    min-height: 200px;
    perspective: 1200px;
  }
  .dish-card:hover { color: white !important; }

  .card-face {
    position: absolute;
    inset: 0;
    padding: 1rem 1.25rem 1.125rem;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    transition: transform 0.8s var(--fluent-curve-easy-ease);
    display: flex;
    flex-direction: column;
  }
  .card-back {
    transform: rotateX(180deg);
    padding: 0;
    background: #000;
  }
  .dish-card.flipped .card-front { transform: rotateX(180deg); }
  .dish-card.flipped .card-back  { transform: rotateX(360deg); }

  .card-photo {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Cards with no photo: no flip; the .card-front fills the tile. */
  .dish-card:not(.has-back) .card-front { position: static; }
  .dish-card:not(.has-back) { min-height: 180px; }

  /* Size rhythm: every 5th card spans 2 cols (kept from prior design). */
  .dish-card:nth-child(5n+1) .card-name { font-size: 1.5rem; }
  .dish-card:nth-child(5n+1) { min-height: 220px; }
  .dish-card:hover { background: var(--t-plate); color: var(--t-ink) !important; }
  .card-no {
    font-family: var(--sans);
    font-size: 0.8rem;
    letter-spacing: 0.22em;
    color: rgba(255,255,255,0.75);
    font-weight: 400;
    text-transform: uppercase;
  }
  .card-name {
    font-family: var(--sans), var(--sans-zh);
    font-size: 1.5rem;
    font-weight: 400;
    letter-spacing: 0.005em;
    margin: 0.4rem 0 0.3rem;
    color: white;
    line-height: 1.15;
  }
  .card-jyut {
    font-family: var(--mono);
    font-size: 0.85rem;
    color: rgba(255,255,255,0.78);
  }
  .card-zh-en {
    font-family: var(--sans), var(--sans-zh);
    font-size: 0.9rem;
    color: rgba(255,255,255,0.78);
    margin-top: 0.55rem;
    font-weight: 400;
  }
  .card-foot {
    margin-top: auto;
    padding-top: 0.75rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }
  .card-ings { font-size: 0.85rem; color: rgba(255,255,255,0.85); }
  /* Badges inside colored tiles — translucent, no loud bg. */
  .dish-card .badge {
    background: rgba(255,255,255,0.18) !important;
    color: white !important;
    border: 0 !important;
    font-size: 0.7rem;
    padding: 0.2rem 0.6rem;
    letter-spacing: 0.18em;
  }
</style>

<script>
  // Staggered Live Tile flip on every dish-card that has a back face.
  // Same dynamics as the homepage WIDE tile: 10s period, 1.4s per-tile
  // phase offset so the panel feels alive without all tiles syncing.
  // Re-inits on astro:page-load and stops on astro:before-preparation.
  {
    const PERIOD = 10000;
    const STEP = 1400;
    let timers: number[] = [];

    function flip(t: HTMLElement) {
      if (document.hidden) return;
      if (t.classList.contains('pressing')) return;
      t.classList.toggle('flipped');
    }
    function stopFlip() {
      timers.forEach((id) => { window.clearTimeout(id); window.clearInterval(id); });
      timers = [];
    }
    function startFlip() {
      stopFlip();
      const tiles = Array.from(document.querySelectorAll<HTMLElement>('.dish-card.has-back'));
      tiles.forEach((t, i) => {
        const offset = (i * STEP) % PERIOD;
        const initial = window.setTimeout(() => {
          flip(t);
          const id = window.setInterval(() => flip(t), PERIOD);
          timers.push(id);
        }, offset);
        timers.push(initial);
      });
    }
    startFlip();
    document.addEventListener('astro:page-load', () => {
      if (document.querySelector('.dish-card.has-back')) startFlip();
      else stopFlip();
    });
    document.addEventListener('astro:before-preparation', stopFlip);
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stopFlip();
      else if (document.querySelector('.dish-card.has-back')) startFlip();
    });
  }
</script>
