---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import CategoryPivot from '~/components/CategoryPivot.astro';

export async function getStaticPaths() {
  const cats = await getCollection('category');
  const paths = [];
  for (const locale of ['zh', 'en', 'yue'] as const) {
    for (const cat of cats) {
      paths.push({ params: { locale, category: cat.id }, props: { cat } });
    }
  }
  return paths;
}

const { locale } = Astro.params as { locale: 'zh' | 'en' | 'yue' };
const { cat } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allDishes = await getCollection('dish');
const dishes = allDishes
  .filter((d) => d.data.category.id === cat.id)
  .sort((a, b) => a.data.menu_no - b.data.menu_no);

const tileColors: Record<string, string> = {
  appetizer: '#B71C1C', 'soup-wonton': '#1565C0', rice: '#E65100',
  noodle: '#2E7D32', 'soup-noodle': '#00838F', 'baked-rice': '#6D4C41',
  congee: '#6A1B9A', main: '#263238',
};
const tileColor = tileColors[cat.id] ?? '#37474F';

const catName = locale === 'en' ? cat.data.names.en : cat.data.names.yue_hant;
const catDesc = locale === 'en'
  ? (cat.data.description.en ?? cat.data.description.zh)
  : locale === 'yue'
    ? (cat.data.description.yue ?? cat.data.description.zh)
    : cat.data.description.zh;

const dict = {
  zh: { back: '← 回到首頁', menu_no: '菜單編號', complete: '已完成', draft: '草稿', stub: '配料表' },
  en: { back: '← Home', menu_no: 'Menu #', complete: 'complete', draft: 'draft', stub: 'ingredients only' },
  yue: { back: '← 返首頁', menu_no: '菜單編號', complete: '已完成', draft: '草稿', stub: '配料表' },
}[locale];
---
<BaseLayout title={catName} locale={locale}>
  <CategoryPivot currentId={cat.id} locale={locale} />

  <header class="cat-hero" style={`background: ${tileColor}; view-transition-name: tile-${cat.id};`}>
    <div class="cat-no">{dishes.length}</div>
    <h1 class="cat-name">{catName}</h1>
    <p class="cat-desc">{catDesc}</p>
    <p class="cat-langs">
      · {cat.data.names.zh} · {cat.data.names.en}
    </p>
  </header>

  <div class="dish-grid">
    {dishes.map((dish) => {
      const dishName = locale === 'en' ? dish.data.names.en : dish.data.names.yue_hant;
      const statusClass =
        dish.data.method_status === 'complete' ? 'badge--seal' :
        dish.data.method_status === 'draft' ? 'badge--warn' : '';
      const statusLabel =
        dish.data.method_status === 'complete' ? dict.complete :
        dish.data.method_status === 'draft' ? dict.draft : dict.stub;
      return (
        <a class="dish-card wp-tile"
           href={`${base}/${locale}/dishes/${dish.id}`}
           style={`--cat-color: ${tileColor}; view-transition-name: dish-${dish.id};`}>
          <div class="card-no">#{String(dish.data.menu_no).padStart(2, '0')}</div>
          <div class="card-name">{dishName}</div>
          <div class="card-jyut">{dish.data.names.jyutping}</div>
          <div class="card-zh-en">· {dish.data.names.zh} · {dish.data.names.en}</div>
          <div class="card-foot">
            <span class={`badge ${statusClass}`}>{statusLabel}</span>
            <span class="card-ings meta">{dish.data.ingredients.length} ingredients</span>
          </div>
        </a>
      );
    })}
  </div>

  <footer>
    <a href={`${base}/${locale}`}>{dict.back}</a>
  </footer>
</BaseLayout>

<style>
  main { max-width: 980px !important; }

  .cat-hero {
    color: white;
    padding: 2.5rem 2rem;
    margin: 1rem 0 2.5rem;
  }
  .cat-no {
    font-family: var(--display);
    font-size: 4rem;
    font-weight: 700;
    line-height: 1;
  }
  .cat-name {
    font-family: var(--serif-zh);
    font-size: 2.25rem;
    margin: 0.5rem 0 0.5rem;
    color: white;
  }
  .cat-desc { font-family: var(--serif-en); font-size: 1rem; margin: 0.5rem 0; opacity: 0.92; }
  .cat-langs { font-family: var(--meta); font-size: 0.875rem; opacity: 0.85; margin-top: 0.5rem; }

  .dish-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 8px;
  }
  .dish-card {
    background: var(--plate);
    color: var(--ink);
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    border: 1px solid transparent;
    border-top: 6px solid var(--cat-color);
    border-bottom: 1px solid var(--rule);
    transition: background 0.15s, transform 0.15s;
    display: flex;
    flex-direction: column;
  }
  .dish-card:hover { background: #F3EAD3; transform: translateY(-1px); }
  .card-no {
    font-family: var(--meta);
    font-size: 0.6875rem;
    letter-spacing: 0.15em;
    color: var(--seal);
    font-weight: 600;
  }
  .card-name {
    font-family: var(--serif-zh);
    font-size: 1.375rem;
    font-weight: 600;
    margin: 0.25rem 0 0.25rem;
  }
  .card-jyut {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--ink-dim);
  }
  .card-zh-en {
    font-family: var(--meta);
    font-size: 0.8125rem;
    color: var(--ink-dim);
    margin-top: 0.5rem;
  }
  .card-foot {
    margin-top: auto;
    padding-top: 0.75rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }
  .card-ings { font-size: 0.75rem; }
</style>
