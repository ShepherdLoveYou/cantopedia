---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import CategoryPivot from '~/components/CategoryPivot.astro';

export async function getStaticPaths() {
  const cats = await getCollection('category');
  const paths = [];
  for (const locale of ['zh', 'en', 'yue'] as const) {
    for (const cat of cats) {
      paths.push({ params: { locale, category: cat.id }, props: { cat } });
    }
  }
  return paths;
}

const { locale } = Astro.params as { locale: 'zh' | 'en' | 'yue' };
const { cat } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allDishes = await getCollection('dish');
const dishes = allDishes
  .filter((d) => d.data.category.id === cat.id)
  .sort((a, b) => a.data.menu_no - b.data.menu_no);

const tileColors: Record<string, string> = {
  appetizer: '#B71C1C', 'soup-wonton': '#1565C0', rice: '#E65100',
  noodle: '#2E7D32', 'soup-noodle': '#00838F', 'baked-rice': '#6D4C41',
  congee: '#6A1B9A', main: '#263238',
};
const tileColor = tileColors[cat.id] ?? '#37474F';

const catName = locale === 'en' ? cat.data.names.en : cat.data.names.yue_hant;
const catDesc = locale === 'en'
  ? (cat.data.description.en ?? cat.data.description.zh)
  : locale === 'yue'
    ? (cat.data.description.yue ?? cat.data.description.zh)
    : cat.data.description.zh;

const dict = {
  zh: { back: '← 回到首頁', menu_no: '菜單編號', complete: '已完成', draft: '草稿', stub: '配料表' },
  en: { back: '← Home', menu_no: 'Menu #', complete: 'complete', draft: 'draft', stub: 'ingredients only' },
  yue: { back: '← 返首頁', menu_no: '菜單編號', complete: '已完成', draft: '草稿', stub: '配料表' },
}[locale];
---
<BaseLayout title={catName} locale={locale}>
  <CategoryPivot currentId={cat.id} locale={locale} />

  <header class="cat-hero" style={`background: ${tileColor}; view-transition-name: tile-${cat.id};`}>
    <div class="cat-no">{dishes.length}</div>
    <h1 class="cat-name">{catName}</h1>
    <p class="cat-desc">{catDesc}</p>
    <p class="cat-langs">
      · {cat.data.names.zh} · {cat.data.names.en}
    </p>
  </header>

  <div class="dish-grid">
    {dishes.map((dish) => {
      const dishName = locale === 'en' ? dish.data.names.en : dish.data.names.yue_hant;
      const statusClass =
        dish.data.method_status === 'complete' ? 'badge--seal' :
        dish.data.method_status === 'draft' ? 'badge--warn' : '';
      const statusLabel =
        dish.data.method_status === 'complete' ? dict.complete :
        dish.data.method_status === 'draft' ? dict.draft : dict.stub;
      return (
        <a class="dish-card wp-tile"
           href={`${base}/${locale}/dishes/${dish.id}`}
           style={`--cat-color: ${tileColor}; view-transition-name: dish-${dish.id};`}>
          <div class="card-no">#{String(dish.data.menu_no).padStart(2, '0')}</div>
          <div class="card-name">{dishName}</div>
          <div class="card-jyut">{dish.data.names.jyutping}</div>
          <div class="card-zh-en">· {dish.data.names.zh} · {dish.data.names.en}</div>
          <div class="card-foot">
            <span class={`badge ${statusClass}`}>{statusLabel}</span>
            <span class="card-ings meta">{dish.data.ingredients.length} ingredients</span>
          </div>
        </a>
      );
    })}
  </div>

  <footer>
    <a href={`${base}/${locale}`}>{dict.back}</a>
  </footer>
</BaseLayout>

<style>
  main { max-width: 980px !important; }

  /* Category hero — color band kept as morph target from homepage tile, flattened. */
  .cat-hero {
    color: white;
    padding: 2rem 2rem 1.75rem;
    margin: 0.5rem 0 2.5rem;
    position: relative;
  }
  .cat-no {
    font-family: var(--sans);
    font-size: 3.5rem;
    font-weight: 200;
    line-height: 0.95;
    letter-spacing: -0.02em;
  }
  .cat-name {
    font-family: var(--sans), var(--sans-zh);
    font-size: 2rem;
    font-weight: 200;
    letter-spacing: -0.01em;
    margin: 0.25rem 0 0.5rem;
    color: white;
  }
  .cat-desc { font-family: var(--sans), var(--sans-zh); font-size: 0.95rem; font-weight: 300; margin: 0.5rem 0 0; opacity: 0.92; max-width: 60ch; }
  .cat-langs { font-family: var(--meta); font-size: 0.8rem; opacity: 0.8; margin-top: 0.75rem; letter-spacing: 0.04em; }

  /* WP10 Start Screen dish-grid — colored tiles with size variety for rhythm. */
  .dish-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: minmax(140px, auto);
    gap: 8px;
  }
  @media (max-width: 900px) {
    .dish-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .dish-grid { grid-template-columns: 1fr; }
  }

  /* dish-card is a colored tile: cat-color bg, white text, no stripe. */
  .dish-card {
    background: var(--cat-color);
    color: white !important;
    padding: 1rem 1.125rem 1rem;
    text-decoration: none;
    transition: filter var(--fluent-duration-fast) ease;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    min-height: 140px;
  }
  .dish-card::before {
    /* Subtle inner darkening at the bottom for text legibility on bright tile colors. */
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0) 40%, rgba(0,0,0,0.18) 100%);
    pointer-events: none;
  }
  .dish-card:hover { filter: brightness(1.08); color: white !important; }

  /* Size variety for Start Screen rhythm — every 5th card spans 2 columns
     (and is taller). Pattern repeats so any category length looks lively. */
  .dish-card:nth-child(5n+1) { grid-column: span 2; min-height: 180px; }
  @media (max-width: 900px) {
    .dish-card:nth-child(5n+1) { grid-column: span 2; }
  }
  @media (max-width: 520px) {
    .dish-card:nth-child(5n+1) { grid-column: span 1; min-height: 140px; }
  }

  .card-no {
    font-family: var(--sans);
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    color: rgba(255,255,255,0.7);
    font-weight: 500;
    text-transform: uppercase;
    position: relative;
    z-index: 1;
  }
  .card-name {
    font-family: var(--sans), var(--sans-zh);
    font-size: 1.25rem;
    font-weight: 300;
    letter-spacing: 0.005em;
    margin: 0.35rem 0 0.35rem;
    color: white;
    line-height: 1.2;
    position: relative;
    z-index: 1;
  }
  .dish-card:nth-child(5n+1) .card-name { font-size: 1.5rem; }
  .card-jyut {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: rgba(255,255,255,0.78);
    position: relative;
    z-index: 1;
  }
  .card-zh-en {
    font-family: var(--meta);
    font-size: 0.78rem;
    color: rgba(255,255,255,0.78);
    margin-top: 0.4rem;
    position: relative;
    z-index: 1;
  }
  .card-foot {
    margin-top: auto;
    padding-top: 0.6rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    position: relative;
    z-index: 1;
  }
  .card-ings { font-size: 0.72rem; color: rgba(255,255,255,0.85); }
  /* Restyle badges inside colored tiles — subtle outline, not loud bg. */
  .dish-card .badge {
    background: rgba(255,255,255,0.16) !important;
    color: white !important;
    border: 0 !important;
    font-size: 0.62rem;
    padding: 0.15rem 0.55rem;
    letter-spacing: 0.08em;
  }
  .dish-card .badge--warn { background: rgba(255,255,255,0.32) !important; color: #2a1a00 !important; }
</style>
