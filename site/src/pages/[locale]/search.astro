---
import BaseLayout from '~/layouts/BaseLayout.astro';
import HubPivot from '~/components/HubPivot.astro';

export async function getStaticPaths() {
  return [
    { params: { locale: 'zh' } },
    { params: { locale: 'en' } },
    { params: { locale: 'yue' } },
  ];
}

const { locale } = Astro.params as { locale: 'zh' | 'en' | 'yue' };
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const dict = {
  zh: { title: '搜尋', placeholder: '搜尋菜式、配料、醬料…', hint: '輸入關鍵字（粵 / 中 / English / jyutping 都可以）', empty: '輸入關鍵字開始搜尋。', no_results: '冇結果。試試其他關鍵字？' },
  en: { title: 'Search', placeholder: 'Search dishes, ingredients, sauces…', hint: 'Enter a keyword in Cantonese, Chinese, English, or Jyutping.', empty: 'Type a keyword to start searching.', no_results: 'No results. Try a different keyword?' },
  yue: { title: '搵', placeholder: '搵餸、食材、醬料…', hint: '入關鍵字（粵 / 中 / English / jyutping 都得）', empty: '入關鍵字開始搵。', no_results: '冇結果。試下其他關鍵字？' },
}[locale];
---
<BaseLayout title={dict.title} locale={locale}>
  <HubPivot initialTitle={dict.title} />

  <section class="search-section">
    <input
      id="q"
      class="search-input"
      type="search"
      autocomplete="off"
      autocapitalize="none"
      spellcheck="false"
      placeholder={dict.placeholder}
      aria-label={dict.title}
    />
    <ul id="results" class="search-results" data-empty={dict.empty} data-noresults={dict.no_results}>
      <li class="search-status">{dict.empty}</li>
    </ul>
  </section>
</BaseLayout>

<script define:vars={{ base }}>
  let pagefind;
  const q = document.getElementById('q');
  const results = document.getElementById('results');
  const emptyMsg = results.dataset.empty;
  const noResultsMsg = results.dataset.noresults;

  async function ensurePagefind() {
    if (pagefind) return pagefind;
    // Pagefind ships its own JS bundle at /pagefind/pagefind.js relative to site root.
    pagefind = await import(`${base}/pagefind/pagefind.js`);
    await pagefind.options({ baseUrl: base + '/' });
    return pagefind;
  }

  async function runSearch(term) {
    if (!term.trim()) {
      results.innerHTML = `<li class="search-status">${emptyMsg}</li>`;
      return;
    }
    try {
      const pf = await ensurePagefind();
      const { results: hits } = await pf.search(term);
      if (hits.length === 0) {
        results.innerHTML = `<li class="search-status">${noResultsMsg}</li>`;
        return;
      }
      const top = hits.slice(0, 20);
      const html = await Promise.all(
        top.map(async (h) => {
          const data = await h.data();
          return `
            <li class="search-hit">
              <a href="${data.url.replace(/\/$/, '')}">
                <span class="app-list-thumb"></span>
                <span class="app-list-text">
                  <span class="app-list-name">${data.meta?.title ?? data.url}</span>
                  <span class="app-list-meta">${data.excerpt}</span>
                </span>
              </a>
            </li>
          `;
        })
      );
      results.innerHTML = html.join('');
    } catch (err) {
      // Pagefind not yet built locally (dev mode) — show friendly notice
      results.innerHTML = `<li class="search-status">Search index not available in dev. Run <code>pnpm build</code>.</li>`;
    }
  }

  let timer;
  q.addEventListener('input', () => {
    clearTimeout(timer);
    timer = setTimeout(() => runSearch(q.value), 120);
  });

  // Honor ?q= on initial load
  const urlQ = new URL(location.href).searchParams.get('q');
  if (urlQ) { q.value = urlQ; runSearch(urlQ); }
  q.focus();
</script>

<style>
  .search-section { max-width: 760px; margin: 0 auto; padding: var(--sp-4) var(--sp-5); }

  .search-input {
    width: 100%;
    padding: var(--sp-3) var(--sp-4);
    font-family: var(--lang-font-primary);
    font-size: var(--fs-panel);
    background: var(--t-card);
    color: var(--t-ink);
    border: 1px solid var(--t-ink);
    border-radius: 0;
    outline: none;
    transition: border-color 120ms ease;
  }
  .search-input::placeholder { color: var(--t-ink-dim); opacity: 0.6; }
  .search-input:focus { border-color: var(--m-red); background: var(--t-ink); color: #fff; }

  .search-results { list-style: none; padding: 0; margin: var(--sp-4) 0 0; }
  .search-status { padding: var(--sp-5); text-align: center; color: var(--t-ink-dim); }

  .search-hit { display: block; }
  .search-hit a {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: var(--sp-4);
    align-items: center;
    padding: var(--sp-3) var(--sp-2);
    color: var(--t-ink);
    text-decoration: none;
    border-bottom: 1px solid var(--t-rule);
    transition: background 120ms ease;
    animation: hit-enter 280ms var(--fluent-curve-decelerate-mid, ease-out) backwards;
  }
  .search-hit:nth-child(1)  a { animation-delay: 0ms; }
  .search-hit:nth-child(2)  a { animation-delay: 30ms; }
  .search-hit:nth-child(3)  a { animation-delay: 60ms; }
  .search-hit:nth-child(4)  a { animation-delay: 90ms; }
  .search-hit:nth-child(5)  a { animation-delay: 120ms; }
  .search-hit:nth-child(6)  a { animation-delay: 150ms; }
  .search-hit:nth-child(7)  a { animation-delay: 180ms; }
  .search-hit:nth-child(8)  a { animation-delay: 210ms; }
  .search-hit:nth-child(9)  a { animation-delay: 240ms; }
  .search-hit:nth-child(n+10) a { animation-delay: 270ms; }
  @keyframes hit-enter {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .search-hit a { animation: none; }
  }
  .search-hit a:hover { background: var(--t-plate); }

  .app-list-thumb { width: 64px; height: 64px; background: var(--t-plate-dark); flex-shrink: 0; }
  .app-list-text { display: flex; flex-direction: column; gap: 0.2rem; min-width: 0; }
  .app-list-name {
    font-family: var(--sans), var(--sans-zh);
    font-size: var(--fs-panel);
    font-weight: var(--fw-regular);
    line-height: 1.25;
    color: var(--t-ink);
  }
  .app-list-meta {
    font-family: var(--mono);
    font-size: var(--fs-caption);
    color: var(--t-ink-dim);
    letter-spacing: var(--ls-meta);
  }
  .app-list-meta :global(mark) {
    background: var(--m-yellow);
    color: var(--t-ink);
    padding: 0 2px;
  }
</style>
