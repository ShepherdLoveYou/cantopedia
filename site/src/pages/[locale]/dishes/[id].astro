---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { commonsThumb, commonsPageUrl } from '~/lib/commonsImage';
import { tileColor as tileColorFor } from '~/lib/categoryColors';

export async function getStaticPaths() {
  const dishes = await getCollection('dish');
  const paths = [];
  for (const locale of ['zh', 'en', 'yue'] as const) {
    for (const dish of dishes) {
      paths.push({ params: { locale, id: dish.id }, props: { dish } });
    }
  }
  return paths;
}

const { locale } = Astro.params as { locale: 'zh' | 'en' | 'yue' };
const { dish } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const category = await getEntry('category', dish.data.category.id);
const sauce = dish.data.sauce ? await getEntry('sauce', dish.data.sauce.id) : null;

type SourceRefData = { source_id: string; url?: string; accessed: string; note?: string };
const sources: { ref: SourceRefData; entry: Awaited<ReturnType<typeof getEntry>> }[] = [];
for (const s of dish.data.sources as SourceRefData[]) {
  const entry = await getEntry('source', s.source_id);
  if (entry) sources.push({ ref: s, entry });
}
const ingredientRefs = await Promise.all(
  dish.data.ingredients.map(async (i: { ref: { id: string }; qty: number; unit: string; prep?: any }) => ({
    ...i,
    entry: await getEntry('ingredient', i.ref.id),
  }))
);

const catColor = tileColorFor(dish.data.category.id);

function tNames(names: any, prefer = locale): string {
  if (prefer === 'en') return names.en;
  if (prefer === 'yue') return names.yue_hant;
  return names.yue_hant || names.zh;
}

function tBody(body: any, prefer = locale): string {
  if (!body) return '';
  if (prefer === 'en' && body.en) return body.en;
  if (prefer === 'yue' && body.yue) return body.yue;
  return body.zh ?? body.yue ?? body.en ?? '';
}

function langOfBody(body: any, prefer = locale): 'yue' | 'zh' | 'en' {
  if (prefer === 'en' && body?.en) return 'en';
  if (prefer === 'yue' && body?.yue) return 'yue';
  return 'zh';
}

const dict = {
  zh: {
    ingredients: '配料', method: '做法', tips: '小貼士', history: '由來', sources: '引用源',
    sauce_link: '關聯醬料', servings: '份量', difficulty: '難度', equipment: '設備', allergens: '過敏原',
    prep: '備料', cook: '烹飪', minutes: '分鐘', stub_warn: '此菜暫只有配料表，做法待補。',
    draft_warn: '此做法為流水線初稿，待人工校對。',
    cite: '引用', back_home: '首頁', back_cat: category?.data.names.yue_hant ?? 'Category',
    fallback_note: '此段以普通話呈現（粵文待補）',
    item_no: '菜單編號',
  },
  en: {
    ingredients: 'Ingredients', method: 'Method', tips: 'Tips', history: 'History', sources: 'Sources',
    sauce_link: 'Linked sauce', servings: 'Servings', difficulty: 'Difficulty', equipment: 'Equipment', allergens: 'Allergens',
    prep: 'Prep', cook: 'Cook', minutes: 'min', stub_warn: 'Ingredients listed only — the cooking method has not yet been written.',
    draft_warn: 'Auto-generated draft — pending human review.',
    cite: 'cite', back_home: 'Home', back_cat: category?.data.names.en ?? 'Category',
    fallback_note: 'Translation pending — showing Chinese original',
    item_no: 'Menu #',
  },
  yue: {
    ingredients: '配料', method: '做法', tips: '貼士', history: '由來', sources: '引用源',
    sauce_link: '關聯醬料', servings: '份量', difficulty: '難度', equipment: '設備', allergens: '過敏原',
    prep: '備料', cook: '烹飪', minutes: '分鐘', stub_warn: '此菜淨係有配料，做法仲未寫。',
    draft_warn: '此做法係流水線初稿，未經人工校對。',
    cite: '引用', back_home: '首頁', back_cat: category?.data.names.yue_hant ?? 'Category',
    fallback_note: '此段以普通話呈現（粵文待補）',
    item_no: '菜單編號',
  },
}[locale];

const title = locale === 'en' ? dish.data.names.en : dish.data.names.yue_hant;
---
<BaseLayout title={title} locale={locale}>
  <nav class="crumbs">
    <a href={`${base}/${locale}`}>{dict.back_home}</a>
    <span class="sep">›</span>
    <a href={`${base}/${locale}/browse/${dish.data.category.id}`}>{dict.back_cat}</a>
    <span class="sep">›</span>
    <span class="meta">#{String(dish.data.menu_no).padStart(2, '0')}</span>
  </nav>

  <header class={`hero-band ${dish.data.images?.[0] ? 'has-photo' : ''}`} style={`background: ${catColor}; view-transition-name: dish-${dish.id};`}>
    {dish.data.images?.[0] && (
      <img class="hero-photo" src={commonsThumb(dish.data.images[0].path, 1400)} alt={`${dish.data.names.yue_hant} · ${dish.data.names.en}`} loading="eager" decoding="async" />
    )}
    <div class="hero-no">#{String(dish.data.menu_no).padStart(2, '0')}</div>
    <h1 class="hero-name">{dish.data.names.yue_hant}</h1>
    <div class="hero-jyut">{dish.data.names.jyutping}</div>
    <div class="hero-alt">
      <span class="alt-zh">{dish.data.names.zh}</span>
      <span class="alt-sep">·</span>
      <span class="alt-en">{dish.data.names.en}</span>
    </div>
    <div class="hero-tags">
      <span class="htag">{category?.data.names[locale === 'en' ? 'en' : 'yue_hant']}</span>
      {dish.data.difficulty && <span class="htag">{dict.difficulty}: {dish.data.difficulty}</span>}
      {dish.data.time_minutes && (
        <span class="htag">⏱ {dish.data.time_minutes.prep + dish.data.time_minutes.cook} {dict.minutes}</span>
      )}
      <span class="htag">👥 {dish.data.servings}</span>
      {dish.data.method_status === 'complete' && <span class="htag htag-on">✓ {dict.method}</span>}
      {dish.data.method_status === 'draft' && <span class="htag htag-warn">{dict.method} draft</span>}
    </div>
    {dish.data.images?.[0] && (
      <div class="hero-credit">
        <a href={commonsPageUrl(dish.data.images[0].path)} target="_blank" rel="noopener">
          {dish.data.images[0].license} · {dish.data.images[0].credit || 'Wikimedia Commons'} ↗
        </a>
      </div>
    )}
  </header>

  <div class="dish-grid">
    <main class="dish-main">
      {dish.data.method_status === 'stub' && (
        <div class="alert alert-warn">
          <strong>⚠️</strong> {dict.stub_warn}
        </div>
      )}
      {dish.data.method_status === 'draft' && (
        <div class="alert alert-warn">
          <strong>⚠️</strong> {dict.draft_warn}
        </div>
      )}

      <h2>{dict.ingredients}</h2>
      <table class="ing-table">
        <thead>
          <tr>
            <th>{locale === 'en' ? 'Ingredient' : '食材'}</th>
            <th style="text-align: right;">{locale === 'en' ? 'Qty' : '份量'}</th>
            <th>{locale === 'en' ? 'Prep' : '處理'}</th>
          </tr>
        </thead>
        <tbody>
          {ingredientRefs.map((ing) => (
            <tr>
              <td>
                <a href={`${base}/${locale}/ingredients/${ing.entry?.id}`}>
                  {ing.entry ? tNames(ing.entry.data.names) : ing.ref.id}
                </a>
              </td>
              <td style="text-align: right; font-variant-numeric: tabular-nums;">{ing.qty} <span class="meta">{ing.unit}</span></td>
              <td class="meta">{ing.prep ? tBody(ing.prep) : ''}</td>
            </tr>
          ))}
        </tbody>
      </table>

      {sauce && (
        <a class="sauce-card" href={`${base}/${locale}/sauces/${sauce.id}`}>
          <div class="sauce-label">{dict.sauce_link}</div>
          <div class="sauce-name">{locale === 'en' ? sauce.data.names.en : sauce.data.names.yue_hant}</div>
          <span class="sauce-chev">›</span>
        </a>
      )}

      {dish.data.method_status !== 'stub' && dish.data.method && (
        <>
          <h2>{dict.method}</h2>
          <ol class="method-list">
            {dish.data.method.map((step: any) => {
              const lang = langOfBody(step.body);
              const fallback = (locale !== 'zh' && lang === 'zh');
              return (
                <li class="method-step">
                  <div class="step-no" style={`background: ${catColor}`}>{step.order}</div>
                  <div class="step-body">
                    <div class={`step-text ${fallback ? 'fallback' : ''}`}>{tBody(step.body)}</div>
                    {fallback && <div class="step-fallback">{dict.fallback_note}</div>}
                    {(step.temperature_c || step.time_seconds) && (
                      <div class="step-meta">
                        {step.temperature_c && <span class="chip">🌡 {step.temperature_c}°C</span>}
                        {step.time_seconds && <span class="chip">⏱ {Math.round(step.time_seconds / 60)} {dict.minutes}</span>}
                      </div>
                    )}
                    {step.cite && step.cite.length > 0 && (
                      <div class="step-cite">
                        {step.cite.map((c: string) => (
                          <a href={`#source-${c}`}>[{c}]</a>
                        ))}
                      </div>
                    )}
                  </div>
                </li>
              );
            })}
          </ol>
        </>
      )}

      {dish.data.tips && dish.data.tips.length > 0 && (
        <>
          <h2>{dict.tips}</h2>
          <ul class="tips">
            {dish.data.tips.map((tip: any) => (
              <li>{tBody(tip)}</li>
            ))}
          </ul>
        </>
      )}

      {dish.data.history && (
        <>
          <h2>{dict.history}</h2>
          <p class="history">{tBody(dish.data.history)}</p>
        </>
      )}

      {dish.data.allergens && dish.data.allergens.length > 0 && (
        <>
          <h3>{dict.allergens}</h3>
          <div>
            {dish.data.allergens.map((a: string) => <span class="badge">{a}</span>)}
          </div>
        </>
      )}

      <h2>{dict.sources}</h2>
      <ol class="sources">
        {sources.map(({ ref, entry }) => (
          <li id={`source-${ref.source_id}`}>
            <div class="src-title">
              {entry ? (
                <>
                  {entry.data.url ? (
                    <a href={entry.data.url}>{entry.data.title}</a>
                  ) : entry.data.title}
                </>
              ) : ref.source_id}
            </div>
            <div class="src-meta meta">
              {entry?.data.license && <span>{entry.data.license}</span>}
              <span class="dot">·</span>
              <span>accessed {ref.accessed}</span>
              {ref.note && <><span class="dot">·</span><span>{ref.note}</span></>}
            </div>
          </li>
        ))}
      </ol>
    </main>

    <aside class="dish-aside">
      <div class="aside-card">
        <h3 style="margin-top: 0;">{dict.item_no}</h3>
        <div class="aside-val">#{String(dish.data.menu_no).padStart(2, '0')}</div>
      </div>
      {dish.data.time_minutes && (
        <div class="aside-card">
          <h3 style="margin-top: 0;">{dict.prep} · {dict.cook}</h3>
          <div class="aside-val">{dish.data.time_minutes.prep} + {dish.data.time_minutes.cook} {dict.minutes}</div>
        </div>
      )}
      {dish.data.equipment && dish.data.equipment.length > 0 && (
        <div class="aside-card">
          <h3 style="margin-top: 0;">{dict.equipment}</h3>
          <div>
            {dish.data.equipment.map((e: string) => <span class="badge">{e}</span>)}
          </div>
        </div>
      )}
      <div class="aside-card">
        <h3 style="margin-top: 0;">{locale === 'en' ? 'Status' : '狀態'}</h3>
        <div>
          {dish.data.method_status === 'complete' && <span class="badge badge--green">✓ {dict.method}</span>}
          {dish.data.method_status === 'draft' && <span class="badge badge--warn">{dict.method} · draft</span>}
          {dish.data.method_status === 'stub' && <span class="badge">{dict.ingredients} {locale === 'en' ? 'only' : '僅有'}</span>}
        </div>
      </div>
    </aside>
  </div>

  <footer>
    <a href={`${base}/${locale}/browse/${dish.data.category.id}`}>‹ {dict.back_cat}</a>
    <span style="margin: 0 0.5rem; color: var(--rule);">·</span>
    <a href={`${base}/${locale}`}>{dict.back_home}</a>
  </footer>
</BaseLayout>

<style>
  .crumbs {
    font-family: var(--sans);
    font-size: 0.8125rem;
    margin: -0.5rem 0 1.5rem;
    color: var(--ink-dim);
  }
  .crumbs a { color: var(--ink-dim); }
  .crumbs a:hover { color: var(--m-red); }
  .crumbs .sep { margin: 0 0.5rem; opacity: 0.5; }

  .hero-band {
    color: white;
    padding: 2rem 2rem 2rem;
    margin: 0 -1.5rem 2rem;
    position: relative;
    overflow: hidden;
  }
  .hero-band.has-photo { padding: 2.5rem 2rem 3rem; min-height: 320px; }
  .hero-photo {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .hero-band.has-photo::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg,
      color-mix(in srgb, var(--cat-color, #000) 78%, transparent) 0%,
      rgba(0,0,0,0.35) 100%);
    z-index: 1;
    pointer-events: none;
  }
  .hero-band.has-photo > *:not(.hero-photo) { position: relative; z-index: 2; }
  .hero-credit {
    margin-top: 1.25rem;
    font-family: var(--sans);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.75;
  }
  .hero-credit a { color: rgba(255,255,255,0.85) !important; text-decoration: none; }
  .hero-credit a:hover { color: white !important; text-decoration: underline; }
  .hero-no {
    font-family: var(--sans);
    font-size: 0.85rem;
    letter-spacing: 0.22em;
    opacity: 0.75;
    text-transform: uppercase;
    font-weight: 400;
  }
  .hero-name {
    font-family: var(--sans), var(--sans-zh);
    font-size: clamp(var(--lang-h1-size), 6vw, 3rem);
    font-weight: 400;
    letter-spacing: -0.015em;
    color: white;
    margin: 0.25rem 0 0.25rem;
    line-height: 1.05;
    overflow-wrap: break-word;
    word-break: break-word;
    hyphens: auto;
  }
  .hero-jyut {
    font-family: var(--mono);
    font-size: 1rem;
    opacity: 0.9;
  }
  .hero-alt {
    margin-top: 0.6rem;
    font-family: var(--sans), var(--sans-zh);
    font-size: 1.15rem;
    font-weight: 400;
    opacity: 0.95;
  }
  .alt-sep { margin: 0 0.5rem; opacity: 0.6; }

  .hero-tags { margin-top: 1.25rem; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .htag {
    background: rgba(255,255,255,0.16);
    padding: 0.35rem 0.9rem;
    font-family: var(--sans);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    font-weight: 400;
  }
  .htag-on   { background: rgba(255,255,255,0.95); color: var(--ink); font-weight: 400; }
  .htag-warn { background: var(--m-yellow); color: #4a3800; font-weight: 400; }

  .dish-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 2rem;
  }
  .dish-aside { font-size: 0.875rem; }
  /* Panorama aside — no bg fill, just an uppercase letter-spaced label + value. */
  .aside-card { background: transparent; padding: 0.5rem 0 1rem; margin-bottom: 0; border: 0; border-bottom: 1px solid var(--t-rule); }
  .aside-card:last-child { border-bottom: 0; }
  .aside-card h3 { margin: 0 0 0.35rem; font-size: 0.8rem; letter-spacing: 0.22em; color: var(--t-ink-dim); font-weight: 400; text-transform: uppercase; }
  .aside-val { font-family: var(--sans); font-weight: 400; font-size: 1.45rem; color: var(--t-ink); letter-spacing: -0.01em; }

  .alert { padding: 0.75rem 0 0.75rem 0.875rem; margin: 1rem 0 2rem; }
  .alert-warn { background: transparent; border-left: 3px solid var(--m-yellow); color: var(--t-ink-dim); }

  .ing-table { background: transparent; }
  .ing-table th { background: transparent; border-bottom: 1px solid var(--t-rule); }

  /* Panorama sauce row — no card, just a clickable underlined row with chevron. */
  .sauce-card {
    display: flex;
    align-items: center;
    background: transparent;
    padding: 0.625rem 0;
    margin: 1.5rem 0;
    color: var(--t-ink) !important;
    border: 0;
    border-bottom: 1px solid var(--t-rule);
    border-top: 1px solid var(--t-rule);
  }
  .sauce-card:hover { background: var(--t-plate); }
  .sauce-label { font-family: var(--sans); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.22em; color: var(--t-ink-dim); margin-right: 0.875rem; font-weight: 400; }
  .sauce-name { font-family: var(--sans), var(--sans-zh); font-size: 1.25rem; font-weight: 400; flex: 1; color: var(--t-ink); }
  .sauce-chev { font-size: 1.5rem; color: var(--t-ink-dim); }

  .method-list { list-style: none; padding: 0; counter-reset: step; }
  .method-step { display: grid; grid-template-columns: 48px 1fr; gap: 1rem; padding: 1rem 0; border-bottom: 1px solid var(--rule); }
  .method-step:last-child { border-bottom: none; }
  .step-no {
    width: 40px; height: 40px;
    display: flex; align-items: center; justify-content: center;
    color: white;
    font-family: var(--sans); font-weight: 400; font-size: 1.5rem;
  }
  .step-body { padding-top: 0.125rem; }
  .step-text { font-family: var(--sans), var(--sans-zh); font-size: 1.0625rem; line-height: 1.65; font-weight: 400; }
  .step-text.fallback { color: var(--ink-dim); font-style: italic; }
  .step-fallback { font-family: var(--sans); font-size: 0.78rem; color: var(--m-orange); margin-top: 0.35rem; text-transform: uppercase; letter-spacing: 0.18em; }
  .step-meta { margin-top: 0.6rem; display: flex; gap: 0.5rem; }
  .chip { background: var(--plate); padding: 0.2rem 0.7rem; font-family: var(--sans); font-size: 0.82rem; color: var(--ink-dim); }
  .step-cite { margin-top: 0.6rem; }
  .step-cite a { font-family: var(--mono); font-size: 0.85rem; margin-right: 0.5rem; color: var(--m-blue); }

  .tips { background: transparent; padding: 0.5rem 0 0.5rem 1.5rem; }
  .tips li { margin: 0.5rem 0; }

  .history { background: transparent; padding: 0.5rem 0 0.5rem 0.875rem; border-left: 3px solid var(--m-red); line-height: 1.75; font-family: var(--serif-en), var(--serif-zh); font-size: 1.0625rem; }

  .sources { padding-left: 0; list-style: none; }
  .sources li { padding: 0.625rem 0; border-bottom: 1px dashed var(--rule); }
  .src-title { font-weight: 400; font-size: 1.0625rem; }
  .src-meta { margin-top: 0.125rem; }
  .src-meta .dot { margin: 0 0.5rem; opacity: 0.5; }

  @media (max-width: 900px) {
    .dish-grid { grid-template-columns: 1fr; }
    .dish-aside { order: -1; display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 8px; }
    .aside-card { margin-bottom: 0; }
  }
  @media (max-width: 540px) {
    .hero-band { padding: 1.5rem 1.5rem; }
    .hero-name { font-size: var(--lang-h1-size); }
  }
</style>
