---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { commonsThumb, commonsPageUrl } from '~/lib/commonsImage';
import { tileColor as tileColorFor } from '~/lib/categoryColors';
import PivotPage from '~/components/PivotPage.astro';
import PivotTab from '~/components/PivotTab.astro';

export async function getStaticPaths() {
  const dishes = await getCollection('dish');
  const paths = [];
  for (const locale of ['zh', 'en', 'yue'] as const) {
    for (const dish of dishes) {
      paths.push({ params: { locale, id: dish.id }, props: { dish } });
    }
  }
  return paths;
}

const { locale } = Astro.params as { locale: 'zh' | 'en' | 'yue' };
const { dish } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const category = await getEntry('category', dish.data.category.id);
const sauce = dish.data.sauce ? await getEntry('sauce', dish.data.sauce.id) : null;

type SourceRefData = { source_id: string; url?: string; accessed: string; note?: string };
const sources: { ref: SourceRefData; entry: Awaited<ReturnType<typeof getEntry>> }[] = [];
for (const s of dish.data.sources as SourceRefData[]) {
  const entry = await getEntry('source', s.source_id);
  if (entry) sources.push({ ref: s, entry });
}
const ingredientRefs = await Promise.all(
  dish.data.ingredients.map(async (i: { ref: { id: string }; qty: number; unit: string; prep?: any }) => ({
    ...i,
    entry: await getEntry('ingredient', i.ref.id),
  }))
);

const catColor = tileColorFor(dish.data.category.id);

function tNames(names: any, prefer = locale): string {
  if (prefer === 'en') return names.en;
  if (prefer === 'yue') return names.yue_hant;
  return names.yue_hant || names.zh;
}

function tBody(body: any, prefer = locale): string {
  if (!body) return '';
  if (prefer === 'en' && body.en) return body.en;
  if (prefer === 'yue' && body.yue) return body.yue;
  return body.zh ?? body.yue ?? body.en ?? '';
}

function langOfBody(body: any, prefer = locale): 'yue' | 'zh' | 'en' {
  if (prefer === 'en' && body?.en) return 'en';
  if (prefer === 'yue' && body?.yue) return 'yue';
  return 'zh';
}

const dict = {
  zh: {
    ingredients: '配料', method: '做法', tips: '小貼士', history: '由來', sources: '引用源',
    sauce_link: '關聯醬料', servings: '份量', difficulty: '難度', equipment: '設備', allergens: '過敏原',
    prep: '備料', cook: '烹飪', minutes: '分鐘', stub_warn: '此菜暫只有配料表，做法待補。',
    draft_warn: '此做法為流水線初稿，待人工校對。',
    cite: '引用', back_home: '首頁', back_cat: category?.data.names.yue_hant ?? 'Category',
    fallback_note: '此段以普通話呈現（粵文待補）',
    item_no: '菜單編號',
    no_tips: '尚無小貼士。',
    no_history: '尚無由來資料。',
  },
  en: {
    ingredients: 'Ingredients', method: 'Method', tips: 'Tips', history: 'History', sources: 'Sources',
    sauce_link: 'Linked sauce', servings: 'Servings', difficulty: 'Difficulty', equipment: 'Equipment', allergens: 'Allergens',
    prep: 'Prep', cook: 'Cook', minutes: 'min', stub_warn: 'Ingredients listed only — the cooking method has not yet been written.',
    draft_warn: 'Auto-generated draft — pending human review.',
    cite: 'cite', back_home: 'Home', back_cat: category?.data.names.en ?? 'Category',
    fallback_note: 'Translation pending — showing Chinese original',
    item_no: 'Menu #',
    no_tips: 'No tips yet.',
    no_history: 'No history information yet.',
  },
  yue: {
    ingredients: '配料', method: '做法', tips: '貼士', history: '由來', sources: '引用源',
    sauce_link: '關聯醬料', servings: '份量', difficulty: '難度', equipment: '設備', allergens: '過敏原',
    prep: '備料', cook: '烹飪', minutes: '分鐘', stub_warn: '此菜淨係有配料，做法仲未寫。',
    draft_warn: '此做法係流水線初稿，未經人工校對。',
    cite: '引用', back_home: '首頁', back_cat: category?.data.names.yue_hant ?? 'Category',
    fallback_note: '此段以普通話呈現（粵文待補）',
    item_no: '菜單編號',
    no_tips: '尚無貼士。',
    no_history: '尚無由來資料。',
  },
}[locale];

const title = locale === 'en' ? dish.data.names.en : dish.data.names.yue_hant;

// Compute prev/next dish in menu_no order within same category
const sameCat = (await getCollection('dish'))
  .filter((d) => d.data.category.id === dish.data.category.id)
  .sort((a, b) => a.data.menu_no - b.data.menu_no);
const myIdx = sameCat.findIndex((d) => d.id === dish.id);
const prevDish = myIdx > 0 ? sameCat[myIdx - 1] : null;
const nextDish = myIdx >= 0 && myIdx < sameCat.length - 1 ? sameCat[myIdx + 1] : null;

const prevName = prevDish ? (locale === 'en' ? prevDish.data.names.en : prevDish.data.names.yue_hant) : '';
const nextName = nextDish ? (locale === 'en' ? nextDish.data.names.en : nextDish.data.names.yue_hant) : '';
---
<BaseLayout title={title} locale={locale}>
  <PivotPage
    pivotTitle={dish.data.names.yue_hant}
    prevHref={prevDish ? `${base}/${locale}/dishes/${prevDish.id}` : undefined}
    nextHref={nextDish ? `${base}/${locale}/dishes/${nextDish.id}` : undefined}
    prevLabel={prevName}
    nextLabel={nextName}
    initialTab="ingredients"
  >
    {/* Hero tile-banner — WP10 Metro wide tile (4×2) with dish photo */}
    <div slot="hero" class="dish-hero-banner" data-role="tile" data-size="wide" style={`background: ${catColor}; view-transition-name: dish-${dish.id};`}>
      {dish.data.images?.[0] && (
        <div class="dish-hero-img" style={`background-image: url('${commonsThumb(dish.data.images[0].path, 1400)}'); background-size: cover; background-position: center;`} role="img" aria-label={`${dish.data.names.yue_hant} · ${dish.data.names.en}`}></div>
      )}
      <div class="dish-hero-overlay"></div>
      <div class="dish-hero-no">#{String(dish.data.menu_no).padStart(2, '0')}</div>
      <h2 class="dish-hero-name">{dish.data.names.yue_hant}</h2>
      {locale !== 'en' && (
        <div class="dish-hero-alt">
          {dish.data.names.zh && dish.data.names.zh !== dish.data.names.yue_hant && (
            <span class="alt-zh">{dish.data.names.zh}</span>
          )}
          {dish.data.names.zh && dish.data.names.en && <span class="alt-sep">·</span>}
          {dish.data.names.en && <span class="alt-en">{dish.data.names.en}</span>}
        </div>
      )}
      <div class="dish-hero-jyut">{dish.data.names.jyutping}</div>
      {dish.data.images?.[0] && (
        <div class="dish-hero-credit">
          <a href={commonsPageUrl(dish.data.images[0].path)} target="_blank" rel="noopener">
            {dish.data.images[0].license} · {dish.data.images[0].credit || 'Wikimedia Commons'} ↗
          </a>
        </div>
      )}
    </div>

    <PivotTab id="ingredients" name={dict.ingredients} selected>
      {(dish.data.method_status === 'stub' || dish.data.method_status === 'draft') && (
        <div class="alert alert-warn">
          <strong>⚠️</strong> {dish.data.method_status === 'stub' ? dict.stub_warn : dict.draft_warn}
        </div>
      )}

      <table class="ing-table">
        <thead>
          <tr>
            <th>{locale === 'en' ? 'Ingredient' : '食材'}</th>
            <th style="text-align: right;">{locale === 'en' ? 'Qty' : '份量'}</th>
            <th>{locale === 'en' ? 'Prep' : '處理'}</th>
          </tr>
        </thead>
        <tbody>
          {ingredientRefs.map((ing) => (
            <tr>
              <td>
                <a href={`${base}/${locale}/ingredients/${ing.entry?.id}`}>
                  {ing.entry ? tNames(ing.entry.data.names) : ing.ref.id}
                </a>
              </td>
              <td style="text-align: right; font-variant-numeric: tabular-nums;">{ing.qty} <span class="meta">{ing.unit}</span></td>
              <td class="meta">{ing.prep ? tBody(ing.prep) : ''}</td>
            </tr>
          ))}
        </tbody>
      </table>

      {sauce && (
        <a class="sauce-card" href={`${base}/${locale}/sauces/${sauce.id}`}>
          <div class="sauce-label">{dict.sauce_link}</div>
          <div class="sauce-name">{locale === 'en' ? sauce.data.names.en : sauce.data.names.yue_hant}</div>
          <span class="sauce-chev">›</span>
        </a>
      )}

      {dish.data.allergens && dish.data.allergens.length > 0 && (
        <div class="allergens-block">
          <h3>{dict.allergens}</h3>
          <div>
            {dish.data.allergens.map((a: string) => <span class="badge">{a}</span>)}
          </div>
        </div>
      )}

      <div class="ing-meta-cards">
        <div class="ing-meta-card">
          <div class="ing-meta-label">{dict.item_no}</div>
          <div class="ing-meta-val">#{String(dish.data.menu_no).padStart(2, '0')}</div>
        </div>
        {dish.data.time_minutes && (
          <div class="ing-meta-card">
            <div class="ing-meta-label">{dict.prep} · {dict.cook}</div>
            <div class="ing-meta-val">{dish.data.time_minutes.prep} + {dish.data.time_minutes.cook} {dict.minutes}</div>
          </div>
        )}
        {dish.data.servings && (
          <div class="ing-meta-card">
            <div class="ing-meta-label">{dict.servings}</div>
            <div class="ing-meta-val">{dish.data.servings} 👥</div>
          </div>
        )}
        {dish.data.difficulty && (
          <div class="ing-meta-card">
            <div class="ing-meta-label">{dict.difficulty}</div>
            <div class="ing-meta-val">{dish.data.difficulty}</div>
          </div>
        )}
        {dish.data.equipment && dish.data.equipment.length > 0 && (
          <div class="ing-meta-card">
            <div class="ing-meta-label">{dict.equipment}</div>
            <div>
              {dish.data.equipment.map((e: string) => <span class="badge">{e}</span>)}
            </div>
          </div>
        )}
        <div class="ing-meta-card">
          <div class="ing-meta-label">{locale === 'en' ? 'Status' : '狀態'}</div>
          <div>
            {dish.data.method_status === 'complete' && <span class="badge badge--green">✓ {dict.method}</span>}
            {dish.data.method_status === 'draft' && <span class="badge badge--warn">{dict.method} · draft</span>}
            {dish.data.method_status === 'stub' && <span class="badge">{dict.ingredients} {locale === 'en' ? 'only' : '僅有'}</span>}
          </div>
        </div>
      </div>
    </PivotTab>

    <PivotTab id="method" name={dict.method}>
      {dish.data.method_status === 'stub' && (
        <div class="alert alert-warn">
          <strong>⚠️</strong> {dict.stub_warn}
        </div>
      )}
      {dish.data.method_status === 'draft' && (
        <div class="alert alert-warn">
          <strong>⚠️</strong> {dict.draft_warn}
        </div>
      )}

      {dish.data.method_status !== 'stub' && dish.data.method && dish.data.method.length > 0 ? (
        <ol class="method-list">
          {dish.data.method.map((step: any) => {
            const lang = langOfBody(step.body);
            const fallback = (locale !== 'zh' && lang === 'zh');
            return (
              <li class="method-step">
                <div class="step-no" style={`background: ${catColor}`}>{step.order}</div>
                <div class="step-body">
                  <div class={`step-text ${fallback ? 'fallback' : ''}`}>{tBody(step.body)}</div>
                  {fallback && <div class="step-fallback">{dict.fallback_note}</div>}
                  {(step.temperature_c || step.time_seconds) && (
                    <div class="step-meta">
                      {step.temperature_c && <span class="chip">🌡 {step.temperature_c}°C</span>}
                      {step.time_seconds && <span class="chip">⏱ {Math.round(step.time_seconds / 60)} {dict.minutes}</span>}
                    </div>
                  )}
                  {step.cite && step.cite.length > 0 && (
                    <div class="step-cite">
                      {step.cite.map((c: string) => (
                        <a href={`#source-${c}`}>[{c}]</a>
                      ))}
                    </div>
                  )}
                </div>
              </li>
            );
          })}
        </ol>
      ) : (
        (!dish.data.method || dish.data.method.length === 0) && (
          <p class="no-content">{dict.stub_warn ?? '尚無做法。'}</p>
        )
      )}
    </PivotTab>

    <PivotTab id="tips" name={dict.tips}>
      {dish.data.tips && dish.data.tips.length > 0 ? (
        <ul class="tips">
          {dish.data.tips.map((tip: any) => (
            <li>{tBody(tip)}</li>
          ))}
        </ul>
      ) : (
        <p class="no-content">{dict.no_tips}</p>
      )}
    </PivotTab>

    <PivotTab id="history" name={dict.history}>
      {dish.data.history ? (
        <>
          <h2>{dict.history}</h2>
          <p class="history">{tBody(dish.data.history)}</p>
        </>
      ) : (
        <p class="no-content">{dict.no_history}</p>
      )}

      {sources.length > 0 && (
        <>
          <h2>{dict.sources}</h2>
          <ol class="sources">
            {sources.map(({ ref, entry }) => (
              <li id={`source-${ref.source_id}`}>
                <div class="src-title">
                  {entry ? (
                    <>
                      {entry.data.url ? (
                        <a href={entry.data.url}>{entry.data.title}</a>
                      ) : entry.data.title}
                    </>
                  ) : ref.source_id}
                </div>
                <div class="src-meta meta">
                  {entry?.data.license && <span>{entry.data.license}</span>}
                  <span class="dot">·</span>
                  <span>accessed {ref.accessed}</span>
                  {ref.note && <><span class="dot">·</span><span>{ref.note}</span></>}
                </div>
              </li>
            ))}
          </ol>
        </>
      )}
    </PivotTab>
  </PivotPage>

  <script define:vars={{ dishId: dish.id }}>
    try { localStorage.setItem('cantopedia-last-dish', dishId); } catch {}
  </script>
</BaseLayout>

<style>
  /* ── Dish hero banner (WP10 Metro wide 4×2 tile) ── */
  .dish-hero-banner {
    position: relative;
    overflow: hidden;
    color: #fff;
    margin: 0 0 var(--sp-5);
    height: calc(2 * var(--tile-unit) + var(--tile-gap));
    width: 100%;
    display: block;
  }
  .dish-hero-img { position: absolute; inset: 0; }
  .dish-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.05) 60%, rgba(0,0,0,0) 100%);
  }
  .dish-hero-no {
    position: absolute; top: var(--sp-3); right: var(--sp-4);
    font-family: var(--sans);
    font-size: var(--fs-body);
    background: rgba(0,0,0,0.45);
    padding: var(--sp-1) var(--sp-3);
    z-index: 2;
  }
  .dish-hero-name {
    position: absolute; bottom: calc(var(--sp-4) + 3rem); left: var(--sp-4);
    font-family: var(--lang-font-primary);
    font-size: var(--fs-panorama-sm);
    font-weight: var(--fw-light);
    margin: 0;
    z-index: 2;
    text-shadow: 0 1px 3px rgba(0,0,0,0.6);
  }
  .dish-hero-jyut {
    position: absolute; bottom: var(--sp-4); left: var(--sp-4);
    font-family: var(--mono);
    font-size: var(--fs-body);
    opacity: 0.85;
    z-index: 2;
  }
  .dish-hero-alt {
    position: absolute;
    bottom: calc(var(--sp-4) + 1.5rem);
    left: var(--sp-4);
    z-index: 2;
    font-family: var(--lang-font-primary);
    font-size: var(--fs-body);
    color: rgba(255, 255, 255, 0.85);
    text-shadow: 0 1px 3px rgba(0,0,0,0.6);
  }
  .dish-hero-alt .alt-sep { margin: 0 0.4em; opacity: 0.6; }
  .dish-hero-credit {
    position: absolute; bottom: var(--sp-2); right: var(--sp-4);
    font-family: var(--sans);
    font-size: var(--fs-caption);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.75;
    z-index: 2;
  }
  .dish-hero-credit a { color: rgba(255,255,255,0.85) !important; text-decoration: none; }
  .dish-hero-credit a:hover { color: white !important; text-decoration: underline; }

  /* ── Shared tab content styles ── */
  .alert { padding: 0.75rem 0 0.75rem 0.875rem; margin: 0 0 2rem; }
  .alert-warn { background: transparent; border-left: 3px solid var(--m-yellow); color: var(--t-ink-dim); }

  .ing-table { background: transparent; width: 100%; }
  .ing-table th { background: transparent; border-bottom: 1px solid var(--t-rule); }

  .sauce-card {
    display: flex;
    align-items: center;
    background: transparent;
    padding: 0.625rem 0;
    margin: 1.5rem 0;
    color: var(--t-ink) !important;
    border: 0;
    border-bottom: 1px solid var(--t-rule);
    border-top: 1px solid var(--t-rule);
    text-decoration: none;
  }
  .sauce-card:hover { background: var(--t-plate); }
  .sauce-label { font-family: var(--sans); font-size: var(--fs-tiny); text-transform: uppercase; letter-spacing: 0.22em; color: var(--t-ink-dim); margin-right: 0.875rem; font-weight: var(--fw-regular); }
  .sauce-name { font-family: var(--sans), var(--sans-zh); font-size: var(--fs-title); font-weight: var(--fw-regular); flex: 1; color: var(--t-ink); }
  .sauce-chev { font-size: var(--fs-title); color: var(--t-ink-dim); }

  .allergens-block { margin-top: 1.5rem; }
  .allergens-block h3 { margin: 0 0 0.5rem; font-size: var(--fs-tiny); letter-spacing: 0.22em; color: var(--t-ink-dim); font-weight: var(--fw-regular); text-transform: uppercase; }

  /* Inline meta cards (replaces sidebar aside) */
  .ing-meta-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 0;
    margin-top: 2rem;
    border-top: 1px solid var(--t-rule);
  }
  .ing-meta-card {
    padding: 0.875rem 0 0.875rem;
    border-bottom: 1px solid var(--t-rule);
    padding-right: 1rem;
  }
  .ing-meta-label { font-family: var(--sans); font-size: var(--fs-tiny); text-transform: uppercase; letter-spacing: 0.22em; color: var(--t-ink-dim); font-weight: var(--fw-regular); margin-bottom: 0.25rem; }
  .ing-meta-val { font-family: var(--sans); font-weight: var(--fw-regular); font-size: var(--fs-title); color: var(--t-ink); letter-spacing: -0.01em; }

  .method-list { list-style: none; padding: 0; }
  .method-step { display: grid; grid-template-columns: 48px 1fr; gap: 1rem; padding: 1rem 0; border-bottom: 1px solid var(--rule); }
  .method-step:last-child { border-bottom: none; }
  .step-no {
    width: 40px; height: 40px;
    display: flex; align-items: center; justify-content: center;
    color: white;
    font-family: var(--sans); font-weight: var(--fw-regular); font-size: var(--fs-title);
  }
  .step-body { padding-top: 0.125rem; }
  .step-text { font-family: var(--sans), var(--sans-zh); font-size: var(--fs-panel); line-height: 1.65; font-weight: var(--fw-regular); }
  .step-text.fallback { color: var(--ink-dim); font-style: italic; }
  .step-fallback { font-family: var(--sans); font-size: var(--fs-tiny); color: var(--m-orange); margin-top: 0.35rem; text-transform: uppercase; letter-spacing: 0.18em; }
  .step-meta { margin-top: 0.6rem; display: flex; gap: 0.5rem; }
  .chip { background: var(--plate); padding: 0.2rem 0.7rem; font-family: var(--sans); font-size: var(--fs-tiny); color: var(--ink-dim); }
  .step-cite { margin-top: 0.6rem; }
  .step-cite a { font-family: var(--mono); font-size: var(--fs-body); margin-right: 0.5rem; color: var(--m-blue); }

  .tips { background: transparent; padding: 0.5rem 0 0.5rem 1.5rem; }
  .tips li { margin: 0.5rem 0; }

  .history { background: transparent; padding: 0.5rem 0 0.5rem 0.875rem; border-left: 3px solid var(--m-red); line-height: 1.75; font-family: var(--serif-en), var(--serif-zh); font-size: var(--fs-panel); }

  .sources { padding-left: 0; list-style: none; }
  .sources li { padding: 0.625rem 0; border-bottom: 1px dashed var(--rule); }
  .src-title { font-weight: var(--fw-regular); font-size: var(--fs-panel); }
  .src-meta { margin-top: 0.125rem; }
  .src-meta .dot { margin: 0 0.5rem; opacity: 0.5; }

  .no-content { color: var(--t-ink-dim); font-style: italic; }
</style>
