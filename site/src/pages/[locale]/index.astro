---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hub from '~/components/Hub.astro';

export async function getStaticPaths() {
  return [
    { params: { locale: 'zh' } },
    { params: { locale: 'en' } },
    { params: { locale: 'yue' } },
  ];
}

const { locale } = Astro.params as { locale: 'zh' | 'en' | 'yue' };
const dict = {
  zh: { hero_title: '粵食典', hero_sub_a: '六張港式茶餐廳水牌' },
  en: { hero_title: 'Cantopedia', hero_sub_a: 'Six hand-written 茶餐廳 menus' },
  yue: { hero_title: '粵食典', hero_sub_a: '六張茶餐廳水牌' },
}[locale];
---
<BaseLayout title={dict.hero_title} locale={locale} description={dict.hero_sub_a}>
  <Hub locale={locale} initialPanel="home" />
</BaseLayout>
