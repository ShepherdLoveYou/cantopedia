---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';

export async function getStaticPaths() {
  return [
    { params: { locale: 'zh' } },
    { params: { locale: 'en' } },
    { params: { locale: 'yue' } },
  ];
}

const { locale } = Astro.params as { locale: 'zh' | 'en' | 'yue' };
const dishes = await getCollection('dish');
const categories = await getCollection('category');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sortedCategories = categories.sort((a, b) => a.data.sort_order - b.data.sort_order);
const dishesByCategory = new Map<string, typeof dishes>();
for (const dish of dishes) {
  const catId = dish.data.category.id;
  if (!dishesByCategory.has(catId)) dishesByCategory.set(catId, []);
  dishesByCategory.get(catId)!.push(dish);
}
for (const arr of dishesByCategory.values()) {
  arr.sort((a, b) => a.data.menu_no - b.data.menu_no);
}

// Live-tile colours per category (Metro / 印章紅 palette)
const tileColors: Record<string, string> = {
  appetizer:   '#B71C1C',  // 印章紅
  'soup-wonton': '#1565C0', // 深藍
  rice:        '#E65100',   // 橙
  noodle:      '#2E7D32',   // 翠
  'soup-noodle': '#00838F', // 青
  'baked-rice': '#6D4C41',  // 焙茶
  congee:      '#6A1B9A',   // 紫
  main:        '#263238',   // 墨
};

const total = dishes.length;
const complete = dishes.filter(d => d.data.method_status === 'complete').length;
const draft = dishes.filter(d => d.data.method_status === 'draft').length;

const dict = {
  zh: {
    seal_label: '粵 · CANTOPEDIA',
    hero_title: '粵食典',
    hero_sub: '六張港式茶餐廳水牌 · 66 道菜 · 三語可溯源開源典籍',
    browse: '按類別瀏覽',
    progress: '進度',
    complete: '已完成', draft: '草稿', stub: '配料表',
    other_locales: { en: 'English', yue: '粵' },
    pieces: '道',
  },
  en: {
    seal_label: '粵 · CANTOPEDIA',
    hero_title: 'Cantopedia',
    hero_sub: 'Six hand-written 港式茶餐廳 menus · 66 dishes · tri-lingual, citation-traceable, open source',
    browse: 'Browse by category',
    progress: 'Progress',
    complete: 'complete', draft: 'draft', stub: 'ingredients only',
    other_locales: { zh: '中文', yue: '粵' },
    pieces: 'dishes',
  },
  yue: {
    seal_label: '粵 · CANTOPEDIA',
    hero_title: '粵食典',
    hero_sub: '六張茶餐廳水牌 · 66 道菜 · 三語可溯源嘅開源典籍',
    browse: '按類別瀏覽',
    progress: '進度',
    complete: '已完成', draft: '草稿', stub: '配料表',
    other_locales: { zh: '中文', en: 'English' },
    pieces: '道',
  },
}[locale];
---
<BaseLayout title={dict.hero_title} locale={locale} description={dict.hero_sub}>
  <header style="text-align: center; margin: -2rem auto 3rem; max-width: 720px;">
    <div class="seal" aria-label="seal logo">
      <span>粵</span>
    </div>
    <h1 style="font-size: 4rem; margin: 1rem 0 0.25rem; letter-spacing: 0.05em;">{dict.hero_title}</h1>
    <p class="meta" style="font-size: 1rem; margin: 0.5rem auto 1.25rem; max-width: 540px;">{dict.hero_sub}</p>
    <div class="locale-switch">
      <strong>{locale === 'en' ? 'English' : locale === 'yue' ? '粵' : '中文'}</strong>
      <span class="sep">·</span>
      {Object.entries(dict.other_locales).map(([loc, label]) => (
        <a href={`${base}/${loc}`}>{label}</a>
      ))}
    </div>
  </header>

  <section class="progress-bar">
    <div class="prog-label">{dict.progress}</div>
    <div class="prog-track">
      <div class="prog-seg prog-complete" style={`width: ${(complete / total) * 100}%`}></div>
      <div class="prog-seg prog-draft" style={`width: ${(draft / total) * 100}%`}></div>
    </div>
    <div class="prog-stats">
      <span><b>{complete}</b> {dict.complete}</span>
      <span><b>{draft}</b> {dict.draft}</span>
      <span><b>{total - complete - draft}</b> {dict.stub}</span>
    </div>
  </section>

  <h2 style="margin-top: 4rem;">{dict.browse}</h2>

  <div class="tile-grid">
    {sortedCategories.map((cat) => {
      const inCat = dishesByCategory.get(cat.id) ?? [];
      if (inCat.length === 0) return null;
      const catName = locale === 'en' ? cat.data.names.en : cat.data.names.yue_hant;
      const desc = locale === 'en'
        ? (cat.data.description.en ?? cat.data.description.zh)
        : locale === 'yue'
          ? (cat.data.description.yue ?? cat.data.description.zh)
          : cat.data.description.zh;
      const tileColor = tileColors[cat.id] || '#37474F';
      return (
        <a class="tile" href={`${base}/${locale}/browse/${cat.id}`} style={`--tile: ${tileColor}`}>
          <div class="tile-count">{inCat.length}</div>
          <div class="tile-pieces">{dict.pieces}</div>
          <div class="tile-name">{catName}</div>
          <div class="tile-desc">{desc}</div>
        </a>
      );
    })}
  </div>

  <footer>
    粵食典 · Cantopedia · v0.1-alpha · Code MIT, Content CC BY-SA 4.0 ·
    <a href="https://github.com/ShepherdLoveYou/cantopedia">GitHub</a>
  </footer>
</BaseLayout>

<style>
  main { max-width: 980px !important; }

  .seal {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 96px;
    height: 96px;
    background: var(--seal);
    color: var(--bg);
    font-family: var(--display);
    font-weight: 700;
    font-size: 56px;
    border-radius: 6px;
    line-height: 1;
  }

  .locale-switch { font-family: var(--meta); font-size: 0.875rem; color: var(--ink-dim); }
  .locale-switch strong { color: var(--ink); }
  .locale-switch .sep { margin: 0 0.5rem; color: var(--rule); }
  .locale-switch a { margin: 0 0.5rem; border-bottom: none; }
  .locale-switch a:hover { border-bottom: 1px solid var(--seal); }

  .progress-bar {
    background: var(--plate);
    padding: 1.25rem 1.5rem;
    border-radius: 4px;
    margin-top: 1rem;
  }
  .prog-label {
    font-family: var(--meta);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-dim);
    margin-bottom: 0.5rem;
  }
  .prog-track {
    height: 8px;
    background: var(--rule);
    border-radius: 2px;
    overflow: hidden;
    display: flex;
  }
  .prog-seg { height: 100%; }
  .prog-complete { background: var(--seal); }
  .prog-draft    { background: #E8C46C; }
  .prog-stats {
    font-family: var(--meta);
    font-size: 0.8125rem;
    color: var(--ink-dim);
    margin-top: 0.75rem;
    display: flex;
    gap: 1.5rem;
  }
  .prog-stats b { color: var(--ink); margin-right: 0.25rem; }

  .tile-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 12px;
    margin-top: 1.5rem;
  }
  .tile {
    background: var(--tile);
    color: white;
    padding: 1.5rem;
    border: none;
    border-radius: 0;
    text-decoration: none;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    display: flex;
    flex-direction: column;
    min-height: 200px;
    position: relative;
    overflow: hidden;
  }
  .tile:hover { transform: translateY(-2px); box-shadow: 0 6px 18px rgba(0,0,0,0.12); }
  .tile-count {
    font-family: var(--display);
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .tile-pieces {
    font-family: var(--meta);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.85;
    margin-top: 0.25rem;
  }
  .tile-name {
    font-family: var(--serif-zh);
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: auto;
    padding-top: 1rem;
  }
  .tile-desc {
    font-family: var(--serif-en);
    font-size: 0.8125rem;
    line-height: 1.5;
    opacity: 0.88;
    margin-top: 0.5rem;
  }

  @media (max-width: 540px) {
    .tile-grid { grid-template-columns: 1fr 1fr; }
    .tile { min-height: 140px; padding: 1rem; }
    .tile-count { font-size: 2.5rem; }
  }
</style>
