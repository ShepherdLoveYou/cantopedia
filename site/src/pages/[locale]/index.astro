---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import CategoryIcon from '~/components/CategoryIcon.astro';
import { tileColors } from '~/lib/categoryColors';
import { commonsThumb } from '~/lib/commonsImage';

export async function getStaticPaths() {
  return [
    { params: { locale: 'zh' } },
    { params: { locale: 'en' } },
    { params: { locale: 'yue' } },
  ];
}

const { locale } = Astro.params as { locale: 'zh' | 'en' | 'yue' };
const dishes = await getCollection('dish');
const categories = await getCollection('category');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sortedCategories = categories.sort((a, b) => a.data.sort_order - b.data.sort_order);
const dishesByCategory = new Map<string, typeof dishes>();
for (const dish of dishes) {
  const catId = dish.data.category.id;
  if (!dishesByCategory.has(catId)) dishesByCategory.set(catId, []);
  dishesByCategory.get(catId)!.push(dish);
}
for (const arr of dishesByCategory.values()) {
  arr.sort((a, b) => a.data.menu_no - b.data.menu_no);
}

type CatId = 'appetizer' | 'soup-wonton' | 'rice' | 'noodle' | 'soup-noodle' | 'baked-rice' | 'congee' | 'main';
// Tile size mapping: dishes >=20 -> WIDE, 7-19 -> MEDIUM, <7 -> SMALL.
function sizeOf(_catId: string, dishCount: number): 'w' | 'm' | 's' {
  if (dishCount >= 20) return 'w';
  if (dishCount >= 7) return 'm';
  return 's';
}

const total = dishes.length;
const complete = dishes.filter(d => d.data.method_status === 'complete').length;
const draft = dishes.filter(d => d.data.method_status === 'draft').length;

const dict = {
  zh: {
    hero_title: '粵食典',
    hero_sub_a: '六張港式茶餐廳水牌',
    hero_sub_b: '66 道菜 · 三語可溯源',
    browse: '按類別瀏覽',
    progress: '收錄進度',
    complete: '完整做法', draft: '草稿', stub: '配料表',
    pieces: '道',
    featured_today: '今日推介', featured_random: '隨機菜', featured_recent: '最近瀏覽',
    dishes_text: '菜',
  },
  en: {
    hero_title: 'Cantopedia',
    hero_sub_a: 'Six hand-written 茶餐廳 menus',
    hero_sub_b: '66 dishes · tri-lingual · citation-traceable',
    browse: 'Browse by category',
    progress: 'Cataloging progress',
    complete: 'with method', draft: 'draft', stub: 'ingredients only',
    pieces: 'dishes',
    featured_today: 'TODAY\'S PICK', featured_random: 'RANDOM DISH', featured_recent: 'RECENTLY VIEWED',
    dishes_text: 'dishes',
  },
  yue: {
    hero_title: '粵食典',
    hero_sub_a: '六張茶餐廳水牌',
    hero_sub_b: '66 道菜 · 三語可溯源',
    browse: '按類別瀏覽',
    progress: '收錄進度',
    complete: '完整做法', draft: '草稿', stub: '配料表',
    pieces: '道',
    featured_today: '今日推介', featured_random: '隨機餸', featured_recent: '啱啱睇過',
    dishes_text: '菜',
  },
}[locale];
---
<BaseLayout title={dict.hero_title} locale={locale} description={dict.hero_sub_a}>
  <section class="panorama">
    <div class="panorama-stripe" aria-hidden="true"></div>
    <h1 class="panorama-title">{dict.hero_title}</h1>
    <p class="panorama-sub">
      <span>{dict.hero_sub_a}</span>
      <span class="panorama-dot">·</span>
      <span>{dict.hero_sub_b}</span>
    </p>
  </section>

  <section class="featured-section">
    <a id="featured-tile" class="featured-tile wp-tile" href={`${base}/${locale}/dishes/${dishes[0].id}`}>
      <div class="featured-face featured-face--active" data-face="today">
        <div class="featured-img" data-img=""></div>
        <div class="featured-overlay"></div>
        <div class="featured-label">{dict.featured_today}</div>
        <div class="featured-name"></div>
      </div>
      <div class="featured-face" data-face="random">
        <div class="featured-img" data-img=""></div>
        <div class="featured-overlay"></div>
        <div class="featured-label">{dict.featured_random}</div>
        <div class="featured-name"></div>
      </div>
      <div class="featured-face" data-face="recent">
        <div class="featured-img" data-img=""></div>
        <div class="featured-overlay"></div>
        <div class="featured-label">{dict.featured_recent}</div>
        <div class="featured-name"></div>
      </div>
    </a>
  </section>

  <script define:vars={{ base, locale, dishesData: dishes.map(d => ({
    id: d.id,
    name: locale === 'en' ? d.data.names.en : d.data.names.yue_hant,
    img: d.data.images?.[0]?.path ? commonsThumb(d.data.images[0].path, 1200) : null,
  })) }}>
    (function () {
      const tile = document.getElementById('featured-tile');
      if (!tile) return;
      const faces = tile.querySelectorAll('.featured-face');
      const withImg = dishesData.filter(d => d.img);
      if (withImg.length === 0) return;

      // Today's pick — deterministic by day-of-year
      const today = new Date();
      const dayOfYear = Math.floor((today - new Date(today.getFullYear(), 0, 0)) / 86400000);
      const todayDish = withImg[dayOfYear % withImg.length];

      // Random
      const randomDish = withImg[Math.floor(Math.random() * withImg.length)];

      // Recent from localStorage
      let recentDish = null;
      try {
        const recentId = localStorage.getItem('cantopedia-last-dish');
        if (recentId) {
          recentDish = dishesData.find(d => d.id === recentId && d.img);
        }
      } catch {}
      if (!recentDish) recentDish = todayDish;

      const picks = { today: todayDish, random: randomDish, recent: recentDish };

      // dishesData.img is already a thumb URL (commonsThumb applied in SSG).
      faces.forEach((face) => {
        const f = face.dataset.face;
        const pick = picks[f];
        if (!pick) return;
        const imgEl = face.querySelector('.featured-img');
        if (imgEl && pick.img) imgEl.style.backgroundImage = `url("${pick.img}")`;
        face.querySelector('.featured-name').textContent = pick.name;
      });

      // Link click → track the currently active face's dish
      tile.addEventListener('click', () => {
        const active = tile.querySelector('.featured-face--active');
        const f = active?.dataset.face;
        const pick = picks[f];
        if (pick) {
          try { localStorage.setItem('cantopedia-last-dish', pick.id); } catch {}
          tile.href = `${base}/${locale}/dishes/${pick.id}`;
        }
      });
      // Initial href
      tile.href = `${base}/${locale}/dishes/${todayDish.id}`;

      // Rotate every 6s
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      let i = 0;
      setInterval(() => {
        faces[i].classList.remove('featured-face--active');
        i = (i + 1) % faces.length;
        faces[i].classList.add('featured-face--active');
        // Update tile href to current face's dish
        const f = faces[i].dataset.face;
        if (picks[f]) tile.href = `${base}/${locale}/dishes/${picks[f].id}`;
      }, 6000);
    })();
  </script>

  <section class="pivot-section">
    <div class="pivot-label">{dict.progress}</div>
    <div class="stat-tiles">
      <div class="stat-tile stat-complete live-tile">
        <div class="live-tile-face front">
          <div class="stat-num">{complete}</div>
          <div class="stat-label">{dict.complete}</div>
        </div>
        <div class="live-tile-face back">
          <div class="stat-num-small">{Math.round((complete / total) * 100)}%</div>
          <div class="stat-label">{dict.complete}</div>
        </div>
      </div>
      <div class="stat-tile stat-draft live-tile">
        <div class="live-tile-face front">
          <div class="stat-num">{draft}</div>
          <div class="stat-label">{dict.draft}</div>
        </div>
        <div class="live-tile-face back">
          <div class="stat-num-small">{Math.round((draft / total) * 100)}%</div>
          <div class="stat-label">{dict.draft}</div>
        </div>
      </div>
      <div class="stat-tile stat-stub live-tile">
        <div class="live-tile-face front">
          <div class="stat-num">{total - complete - draft}</div>
          <div class="stat-label">{dict.stub}</div>
        </div>
        <div class="live-tile-face back">
          <div class="stat-num-small">{Math.round(((total - complete - draft) / total) * 100)}%</div>
          <div class="stat-label">{dict.stub}</div>
        </div>
      </div>
      <div class="stat-tile stat-total live-tile">
        <div class="live-tile-face front">
          <div class="stat-num">{total}</div>
          <div class="stat-label">{dict.pieces}</div>
        </div>
        <div class="live-tile-face back">
          <div class="stat-num-small">100%</div>
          <div class="stat-label">{dict.pieces}</div>
        </div>
      </div>
    </div>
    <div class="prog-track">
      <div class="prog-seg prog-complete" style={`width: ${(complete / total) * 100}%`}></div>
      <div class="prog-seg prog-draft" style={`width: ${(draft / total) * 100}%`}></div>
    </div>
  </section>

  <h2 class="pivot-h">{dict.browse}</h2>

  <div class="start-screen">
    {sortedCategories.map((cat) => {
      const inCat = dishesByCategory.get(cat.id) ?? [];
      if (inCat.length === 0) return null;
      const catName = locale === 'en' ? cat.data.names.en : cat.data.names.yue_hant;
      const tileColor = tileColors[cat.id] || '#37474F';
      const size = sizeOf(cat.id, inCat.length);
      const isWide = size === 'w';
      return (
        <a
          class={`tile wp-tile size-${size}`}
          href={`${base}/${locale}/browse/${cat.id}`}
          data-cat={cat.id}
          aria-label={`${catName} (${inCat.length} ${dict.pieces})`}
          style={`background: ${tileColor}; view-transition-name: tile-${cat.id};`}
        >
          {isWide ? (
            <>
              <div class="face front">
                <CategoryIcon cat={cat.id as CatId} size={88} />
                <div class="tile-name">{catName}</div>
                <div class="tile-count">{inCat.length} {dict.pieces}</div>
              </div>
              <div class="face back" aria-hidden="true">
                <div class="back-label">{locale === 'en' ? 'CANTOPEDIA · STATS' : '粵食典 · 數據'}</div>
                <div class="back-num">{total}</div>
                <div class="back-tagline">{
                  locale === 'en'
                    ? `${total} dishes · 8 categories · tri-lingual`
                    : `${total} 道菜 · 8 大類 · 三語可溯`
                }</div>
              </div>
            </>
          ) : (
            <>
              <div class="face front">
                <CategoryIcon cat={cat.id as CatId} size={size === 's' ? 48 : 72} />
                <div class="tile-name">{catName}</div>
                <span class="tile-badge">{inCat.length}</span>
              </div>
              <div class="face back" aria-hidden="true">
                <div class="back-num-sm">{inCat.length}</div>
                <div class="back-label-sm">{locale === 'en' ? 'dishes' : '道菜'}</div>
                <div class="back-name-sm">{catName}</div>
              </div>
            </>
          )}
        </a>
      );
    })}
  </div>

  <footer>
    粵食典 · Cantopedia · v0.1-alpha · MIT (code) + CC BY-SA 4.0 (content)<br>
    <a href="https://github.com/ShepherdLoveYou/cantopedia">github.com/ShepherdLoveYou/cantopedia</a>
  </footer>
</BaseLayout>

<style>
  /* WP10 Panorama header — title sits directly on page bg, no slab. */
  .panorama {
    position: relative;
    padding: 3.5rem 0 2.5rem;
    margin-bottom: 1.5rem;
  }
  .panorama-stripe {
    position: absolute;
    left: -1.5rem;
    top: 3.5rem;
    width: 3px;
    height: 5.5rem;
    background: var(--m-red);
  }
  .panorama-title {
    font-family: var(--sans), var(--sans-zh);
    font-weight: 400;
    font-size: clamp(var(--lang-h1-size), 9vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin: 0;
    color: var(--t-ink);
  }
  .panorama-sub {
    margin: 0.75rem 0 0;
    font-family: var(--sans), var(--sans-zh);
    font-weight: 400;
    font-size: 0.95rem;
    color: var(--t-ink-dim);
    letter-spacing: 0.02em;
  }
  .panorama-dot { margin: 0 0.5rem; opacity: 0.5; }

  /* Pivot section — section label + content directly on bg, no card. */
  .pivot-section { margin: 0 0 3rem; }
  .pivot-label {
    font-family: var(--sans);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--t-ink-dim);
    margin-bottom: 1rem;
    font-weight: 400;
  }
  /* WP10 stat tiles — 4 small colored Live Tiles showing dataset progress.
     Big number weight 300, small uppercase letter-spaced label, solid bg
     per status. Same vocabulary as Start Screen tiles below. */
  .stat-tiles {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
    margin-bottom: 0.875rem;
  }
  @media (max-width: 520px) {
    .stat-tiles { grid-template-columns: repeat(2, 1fr); }
  }
  .stat-tile {
    padding: 0.85rem 0.95rem 0.9rem;
    color: white;
    min-height: 88px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .stat-complete { background: var(--m-green); }
  .stat-draft    { background: var(--m-orange); }
  .stat-stub     { background: #647687; }   /* steel */
  .stat-total    { background: var(--m-red); }
  .stat-num {
    font-family: var(--sans);
    font-size: 2.5rem;
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .stat-label {
    font-family: var(--sans), var(--sans-zh);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.85;
  }
  .prog-track {
    height: 3px;
    background: var(--t-rule);
    overflow: hidden;
    display: flex;
  }
  .prog-seg { height: 100%; }
  .prog-complete { background: var(--m-green); }
  .prog-draft { background: var(--m-orange); }

  .pivot-h {
    font-family: var(--sans), var(--sans-zh);
    font-weight: 400;
    font-size: 1.5rem;
    letter-spacing: 0.04em;
    margin: 0 0 1.25rem;
    color: var(--t-ink);
  }

  .start-screen {
    display: grid;
    grid-template-columns: repeat(4, var(--tile-unit));
    grid-auto-rows: var(--tile-unit);
    gap: var(--start-gap, 6px);
    justify-content: center;
    margin: 1rem auto 2rem;
    --tile-unit: clamp(72px, 18vw, 200px);
  }
  @media (min-width: 768px) {
    .start-screen { --start-gap: 8px; }
  }

  /* Per-tile placement */
  .start-screen .tile[data-cat="main"]        { grid-area: 1 / 1 / 3 / 5; }
  .start-screen .tile[data-cat="rice"]        { grid-area: 3 / 1 / 5 / 3; }
  .start-screen .tile[data-cat="noodle"]      { grid-area: 3 / 3 / 5 / 5; }
  .start-screen .tile[data-cat="appetizer"]   { grid-area: 5 / 1 / 7 / 3; }
  .start-screen .tile[data-cat="soup-noodle"] { grid-area: 5 / 3 / 6 / 4; }
  .start-screen .tile[data-cat="baked-rice"]  { grid-area: 5 / 4 / 6 / 5; }
  .start-screen .tile[data-cat="congee"]      { grid-area: 6 / 3 / 7 / 4; }
  .start-screen .tile[data-cat="soup-wonton"] { grid-area: 6 / 4 / 7 / 5; }

  .tile {
    position: relative;
    display: block;
    color: white !important;
    text-decoration: none;
    cursor: pointer;
    overflow: hidden;
    padding: 10px;
  }
  .tile:hover { color: white !important; }

  /* Live Tile flip — applied to ALL tiles, staggered via JS */
  .tile { perspective: 1200px; }
  .tile .face {
    position: absolute; inset: 0;
    padding: 1rem;
    display: flex; flex-direction: column; justify-content: center; align-items: center;
    text-align: center;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    transition: transform 0.8s var(--fluent-curve-easy-ease, cubic-bezier(0.6, 0, 0.2, 1));
  }
  .tile .face.back { transform: rotateX(180deg); }
  .tile.flipped .face.front { transform: rotateX(180deg); }
  .tile.flipped .face.back  { transform: rotateX(360deg); }

  /* WIDE front + back text */
  .tile.size-w .face { padding: 1.25rem; }
  .tile.size-w .face .tile-name  { font-size: 1.75rem; font-weight: 400; margin-top: 0.6rem; letter-spacing: 0.01em; }
  .tile.size-w .face .tile-count { font-size: 1rem; opacity: 0.85; margin-top: 0.2rem; letter-spacing: 0.04em; }
  .tile.size-w .face.back .back-label   { font-size: 0.78rem; letter-spacing: 0.22em; opacity: 0.75; font-weight: 400; text-transform: uppercase; }
  .tile.size-w .face.back .back-num     { font-size: 4rem; font-weight: 400; line-height: 1.1; margin: 0.25rem 0; }
  .tile.size-w .face.back .back-tagline { font-size: 0.9rem; opacity: 0.85; max-width: 320px; }

  /* MEDIUM front + back text */
  .tile.size-m .face .tile-name { font-size: 1rem; font-weight: 400; margin-top: 0.6rem; letter-spacing: 0.02em; }
  .tile.size-m .face.back .back-num-sm   { font-size: 3rem; font-weight: 400; line-height: 1; }
  .tile.size-m .face.back .back-label-sm { font-size: 0.75rem; opacity: 0.85; letter-spacing: 0.18em; text-transform: uppercase; margin-top: 0.25rem; }
  .tile.size-m .face.back .back-name-sm  { font-size: 0.85rem; opacity: 0.85; margin-top: 0.5rem; }

  /* SMALL front + back text */
  .tile.size-s .face { padding: 0.5rem; }
  .tile.size-s .face .tile-name { font-size: 0.78rem; font-weight: 400; margin-top: 0.4rem; letter-spacing: 0.02em; line-height: 1.15; }
  .tile.size-s .face.back .back-num-sm   { font-size: 2.25rem; font-weight: 400; line-height: 1; }
  .tile.size-s .face.back .back-label-sm { font-size: 0.72rem; opacity: 0.85; letter-spacing: 0.18em; text-transform: uppercase; margin-top: 0.2rem; font-weight: 400; }
  .tile.size-s .face.back .back-name-sm  { font-size: 0.78rem; opacity: 0.85; margin-top: 0.3rem; }

  .tile-badge {
    position: absolute;
    top: 6px; right: 8px;
    padding: 1px 6px;
    background: rgba(255, 255, 255, 0.18);
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.02em;
  }
  .tile.size-s .tile-badge { display: none; }

  @media (max-width: 640px) {
    .hero { padding: 2.5rem 1.5rem 2.5rem; }
    .hero-title { font-size: 3.5rem; }
  }

  .live-tile {
    position: relative;
    perspective: 800px;
    overflow: hidden;
  }
  .live-tile-face {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-end;
    padding: inherit;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    transform-style: preserve-3d;
    animation: tile-flip-front 9s infinite;
  }
  .live-tile-face.back {
    animation-name: tile-flip-back;
    transform: rotateX(180deg);
  }
  @keyframes tile-flip-front {
    0%, 50%   { transform: rotateX(0deg); }
    60%, 100% { transform: rotateX(-180deg); }
  }
  @keyframes tile-flip-back {
    0%, 50%   { transform: rotateX(180deg); }
    60%, 100% { transform: rotateX(0deg); }
  }
  .stat-num-small {
    font-family: var(--lang-font-primary);
    font-size: 2.5rem;
    font-weight: var(--lang-min-weight, 300);
    letter-spacing: -0.02em;
    color: white;
    line-height: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .live-tile-face { animation: none; }
    .live-tile-face.back { display: none; }
  }

  /* WP10 Live-Tile entrance — fade + slide-up + slight scale, staggered. */
  @keyframes tile-enter {
    0%   { opacity: 0; transform: translateY(20px) scale(0.92); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }
  .wp-tile, .stat-tile {
    animation: tile-enter 520ms var(--fluent-curve-decelerate-mid, ease-out) backwards;
  }
  .stat-tile:nth-child(1) { animation-delay: 0ms; }
  .stat-tile:nth-child(2) { animation-delay: 50ms; }
  .stat-tile:nth-child(3) { animation-delay: 100ms; }
  .stat-tile:nth-child(4) { animation-delay: 150ms; }
  /* Category tile stagger — assign delays to first 12 tiles in nth-child order. */
  .start-screen > .wp-tile:nth-child(1)  { animation-delay: 240ms; }
  .start-screen > .wp-tile:nth-child(2)  { animation-delay: 270ms; }
  .start-screen > .wp-tile:nth-child(3)  { animation-delay: 300ms; }
  .start-screen > .wp-tile:nth-child(4)  { animation-delay: 330ms; }
  .start-screen > .wp-tile:nth-child(5)  { animation-delay: 360ms; }
  .start-screen > .wp-tile:nth-child(6)  { animation-delay: 380ms; }
  .start-screen > .wp-tile:nth-child(7)  { animation-delay: 400ms; }
  .start-screen > .wp-tile:nth-child(8)  { animation-delay: 420ms; }
  .start-screen > .wp-tile:nth-child(9)  { animation-delay: 440ms; }
  .start-screen > .wp-tile:nth-child(10) { animation-delay: 460ms; }
  .start-screen > .wp-tile:nth-child(11) { animation-delay: 480ms; }
  .start-screen > .wp-tile:nth-child(12) { animation-delay: 500ms; }
  /* Reduced motion: just fade, no slide. */
  @media (prefers-reduced-motion: reduce) {
    .wp-tile, .stat-tile {
      animation: tile-enter-fade 200ms ease-out both;
    }
    @keyframes tile-enter-fade {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
  }

  .featured-section {
    margin: 2rem 0 1.5rem;
    /* tile entrance stagger lives on .wp-tile globally, applies here too */
  }
  .featured-tile {
    position: relative;
    display: block;
    height: 220px;
    overflow: hidden;
