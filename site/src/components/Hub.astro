---
/**
 * 9-panel Hub component. Renders the home panel (panorama + featured tile +
 * progress + start-screen) as panel 0, followed by 8 category panels (one per
 * sorted category). Used by both /[locale]/ and /[locale]/browse/[category]/.
 *
 * Props:
 *   locale: 'zh' | 'en' | 'yue'
 *   initialPanel: 'home' | <category-id>   — which panel is initially in view
 *
 * The hub-pivot's prev/next arrows wrap modulo 9 (home <-> appetizer ... <-> main).
 * URL is kept in sync via history.replaceState as the user scrolls between panels.
 */
import { getCollection } from 'astro:content';
import CategoryIcon from '~/components/CategoryIcon.astro';
import { tileColors, tileColor as tileColorFor } from '~/lib/categoryColors';
import { commonsThumb } from '~/lib/commonsImage';
import '@olton/metroui/lib/metro.css';
import '@olton/metroui/lib/icons.css';
import CatTile from '~/components/CatTile.astro';
import AppListPanel from '~/components/AppListPanel.astro';

interface Props {
  locale: 'zh' | 'en' | 'yue';
  initialPanel: string; // 'home' | category-id
}
const { locale, initialPanel } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allCats = (await getCollection('category')).sort((a, b) => a.data.sort_order - b.data.sort_order);
const allDishes = await getCollection('dish');

const dishesByCat = new Map<string, typeof allDishes>();
for (const cat of allCats) {
  dishesByCat.set(cat.id, allDishes
    .filter((d) => d.data.category.id === cat.id)
    .sort((a, b) => a.data.menu_no - b.data.menu_no));
}

function categoryPhotos(catId: string, max = 4): string[] {
  const dishes = dishesByCat.get(catId) ?? [];
  return dishes
    .map((d) => d.data.images?.[0]?.path)
    .filter((p): p is string => !!p)
    .slice(0, max)
    .map((p) => commonsThumb(p, 800));
}

type CatId = 'appetizer' | 'soup-wonton' | 'rice' | 'noodle' | 'soup-noodle' | 'baked-rice' | 'congee' | 'main';

const total = allDishes.length;
const complete = allDishes.filter((d) => d.data.method_status === 'complete').length;
const draft = allDishes.filter((d) => d.data.method_status === 'draft').length;

function sizeOf(_catId: string, dishCount: number): 'w' | 'm' | 's' {
  if (dishCount >= 20) return 'w';
  if (dishCount >= 7) return 'm';
  return 's';
}

const dict = {
  zh: {
    hero_title: '粵食典',
    hero_sub_a: '六張港式茶餐廳水牌',
    hero_sub_b: '66 道菜 · 三語可溯源',
    browse: '按類別瀏覽',
    progress: '收錄進度',
    complete: '完整做法', draft: '草稿', stub: '配料表', dish_complete: '已完成',
    pieces: '道',
    featured_today: '今日推介', featured_random: '隨機菜', featured_recent: '最近瀏覽',
    dishes_text: '菜',
    home_label: '粵食典',
    applist_label: '所有菜式',
  },
  en: {
    hero_title: 'Cantopedia',
    hero_sub_a: 'Six hand-written 茶餐廳 menus',
    hero_sub_b: '66 dishes · tri-lingual · citation-traceable',
    browse: 'Browse by category',
    progress: 'Cataloging progress',
    complete: 'with method', draft: 'draft', stub: 'ingredients only', dish_complete: 'complete',
    pieces: 'dishes',
    featured_today: "TODAY'S PICK", featured_random: 'RANDOM DISH', featured_recent: 'RECENTLY VIEWED',
    dishes_text: 'dishes',
    home_label: 'Cantopedia',
    applist_label: 'All dishes',
  },
  yue: {
    hero_title: '粵食典',
    hero_sub_a: '六張茶餐廳水牌',
    hero_sub_b: '66 道菜 · 三語可溯源',
    browse: '按類別瀏覽',
    progress: '收錄進度',
    complete: '完整做法', draft: '草稿', stub: '配料表', dish_complete: '已完成',
    pieces: '道',
    featured_today: '今日推介', featured_random: '隨機餸', featured_recent: '啱啱睇過',
    dishes_text: '菜',
    home_label: '粵食典',
    applist_label: '所有菜式',
  },
}[locale];

function nameOf(c: typeof allCats[number]) {
  return locale === 'en' ? c.data.names.en : c.data.names.yue_hant;
}
function descOf(c: typeof allCats[number]) {
  if (locale === 'en') return c.data.description.en ?? c.data.description.zh;
  if (locale === 'yue') return c.data.description.yue ?? c.data.description.zh;
  return c.data.description.zh;
}

// Initial pivot title shown SSR
const initialTitle =
  initialPanel === 'home' ? dict.home_label
  : initialPanel === 'all' ? dict.applist_label
  : (() => {
      const c = allCats.find((c) => c.id === initialPanel);
      return c ? nameOf(c) : dict.home_label;
    })();

// Build dishes data for featured tile inline script (home panel)
const dishesData = allDishes.map((d) => ({
  id: d.id,
  name: locale === 'en' ? d.data.names.en : d.data.names.yue_hant,
  img: d.data.images?.[0]?.path ? commonsThumb(d.data.images[0].path, 1200) : null,
}));

// Featured tile initial href fallback
const firstDishId = allDishes[0]?.id ?? '';
---
<!-- Hub-aware pivot strip: title updates as user scrolls between panels -->
<nav class="hub-pivot" aria-label="Hub pivot">
  <a class="hub-pivot-link hub-pivot-link--prev" id="hub-pivot-prev" href="#" data-dir="prev" aria-label="Previous panel">
    <span class="hub-pivot-peek hub-pivot-peek--prev" id="hub-pivot-peek-prev" aria-hidden="true"></span>
    <span class="hub-pivot-arrow">‹</span>
  </a>
  <h1 class="hub-pivot-title" id="hub-pivot-title">{initialTitle}</h1>
  <a class="hub-pivot-link hub-pivot-link--next" id="hub-pivot-next" href="#" data-dir="next" aria-label="Next panel">
    <span class="hub-pivot-arrow">›</span>
    <span class="hub-pivot-peek hub-pivot-peek--next" id="hub-pivot-peek-next" aria-hidden="true"></span>
  </a>
</nav>

<div class="hub" id="hub" data-initial-panel={initialPanel}>
  <!-- Panel 0: HOME -->
  <section
    class="hub-panel hub-panel--home"
    data-panel="home"
    data-name={dict.home_label}
    data-url={`${base}/${locale}`}
    aria-labelledby="hub-home-title"
  >
    <div class="tiles-grid start-tiles">
      {/* Featured wide live tile — uses tile-wide for sizing + its own .featured-face show/hide cycle.
          Do NOT add cat-face classes here — featured tile has its own display:none/block toggle
          driven by initFeaturedTile() and would conflict with cat-face's rotateX/opacity rules. */}
      <a id="featured-tile" class="tile-wide featured-tile wp-tile" href={`${base}/${locale}/dishes/${firstDishId}`}>
        <div class="featured-face featured-face--active" data-face="today">
          <div class="featured-img"></div>
          <div class="featured-overlay"></div>
          <span class="branding-bar featured-label">{dict.featured_today}</span>
          <span class="featured-name"></span>
        </div>
        <div class="featured-face" data-face="random">
          <div class="featured-img"></div>
          <div class="featured-overlay"></div>
          <span class="branding-bar featured-label">{dict.featured_random}</span>
          <span class="featured-name"></span>
        </div>
        <div class="featured-face" data-face="recent">
          <div class="featured-img"></div>
          <div class="featured-overlay"></div>
          <span class="branding-bar featured-label">{dict.featured_recent}</span>
          <span class="featured-name"></span>
        </div>
      </a>

      {/* 8 category tiles with face cycling */}
      {allCats.map((cat) => {
        const inCat = dishesByCat.get(cat.id) ?? [];
        if (inCat.length === 0) return null;
        const catName = nameOf(cat);
        const size: 's'|'m'|'w' = inCat.length >= 20 ? 'w' : inCat.length >= 7 ? 'm' : 's';
        const photos = categoryPhotos(cat.id);
        return (
          <CatTile
            size={size}
            href={`${base}/${locale}/browse/${cat.id}`}
            color={tileColorFor(cat.id)}
            label={catName}
            badge={inCat.length}
            photos={photos}
            viewTransitionName={`tile-${cat.id}`}
            ariaLabel={`${catName} (${inCat.length} ${dict.pieces})`}
          />
        );
      })}

      {/* 4 stat tiles (medium, no photos, inline-style backgrounds via --m-* tokens) */}
      <a class="tile-medium cat-tile wp-tile stat-tile-mt" href={`${base}/${locale}/all`} style="background: var(--m-green); view-transition-name: stat-complete;">
        <div class="cat-face cat-face--solid active" style="background: var(--m-green);">
          <span class="stat-num">{complete}</span>
          <span class="branding-bar">{dict.complete}</span>
        </div>
      </a>
      <a class="tile-medium cat-tile wp-tile stat-tile-mt" href={`${base}/${locale}/all`} style="background: var(--m-orange);">
        <div class="cat-face cat-face--solid active" style="background: var(--m-orange);">
          <span class="stat-num">{draft}</span>
          <span class="branding-bar">{dict.draft}</span>
        </div>
      </a>
      <a class="tile-medium cat-tile wp-tile stat-tile-mt" href={`${base}/${locale}/all`} style="background: var(--m-steel);">
        <div class="cat-face cat-face--solid active" style="background: var(--m-steel);">
          <span class="stat-num">{total - complete - draft}</span>
          <span class="branding-bar">{dict.stub}</span>
        </div>
      </a>
      <a class="tile-medium cat-tile wp-tile stat-tile-mt" href={`${base}/${locale}/all`} style="background: var(--m-red);">
        <div class="cat-face cat-face--solid active" style="background: var(--m-red);">
          <span class="stat-num">{total}</span>
          <span class="branding-bar">{dict.pieces}</span>
        </div>
      </a>

      {/* Utility row: search + 3 theme + github (all small) */}
      <a class="tile-small cat-tile wp-tile util-tile" href={`${base}/${locale}/search`} style="background: var(--m-cyan);" aria-label={dict.tag_search ?? 'Search'}>
        <div class="cat-face cat-face--solid active" style="background: var(--m-cyan);">
          <span class="mif-search" style="font-size: 32px; color: #fff;"></span>
        </div>
      </a>
      <button type="button" class="tile-small cat-tile wp-tile util-tile" data-theme-choice="light" style="background: var(--m-yellow);" aria-label={dict.light ?? 'Light'}>
        <div class="cat-face cat-face--solid active" style="background: var(--m-yellow);">
          <span class="mif-sunny" style="font-size: 32px; color: #fff;"></span>
        </div>
      </button>
      <button type="button" class="tile-small cat-tile wp-tile util-tile" data-theme-choice="dark" style="background: var(--m-purple);" aria-label={dict.dark ?? 'Dark'}>
        <div class="cat-face cat-face--solid active" style="background: var(--m-purple);">
          <span class="mif-moon-right" style="font-size: 32px; color: #fff;"></span>
        </div>
      </button>
      <button type="button" class="tile-small cat-tile wp-tile util-tile" data-theme-choice="auto" style="background: var(--m-steel);" aria-label={dict.auto ?? 'Auto'}>
        <div class="cat-face cat-face--solid active" style="background: var(--m-steel);">
          <span class="mif-cog" style="font-size: 32px; color: #fff;"></span>
        </div>
      </button>
      <a class="tile-small cat-tile wp-tile util-tile" href="https://github.com/ShepherdLoveYou/cantopedia" target="_blank" rel="noopener" style="background: var(--m-ink);" aria-label="GitHub">
        <div class="cat-face cat-face--solid active" style="background: var(--m-ink);">
          <span class="mif-github" style="font-size: 32px; color: #fff;"></span>
        </div>
      </a>
    </div>
  </section>

  {/* Panel 1: APPLIST */}
  <AppListPanel
    locale={locale}
    dishes={allDishes}
    base={base}
    dataUrl={`${base}/${locale}/all`}
    panelName={dict.applist_label}
  />

  {/* Browse category panels — one per category, each with a Metro tiles grid of dishes */}
  {allCats.map((cat) => {
    const dishes = dishesByCat.get(cat.id) ?? [];
    const tileColor = tileColorFor(cat.id);
    const catName = nameOf(cat);
    return (
      <section
        class="hub-panel"
        data-panel={cat.id}
        data-cat={cat.id}
        data-name={catName}
        data-url={`${base}/${locale}/browse/${cat.id}`}
        aria-labelledby={`hub-title-${cat.id}`}
      >
        <div class="tiles-grid browse-tiles">
          {dishes.map((dish) => {
            const dishName = locale === 'en' ? dish.data.names.en : dish.data.names.yue_hant;
            const heroImg = dish.data.images?.[0];
            const thumb = heroImg ? commonsThumb(heroImg.path, 800) : null;
            return (
              <a
                class="tile-medium cat-tile wp-tile dish-tile"
                href={`${base}/${locale}/dishes/${dish.id}`}
                style={`background: ${tileColor}; ${thumb ? `background-image: url('${thumb}'); background-size: cover; background-position: center;` : ''} view-transition-name: dish-${dish.id};`}
                aria-label={dishName}
              >
                <div class="cat-face cat-face--solid active" style={thumb ? '' : `background: ${tileColor};`}>
                  <span class="dish-no">#{String(dish.data.menu_no).padStart(2, '0')}</span>
                  <span class="branding-bar">{dishName}</span>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    );
  })}
</div>

<!-- Hub boot config: pass SSR data to client module via window.__hubBoot. -->
<script define:vars={{ base, locale, dishesData }}>
  window.__hubBoot = { base, locale, dishesData };
</script>

<!-- Hub module: featured-tile + hub-nav re-init on every ClientRouter swap. -->
<script>
  import { initFeaturedTile, teardownFeaturedTile, initHubNav, teardownHubNav,
           initCatTileCycle, teardownCatTileCycle } from '~/lib/hubScripts';

  function boot() {
    const cfg = (window as any).__hubBoot;
    if (!cfg) return;
    initFeaturedTile(cfg.base, cfg.locale, cfg.dishesData);
    initHubNav();
    initCatTileCycle();
  }
  function teardown() {
    teardownFeaturedTile();
    teardownHubNav();
    teardownCatTileCycle();
  }

  boot();
  document.addEventListener('astro:after-swap', boot);
  document.addEventListener('astro:page-load', boot);
  document.addEventListener('astro:before-preparation', teardown);
</script>

<!-- Live Tile flip for category Start Screen tiles + stat tiles + dish cards.
     Replaces the old start-screen and dish-card flip scripts; runs once
     globally since the hub now owns all of them. -->
<script>
  (function () {
    const PERIOD = 10000;
    const STEP = 1400;
    let timers: number[] = [];

    function isPanelVisible(t: HTMLElement): boolean {
      const panel = t.closest<HTMLElement>('.hub-panel');
      if (!panel) return true;
      const r = panel.getBoundingClientRect();
      return !(r.right < 0 || r.left > window.innerWidth);
    }

    function flip(t: HTMLElement) {
      if (document.hidden) return;
      if (t.classList.contains('pressing')) return;
      if (!isPanelVisible(t)) return;
      t.classList.toggle('flipped');
    }
    function stopFlip() {
      timers.forEach((id) => { window.clearTimeout(id); window.clearInterval(id); });
      timers = [];
    }
    function startFlip() {
      stopFlip();
      // Category Start Screen tiles (home panel) + dish cards (category panels)
      const tiles = Array.from(document.querySelectorAll<HTMLElement>('.start-screen .tile, .dish-card.has-back'));
      tiles.forEach((t, i) => {
        const offset = (i * STEP) % PERIOD;
        const initial = window.setTimeout(() => {
          flip(t);
          const id = window.setInterval(() => flip(t), PERIOD);
          timers.push(id);
        }, offset);
        timers.push(initial);
      });
    }
    startFlip();
    document.addEventListener('astro:before-preparation', stopFlip);
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stopFlip();
      else if (document.querySelector('#hub')) startFlip();
    });
  })();
</script>

<style>
  main { max-width: none !important; padding: 0 !important; }

  /* ===== Hub-aware pivot strip ===== */
  .hub-pivot {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: baseline;
    gap: 1rem;
    padding: 1rem 1.5rem 0.5rem;
    font-family: var(--lang-font-primary);
    min-height: 4.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  .hub-pivot-title {
    font-size: clamp(1.6rem, 7vw, 3.25rem);
    font-weight: var(--lang-min-weight, 300);
    letter-spacing: var(--lang-h1-tracking, -0.025em);
    line-height: 1;
    margin: 0;
    text-align: center;
    color: var(--t-ink);
    overflow-wrap: break-word;
  }
  .hub-pivot-link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    color: var(--ink);
    text-decoration: none;
  }
  .hub-pivot-arrow {
    font-size: 1.6rem;
    font-weight: 200;
    line-height: 1;
  }
  .hub-pivot-peek {
    font-family: var(--sans), var(--sans-zh);
    font-weight: 300;
    font-size: 0.9rem;
    color: var(--ink-dim);
    opacity: 0.55;
    max-width: 8ch;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    letter-spacing: 0.02em;
  }
  @media (max-width: 540px) {
    .hub-pivot { min-height: 3.5rem; padding: 0.75rem 1rem 0.25rem; }
    .hub-pivot-peek { display: none; }
  }

  /* ===== Hub: horizontal scroll-snap container ===== */
  .hub {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 100vw;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    height: calc(100vh - 120px);
    min-height: 480px;
    overscroll-behavior-x: contain;
  }
  .hub::-webkit-scrollbar { display: none; }

  .hub-panel {
    scroll-snap-align: start;
    scroll-snap-stop: always;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 0 1.5rem 4rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
  }
  .hub-panel::-webkit-scrollbar { width: 6px; }
  .hub-panel::-webkit-scrollbar-thumb { background: var(--t-rule); border-radius: 3px; }

  /* ===== Category panel hero ===== */
  .cat-hero {
    color: white;
    padding: 1.5rem 1.5rem 1.25rem;
    margin: 0 -1.5rem 1.5rem;
    position: relative;
  }
  .cat-no {
    font-family: var(--sans);
    font-size: clamp(2.25rem, 8vw, 3.5rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.02em;
  }
  .cat-name {
    font-family: var(--lang-font-primary);
    font-size: clamp(1.3rem, 4.5vw, 2rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    margin: 0.25rem 0 0.5rem;
    color: white;
    line-height: 1.1;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .cat-desc { font-family: var(--lang-font-primary); font-size: 0.95rem; font-weight: 400; margin: 0.5rem 0 0; opacity: 0.92; max-width: 60ch; }
  .cat-langs { font-family: var(--meta); font-size: 0.8rem; opacity: 0.8; margin-top: 0.75rem; letter-spacing: 0.04em; }

  /* ===== Category panel dish grid ===== */
  .dish-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
    max-width: 1200px;
    margin: 0 auto;
  }
  @media (max-width: 900px) { .dish-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .dish-grid { grid-template-columns: 1fr; } }

  .dish-card:nth-child(5n+1) { grid-column: span 2; }
  .dish-card:nth-child(10n+7) { grid-row: span 2; }
  @media (max-width: 900px) {
    .dish-card:nth-child(5n+1) { grid-column: span 2; }
    .dish-card:nth-child(10n+7) { grid-row: auto; }
  }
  @media (max-width: 520px) {
    .dish-card:nth-child(5n+1) { grid-column: span 1; }
  }

  .dish-card {
    background: var(--cat-color);
    color: white !important;
    text-decoration: none;
    display: block;
    position: relative;
    overflow: hidden;
    min-height: 200px;
    perspective: 1200px;
  }
  .dish-card:hover { color: white !important; }

  .card-face {
    position: absolute;
    inset: 0;
    padding: 1rem 1.25rem 1.125rem;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    transition: transform 0.8s var(--fluent-curve-easy-ease);
    display: flex;
    flex-direction: column;
  }
  .card-back { transform: rotateX(180deg); padding: 0; background: #000; }
  .dish-card.flipped .card-front { transform: rotateX(180deg); }
  .dish-card.flipped .card-back  { transform: rotateX(360deg); }

  .card-photo { width: 100%; height: 100%; object-fit: cover; display: block; }
  .dish-card:not(.has-back) .card-front { position: static; }
  .dish-card:not(.has-back) { min-height: 180px; }
  .dish-card:nth-child(5n+1) .card-name { font-size: 1.5rem; }
  .dish-card:nth-child(5n+1) { min-height: 220px; }
  .card-no { font-family: var(--sans); font-size: 0.8rem; letter-spacing: 0.22em; color: rgba(255,255,255,0.75); font-weight: 400; text-transform: uppercase; }
  .card-name { font-family: var(--sans), var(--sans-zh); font-size: 1.5rem; font-weight: 400; letter-spacing: 0.005em; margin: 0.4rem 0 0.3rem; color: white; line-height: 1.15; }
  .card-jyut { font-family: var(--mono); font-size: 0.85rem; color: rgba(255,255,255,0.78); }
  .card-zh-en { font-family: var(--sans), var(--sans-zh); font-size: 0.9rem; color: rgba(255,255,255,0.78); margin-top: 0.55rem; font-weight: 400; }
  .card-foot { margin-top: auto; padding-top: 0.75rem; display: flex; justify-content: space-between; align-items: center; gap: 0.5rem; }
  .card-ings { font-size: 0.85rem; color: rgba(255,255,255,0.85); }
  .dish-card .badge { background: rgba(255,255,255,0.18) !important; color: white !important; border: 0 !important; font-size: 0.7rem; padding: 0.2rem 0.6rem; letter-spacing: 0.18em; }

  /* ============================================================
     HOME PANEL — panorama + featured tile + progress + start-screen
     ============================================================ */
  /* WP10 Panorama header */
  .panorama {
    position: relative;
    padding: 2rem 0 2rem;
    margin-bottom: 1.5rem;
  }
  .panorama-stripe {
    position: absolute;
    left: -1.5rem;
    top: 2rem;
    width: 3px;
    height: 5.5rem;
    background: var(--m-red);
  }
  .panorama-title {
    font-family: var(--sans), var(--sans-zh);
    font-weight: 400;
    font-size: clamp(var(--lang-h1-size), 9vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin: 0;
    color: var(--t-ink);
  }
  .panorama-sub {
    margin: 0.75rem 0 0;
    font-family: var(--sans), var(--sans-zh);
    font-weight: 400;
    font-size: 0.95rem;
    color: var(--t-ink-dim);
    letter-spacing: 0.02em;
  }
  .panorama-dot { margin: 0 0.5rem; opacity: 0.5; }

  /* Pivot section — section label + content */
  .pivot-section { margin: 0 0 3rem; }
  .pivot-label {
    font-family: var(--sans);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--t-ink-dim);
    margin-bottom: 1rem;
    font-weight: 400;
  }
  .stat-tiles {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
    margin-bottom: 0.875rem;
  }
  @media (max-width: 520px) {
    .stat-tiles { grid-template-columns: repeat(2, 1fr); }
  }
  .stat-tile {
    padding: 0.85rem 0.95rem 0.9rem;
    color: white;
    min-height: 88px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .stat-complete { background: var(--m-green); }
  .stat-draft    { background: var(--m-orange); }
  .stat-stub     { background: #647687; }
  .stat-total    { background: var(--m-red); }
  .stat-num {
    font-family: var(--sans);
    font-size: 2.5rem;
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .stat-label {
    font-family: var(--sans), var(--sans-zh);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.85;
  }
  .prog-track {
    height: 3px;
    background: var(--t-rule);
    overflow: hidden;
    display: flex;
  }
  .prog-seg { height: 100%; }
  .prog-complete { background: var(--m-green); }
  .prog-draft { background: var(--m-orange); }

  .pivot-h {
    font-family: var(--sans), var(--sans-zh);
    font-weight: 400;
    font-size: 1.5rem;
    letter-spacing: 0.04em;
    margin: 0 0 1.25rem;
    color: var(--t-ink);
  }

  .start-screen {
    display: grid;
    grid-template-columns: repeat(4, var(--tile-unit));
    grid-auto-rows: var(--tile-unit);
    gap: var(--start-gap, 6px);
    justify-content: center;
    margin: 1rem auto 2rem;
    --tile-unit: clamp(72px, 18vw, 200px);
  }
  @media (min-width: 768px) {
    .start-screen { --start-gap: 8px; }
  }

  /* Per-tile placement */
  .start-screen .tile[data-cat="main"]        { grid-area: 1 / 1 / 3 / 5; }
  .start-screen .tile[data-cat="rice"]        { grid-area: 3 / 1 / 5 / 3; }
  .start-screen .tile[data-cat="noodle"]      { grid-area: 3 / 3 / 5 / 5; }
  .start-screen .tile[data-cat="appetizer"]   { grid-area: 5 / 1 / 7 / 3; }
  .start-screen .tile[data-cat="soup-noodle"] { grid-area: 5 / 3 / 6 / 4; }
  .start-screen .tile[data-cat="baked-rice"]  { grid-area: 5 / 4 / 6 / 5; }
  .start-screen .tile[data-cat="congee"]      { grid-area: 6 / 3 / 7 / 4; }
  .start-screen .tile[data-cat="soup-wonton"] { grid-area: 6 / 4 / 7 / 5; }

  .tile {
    position: relative;
    display: block;
    color: white !important;
    text-decoration: none;
    cursor: pointer;
    overflow: hidden;
    padding: 10px;
  }
  .tile:hover { color: white !important; }

  /* Live Tile flip — applied to ALL tiles */
  .tile { perspective: 1200px; }
  .tile .face {
    position: absolute; inset: 0;
    padding: 1rem;
    display: flex; flex-direction: column; justify-content: center; align-items: center;
    text-align: center;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    transition: transform 0.8s var(--fluent-curve-easy-ease, cubic-bezier(0.6, 0, 0.2, 1));
  }
  .tile .face.back { transform: rotateX(180deg); }
  .tile.flipped .face.front { transform: rotateX(180deg); }
  .tile.flipped .face.back  { transform: rotateX(360deg); }

  /* WIDE front + back text */
  .tile.size-w .face { padding: 1.25rem; }
  .tile.size-w .face .tile-name  { font-size: 1.75rem; font-weight: 400; margin-top: 0.6rem; letter-spacing: 0.01em; }
  .tile.size-w .face .tile-count { font-size: 1rem; opacity: 0.85; margin-top: 0.2rem; letter-spacing: 0.04em; }
  .tile.size-w .face.back .back-label   { font-size: 0.78rem; letter-spacing: 0.22em; opacity: 0.75; font-weight: 400; text-transform: uppercase; }
  .tile.size-w .face.back .back-num     { font-size: 4rem; font-weight: 400; line-height: 1.1; margin: 0.25rem 0; }
  .tile.size-w .face.back .back-tagline { font-size: 0.9rem; opacity: 0.85; max-width: 320px; }

  /* MEDIUM front + back text */
  .tile.size-m .face .tile-name { font-size: 1rem; font-weight: 400; margin-top: 0.6rem; letter-spacing: 0.02em; }
  .tile.size-m .face.back .back-num-sm   { font-size: 3rem; font-weight: 400; line-height: 1; }
  .tile.size-m .face.back .back-label-sm { font-size: 0.75rem; opacity: 0.85; letter-spacing: 0.18em; text-transform: uppercase; margin-top: 0.25rem; }
  .tile.size-m .face.back .back-name-sm  { font-size: 0.85rem; opacity: 0.85; margin-top: 0.5rem; }

  /* SMALL front + back text */
  .tile.size-s .face { padding: 0.5rem; }
  .tile.size-s .face .tile-name { font-size: 0.78rem; font-weight: 400; margin-top: 0.4rem; letter-spacing: 0.02em; line-height: 1.15; }
  .tile.size-s .face.back .back-num-sm   { font-size: 2.25rem; font-weight: 400; line-height: 1; }
  .tile.size-s .face.back .back-label-sm { font-size: 0.72rem; opacity: 0.85; letter-spacing: 0.18em; text-transform: uppercase; margin-top: 0.2rem; font-weight: 400; }
  .tile.size-s .face.back .back-name-sm  { font-size: 0.78rem; opacity: 0.85; margin-top: 0.3rem; }

  .tile-badge {
    position: absolute;
    top: 6px; right: 8px;
    padding: 1px 6px;
    background: rgba(255, 255, 255, 0.18);
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.02em;
  }
  .tile.size-s .tile-badge { display: none; }

  .live-tile {
    position: relative;
    perspective: 800px;
    overflow: hidden;
  }
  .live-tile-face {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-end;
    padding: inherit;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    transform-style: preserve-3d;
    animation: tile-flip-front 9s infinite;
  }
  .live-tile-face.back {
    animation-name: tile-flip-back;
    transform: rotateX(180deg);
  }
  @keyframes tile-flip-front {
    0%, 50%   { transform: rotateX(0deg); }
    60%, 100% { transform: rotateX(-180deg); }
  }
  @keyframes tile-flip-back {
    0%, 50%   { transform: rotateX(180deg); }
    60%, 100% { transform: rotateX(0deg); }
  }
  .stat-num-small {
    font-family: var(--lang-font-primary);
    font-size: 2.5rem;
    font-weight: var(--lang-min-weight, 300);
    letter-spacing: -0.02em;
    color: white;
    line-height: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .live-tile-face { animation: none; }
    .live-tile-face.back { display: none; }
  }

  /* Featured tile rotator */
  .featured-section {
    margin: 2rem 0 1.5rem;
  }
  .featured-tile {
    position: relative;
    display: block;
    height: 220px;
    overflow: hidden;
    text-decoration: none;
    background: var(--t-plate);
    border: 0;
  }
  .featured-face {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 700ms var(--fluent-curve-decelerate-mid, ease-out);
    pointer-events: none;
  }
  .featured-face--active {
    opacity: 1;
    pointer-events: auto;
  }
  .featured-img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-color: var(--m-blue-dark);
  }
  .featured-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg,
      rgba(0,0,0,0.15) 0%,
      rgba(0,0,0,0.55) 60%,
      rgba(0,0,0,0.8) 100%);
  }
  .featured-label {
    position: absolute;
    top: 1.25rem;
    left: 1.5rem;
    font-family: var(--lang-font-primary);
    font-size: 0.75rem;
    color: rgba(255,255,255,0.85);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: var(--lang-min-weight, 400);
  }
  .featured-name {
    position: absolute;
    bottom: 1.25rem;
    left: 1.5rem;
    right: 1.5rem;
    font-family: var(--lang-font-primary);
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    line-height: 1.1;
    color: #fff;
    font-weight: var(--lang-min-weight, 300);
    letter-spacing: var(--lang-h2-tracking, 0);
  }
  @media (max-width: 540px) {
    .featured-tile { height: 180px; }
  }

  /* Tile entrance: keep on stat tiles + featured tile (one-shot reveals).
     Removed from .start-screen tiles since the hub no longer swaps when
     navigating between panels — stagger animation would replay on every
     scroll-snap and feel busy. */
  @keyframes tile-enter {
    0%   { opacity: 0; transform: translateY(20px) scale(0.92); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }
  .stat-tile, .featured-tile {
    animation: tile-enter 520ms var(--fluent-curve-decelerate-mid, ease-out) backwards;
  }
  .stat-tile:nth-child(1) { animation-delay: 0ms; }
  .stat-tile:nth-child(2) { animation-delay: 50ms; }
  .stat-tile:nth-child(3) { animation-delay: 100ms; }
  .stat-tile:nth-child(4) { animation-delay: 150ms; }
  @media (prefers-reduced-motion: reduce) {
    .stat-tile, .featured-tile {
      animation: tile-enter-fade 200ms ease-out both;
    }
    @keyframes tile-enter-fade {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
  }

  .tiles-grid.start-tiles {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 1rem;
    align-content: flex-start;
  }
  .tiles-grid.browse-tiles {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 1rem;
    align-content: flex-start;
  }
  .dish-tile {
    position: relative;
    overflow: hidden;
  }
  .dish-tile .cat-face--solid {
    /* photo overlay if image set — solid color shows through when no image */
    background: rgba(0,0,0,0.25);
  }
  .dish-no {
    position: absolute;
    top: 8px; right: 8px;
    font-family: var(--sans);
    font-size: 0.85rem;
    font-weight: 200;
    color: #fff;
    background: rgba(0,0,0,0.4);
    padding: 2px 6px;
    z-index: 2;
  }
  .dish-tile .branding-bar {
    position: absolute;
    bottom: 8px; left: 8px; right: 8px;
    z-index: 2;
    text-shadow: 0 1px 2px rgba(0,0,0,0.5);
  }
  .stat-num {
    font-family: var(--sans);
    font-size: 3rem;
    font-weight: 200;
    color: #fff;
    line-height: 1;
    position: absolute;
    top: 12px; left: 12px;
  }
  .featured-tile {
    position: relative;
    overflow: hidden;
    color: #fff;
    text-decoration: none;
    display: block;
  }
  .featured-tile .featured-face {
    position: absolute;
    inset: 0;
    display: none;
  }
  .featured-tile .featured-face--active {
    display: block;
  }
  .featured-tile .featured-img {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: center;
  }
  .featured-tile .featured-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.6), rgba(0,0,0,0));
  }
  .featured-tile .featured-name {
    position: absolute;
    bottom: 32px; left: 12px;
    font-family: var(--sans), var(--sans-zh);
    font-size: 1.1rem;
    color: #fff;
    text-shadow: 0 1px 3px rgba(0,0,0,0.5);
    z-index: 2;
  }
  .featured-tile .featured-label {
    position: absolute;
    bottom: 12px; left: 12px;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    opacity: 0.85;
    z-index: 2;
  }
  @media (max-width: 540px) {
    /* Responsive scale via direct width/height override (NOT transform: scale).
       Numbers: small 56, medium 120, wide 248, large 248. */
    .tiles-grid .tile-small  { width: 56px;  height: 56px;  }
    .tiles-grid .tile-medium { width: 120px; height: 120px; }
    .tiles-grid .tile-wide   { width: 248px; height: 120px; }
    .tiles-grid .tile-large  { width: 248px; height: 248px; }
  }
</style>

<style is:global>
  /* Escape BaseLayout's main { max-width: 1200px; padding: 1.5rem 1.5rem 6rem }
     so Hub panels can fill the viewport. Astro's component scope means
     Hub's scoped <style> can't reach <main> in BaseLayout; is:global + :has()
     is the escape hatch. */
  main:has(#hub) {
    max-width: none;
    margin: 0;
    padding: 0;
  }
</style>
