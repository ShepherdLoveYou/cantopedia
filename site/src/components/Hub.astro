---
/**
 * 9-panel Hub component. Renders the home panel (panorama + featured tile +
 * progress + start-screen) as panel 0, followed by 8 category panels (one per
 * sorted category). Used by both /[locale]/ and /[locale]/browse/[category]/.
 *
 * Props:
 *   locale: 'zh' | 'en' | 'yue'
 *   initialPanel: 'home' | <category-id>   — which panel is initially in view
 *
 * The hub-pivot's prev/next arrows wrap modulo 9 (home <-> appetizer ... <-> main).
 * URL is kept in sync via history.replaceState as the user scrolls between panels.
 */
import { getCollection } from 'astro:content';
import CategoryIcon from '~/components/CategoryIcon.astro';
import { tileColors, tileColor as tileColorFor } from '~/lib/categoryColors';
import { commonsThumb } from '~/lib/commonsImage';
import AppListPanel from '~/components/AppListPanel.astro';

interface Props {
  locale: 'zh' | 'en' | 'yue';
  initialPanel: string; // 'home' | category-id
}
const { locale, initialPanel } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allCats = (await getCollection('category')).sort((a, b) => a.data.sort_order - b.data.sort_order);
const allDishes = await getCollection('dish');

const dishesByCat = new Map<string, typeof allDishes>();
for (const cat of allCats) {
  dishesByCat.set(cat.id, allDishes
    .filter((d) => d.data.category.id === cat.id)
    .sort((a, b) => a.data.menu_no - b.data.menu_no));
}

function categoryPhoto(catId: string): string | undefined {
  const dishes = dishesByCat.get(catId) ?? [];
  // Try first dish with image in this category
  for (const d of dishes) {
    const p = d.data.images?.[0]?.path;
    if (p) return commonsThumb(p, 800);
  }
  // Fallback: ANY dish with image (cross-category)
  for (const d of allDishes) {
    const p = d.data.images?.[0]?.path;
    if (p) return commonsThumb(p, 800);
  }
  // Last resort: no image, return undefined (tile shows solid color)
  console.warn(`[Hub] no photo found for category ${catId}; showing solid color`);
  return undefined;
}

type CatId = 'appetizer' | 'soup-wonton' | 'rice' | 'noodle' | 'soup-noodle' | 'baked-rice' | 'congee' | 'main';

const total = allDishes.length;
const complete = allDishes.filter((d) => d.data.method_status === 'complete').length;
const draft = allDishes.filter((d) => d.data.method_status === 'draft').length;

function sizeOf(_catId: string, dishCount: number): 'w' | 'm' | 's' {
  if (dishCount >= 20) return 'w';
  if (dishCount >= 7) return 'm';
  return 's';
}

const dict = {
  zh: {
    hero_title: '粵食典',
    hero_sub_a: '六張港式茶餐廳水牌',
    hero_sub_b: '66 道菜 · 三語可溯源',
    browse: '按類別瀏覽',
    progress: '收錄進度',
    complete: '完整做法', draft: '草稿', stub: '配料表', dish_complete: '已完成',
    pieces: '道',
    featured_today: '今日推介', featured_random: '隨機菜', featured_recent: '最近瀏覽',
    dishes_text: '菜',
    home_label: '粵食典',
    applist_label: '所有菜式',
    theme_light: '浅色主题',
    theme_dark: '深色主题',
    tag_search: '搜索',
  },
  en: {
    hero_title: 'Cantopedia',
    hero_sub_a: 'Six hand-written 茶餐廳 menus',
    hero_sub_b: '66 dishes · tri-lingual · citation-traceable',
    browse: 'Browse by category',
    progress: 'Cataloging progress',
    complete: 'with method', draft: 'draft', stub: 'ingredients only', dish_complete: 'complete',
    pieces: 'dishes',
    featured_today: "TODAY'S PICK", featured_random: 'RANDOM DISH', featured_recent: 'RECENTLY VIEWED',
    dishes_text: 'dishes',
    home_label: 'Cantopedia',
    applist_label: 'All dishes',
    theme_light: 'Light theme',
    theme_dark: 'Dark theme',
    tag_search: 'Search',
  },
  yue: {
    hero_title: '粵食典',
    hero_sub_a: '六張茶餐廳水牌',
    hero_sub_b: '66 道菜 · 三語可溯源',
    browse: '按類別瀏覽',
    progress: '收錄進度',
    complete: '完整做法', draft: '草稿', stub: '配料表', dish_complete: '已完成',
    pieces: '道',
    featured_today: '今日推介', featured_random: '隨機餸', featured_recent: '啱啱睇過',
    dishes_text: '菜',
    home_label: '粵食典',
    applist_label: '所有菜式',
    theme_light: '淺色主題',
    theme_dark: '深色主題',
    tag_search: '搵嘢',
  },
}[locale];

function nameOf(c: typeof allCats[number]) {
  return locale === 'en' ? c.data.names.en : c.data.names.yue_hant;
}
function descOf(c: typeof allCats[number]) {
  if (locale === 'en') return c.data.description.en ?? c.data.description.zh;
  if (locale === 'yue') return c.data.description.yue ?? c.data.description.zh;
  return c.data.description.zh;
}

// Initial pivot title shown SSR
const initialTitle =
  initialPanel === 'home' ? dict.home_label
  : initialPanel === 'all' ? dict.applist_label
  : (() => {
      const c = allCats.find((c) => c.id === initialPanel);
      return c ? nameOf(c) : dict.home_label;
    })();

// Build dishes data for featured tile inline script (home panel)
const dishesData = allDishes.map((d) => ({
  id: d.id,
  name: locale === 'en' ? d.data.names.en : d.data.names.yue_hant,
  img: d.data.images?.[0]?.path ? commonsThumb(d.data.images[0].path, 1200) : null,
}));

// Featured tile initial href fallback
const firstDishId = allDishes[0]?.id ?? '';
---
<!-- Hub-aware pivot strip: title updates as user scrolls between panels -->
<nav class="hub-pivot" aria-label="Hub pivot">
  <a class="hub-pivot-link hub-pivot-link--prev" id="hub-pivot-prev" href="#" data-dir="prev" aria-label="Previous panel">
    <span class="hub-pivot-peek hub-pivot-peek--prev" id="hub-pivot-peek-prev" aria-hidden="true"></span>
    <span class="hub-pivot-arrow">‹</span>
  </a>
  <h1 class="hub-pivot-title" id="hub-pivot-title">{initialTitle}</h1>
  <a class="hub-pivot-link hub-pivot-link--next" id="hub-pivot-next" href="#" data-dir="next" aria-label="Next panel">
    <span class="hub-pivot-arrow">›</span>
    <span class="hub-pivot-peek hub-pivot-peek--next" id="hub-pivot-peek-next" aria-hidden="true"></span>
  </a>
</nav>

<div class="hub" id="hub" data-initial-panel={initialPanel}>
  <!-- Panel 0: HOME -->
  <section
    class="hub-panel hub-panel--home"
    data-panel="home"
    data-name={dict.home_label}
    data-url={`${base}/${locale}`}
    aria-labelledby="hub-home-title"
  >
    <div class="tiles-grid start-tiles">
      {/* Featured live tile — tile-wide (4 cols × 2 rows, Metro "wide" banner) for
          dish-of-the-day prominence. Visual slide-up cycle is driven by Metro v5
          data-effect="slide-up"; initFeaturedTile() only populates dish data and
          keeps tile.href in sync with the currently-visible slide. */}
      <a
        id="featured-tile"
        class="tile-wide featured-tile wp-tile"
        data-role="tile"
        data-size="wide"
        data-effect="slide-up"
        href={`${base}/${locale}/dishes/${firstDishId}`}
      >
        <div class="slide featured-slide" data-face="today">
          <div class="featured-img"></div>
          <div class="featured-overlay"></div>
          <span class="branding-bar featured-label">{dict.featured_today}</span>
          <span class="featured-name"></span>
        </div>
        <div class="slide featured-slide" data-face="random">
          <div class="featured-img"></div>
          <div class="featured-overlay"></div>
          <span class="branding-bar featured-label">{dict.featured_random}</span>
          <span class="featured-name"></span>
        </div>
        <div class="slide featured-slide" data-face="recent">
          <div class="featured-img"></div>
          <div class="featured-overlay"></div>
          <span class="branding-bar featured-label">{dict.featured_recent}</span>
          <span class="featured-name"></span>
        </div>
      </a>

      {/* 8 category tiles with CSS 3D card-flip. Metro v5 data-effect="switch" was
          replaced with our own animation so we can:
            (1) add transition timing (Metro's switch is instant — looks "生硬");
            (2) per-tile stagger via --flip-delay (Metro applies the same phase to
                every tile — they all flip in unison, "刷新时间一致");
            (3) keep all tiles square (Metro's effect inherits border-radius). */}
      {allCats.map((cat, idx) => {
        const inCat = dishesByCat.get(cat.id) ?? [];
        if (inCat.length === 0) return null;
        const catName = nameOf(cat);
        const photo = categoryPhoto(cat.id);
        const color = tileColorFor(cat.id);
        const flipDelay = (idx * 0.55).toFixed(2);
        const tileStyle = photo
          ? `background: ${color}; view-transition-name: tile-${cat.id}; --flip-delay: ${flipDelay}s;`
          : `background: ${color}; view-transition-name: tile-${cat.id};`;
        return (
          <a
            class={`tile-medium wp-tile cat-tile-v5${photo ? ' has-back' : ''}`}
            href={`${base}/${locale}/browse/${cat.id}`}
            style={tileStyle}
            aria-label={`${catName} (${inCat.length} ${dict.pieces})`}
          >
            <div class="slide slide--front" style={`background: ${color};`}>
              <span class="tile-icon"><CategoryIcon cat={cat.id as CatId} size={48} /></span>
              <span class="tile-name">{catName}</span>
              <span class="tile-badge">{inCat.length}</span>
            </div>
            {photo && (
              <div class="slide slide--back" style={`background-image: url('${photo}'); background-size: cover; background-position: center;`}>
                <span class="dish-scrim"></span>
                <span class="tile-name tile-name--back">{catName}</span>
              </div>
            )}
          </a>
        );
      })}

      {/* 4 stat tiles (medium, single-face, no flip — they show stats not pictures) */}
      <a class="tile-medium wp-tile stat-tile-mt" data-role="tile" data-size="medium" href={`${base}/${locale}/all`} style="background: var(--m-green); view-transition-name: stat-complete;">
        <span class="stat-num">{complete}</span>
        <span class="stat-label">{dict.complete}</span>
      </a>
      <a class="tile-medium wp-tile stat-tile-mt" data-role="tile" data-size="medium" href={`${base}/${locale}/all`} style="background: var(--m-orange);">
        <span class="stat-num">{draft}</span>
        <span class="stat-label">{dict.draft}</span>
      </a>
      <a class="tile-medium wp-tile stat-tile-mt" data-role="tile" data-size="medium" href={`${base}/${locale}/all`} style="background: var(--m-steel);">
        <span class="stat-num">{total - complete - draft}</span>
        <span class="stat-label">{dict.stub}</span>
      </a>
      <a class="tile-medium wp-tile stat-tile-mt" data-role="tile" data-size="medium" href={`${base}/${locale}/all`} style="background: var(--m-red);">
        <span class="stat-num">{total}</span>
        <span class="stat-label">{dict.pieces}</span>
      </a>

      {/* Utility row: search + 3 theme + github (all 1×1, single-face icon only) */}
      <a class="tile-small wp-tile util-tile" data-role="tile" data-size="small" href={`${base}/${locale}/search`} style="background: var(--m-cyan);" aria-label={dict.tag_search ?? 'Search'}>
        <span class="mif-search util-icon"></span>
      </a>
      <button type="button" class="tile-small wp-tile util-tile" data-role="tile" data-size="small" data-theme="light" style="background: var(--m-yellow);" aria-label={dict.theme_light ?? 'Light theme'}>
        <span class="mif-sunny util-icon"></span>
      </button>
      <button type="button" class="tile-small wp-tile util-tile" data-role="tile" data-size="small" data-theme="dark" style="background: var(--m-purple);" aria-label={dict.theme_dark ?? 'Dark theme'}>
        <span class="mif-moon-right util-icon"></span>
      </button>
      <a class="tile-small wp-tile util-tile" data-role="tile" data-size="small" href="https://github.com/ShepherdLoveYou/cantopedia" target="_blank" rel="noopener" style="background: var(--m-ink);" aria-label="GitHub">
        <span class="mif-github util-icon"></span>
      </a>
    </div>
  </section>

  {/* Panel 1: APPLIST */}
  <AppListPanel
    locale={locale}
    dishes={allDishes}
    base={base}
    dataUrl={`${base}/${locale}/all`}
    panelName={dict.applist_label}
  />

  {/* Browse category panels — one per category, each with a Metro tiles grid of dishes */}
  {allCats.map((cat) => {
    const dishes = dishesByCat.get(cat.id) ?? [];
    const tileColor = tileColorFor(cat.id);
    const catName = nameOf(cat);
    return (
      <section
        class="hub-panel"
        data-panel={cat.id}
        data-cat={cat.id}
        data-name={catName}
        data-url={`${base}/${locale}/browse/${cat.id}`}
        aria-labelledby={`hub-title-${cat.id}`}
      >
        <div class="tiles-grid browse-tiles">
          {dishes.map((dish) => {
            const dishName = locale === 'en' ? dish.data.names.en : dish.data.names.yue_hant;
            const heroImg = dish.data.images?.[0];
            const thumb = heroImg ? commonsThumb(heroImg.path, 800) : null;
            return (
              <a
                class="tile-medium wp-tile dish-tile"
                data-role="tile"
                data-size="medium"
                href={`${base}/${locale}/dishes/${dish.id}`}
                style={`background: ${tileColor}; ${thumb ? `background-image: url('${thumb}'); background-size: cover; background-position: center;` : ''} view-transition-name: dish-${dish.id};`}
                aria-label={dishName}
              >
                <span class="dish-scrim" aria-hidden="true"></span>
                <span class="dish-no">#{String(dish.data.menu_no).padStart(2, '0')}</span>
                <span class="dish-name">{dishName}</span>
              </a>
            );
          })}
        </div>
      </section>
    );
  })}
</div>

<!-- Hub boot config: pass SSR data to client module via window.__hubBoot. -->
<script define:vars={{ base, locale, dishesData }}>
  window.__hubBoot = { base, locale, dishesData };
</script>

<!-- Hub module: featured-tile + hub-nav re-init on every ClientRouter swap. -->
<script>
  import { initFeaturedTile, teardownFeaturedTile, initHubNav, teardownHubNav } from '~/lib/hubScripts';

  function boot() {
    const cfg = (window as any).__hubBoot;
    if (!cfg) return;
    initFeaturedTile(cfg.base, cfg.locale, cfg.dishesData);
    initHubNav();
  }
  function teardown() {
    teardownFeaturedTile();
    teardownHubNav();
  }

  boot();
  document.addEventListener('astro:after-swap', boot);
  document.addEventListener('astro:page-load', boot);
  document.addEventListener('astro:before-preparation', teardown);
</script>


<style>
  main { max-width: none !important; padding: 0 !important; }

  /* ===== Hub-aware pivot strip ===== */
  .hub-pivot {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: baseline;
    gap: 1rem;
    padding: 1rem 1.5rem 0.5rem;
    font-family: var(--lang-font-primary);
    min-height: 4.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  .hub-pivot-title {
    font-size: clamp(1.6rem, 7vw, 3.25rem);
    font-weight: var(--lang-min-weight, 300);
    letter-spacing: var(--lang-h1-tracking, -0.025em);
    line-height: 1;
    margin: 0;
    text-align: center;
    color: var(--t-ink);
    overflow-wrap: break-word;
  }
  .hub-pivot-link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    color: var(--ink);
    text-decoration: none;
  }
  .hub-pivot-arrow {
    font-size: var(--fs-title);
    font-weight: var(--fw-light);
    line-height: 1;
  }
  .hub-pivot-peek {
    font-family: var(--sans), var(--sans-zh);
    font-weight: var(--fw-regular);
    font-size: var(--fs-body);
    color: var(--ink-dim);
    opacity: 0.55;
    max-width: 8ch;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    letter-spacing: 0.02em;
  }
  @media (max-width: 540px) {
    .hub-pivot { min-height: 3.5rem; padding: 0.75rem 1rem 0.25rem; }
    .hub-pivot-peek { display: none; }
  }

  /* ===== Hub: horizontal scroll-snap container ===== */
  .hub {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 100vw;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    height: calc(100vh - 72px - 56px);  /* top AppBar 72 + hub-pivot 56 */
    min-height: 480px;
    overscroll-behavior-x: contain;
  }
  .hub::-webkit-scrollbar { display: none; }

  .hub-panel {
    /* Each panel fills exactly one snap column (100vw, matching .hub grid-auto-columns).
       The width: 100% is needed because grid-auto-columns sets TRACK size, but the
       panel ITEM defaults to min-content unless explicitly sized. */
    width: 100%;
    box-sizing: border-box;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 0 1.5rem 4rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
  }
  .hub-panel::-webkit-scrollbar { width: 6px; }
  .hub-panel::-webkit-scrollbar-thumb { background: var(--t-rule); border-radius: 3px; }

  /* ============================================================
     HOME PANEL — featured tile
     ============================================================ */
  /* Featured tile rotator — size comes from .tile-wide in BaseLayout.astro (height = 2×--tile-unit + --tile-gap). */
  .featured-tile {
    position: relative;
    display: block;
    overflow: hidden;
    text-decoration: none;
    background: var(--t-plate);
    border: 0;
  }

  /* Tile entrance: one-shot reveal for featured tile. */
  @keyframes tile-enter {
    0%   { opacity: 0; transform: translateY(20px) scale(0.92); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }
  .featured-tile {
    animation: tile-enter 520ms var(--fluent-curve-decelerate-mid, ease-out) backwards;
  }
  @media (prefers-reduced-motion: reduce) {
    .featured-tile {
      animation: tile-enter-fade 200ms ease-out both;
    }
    @keyframes tile-enter-fade {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
  }

  .tiles-grid.start-tiles,
  .tiles-grid.browse-tiles {
    /* CSS Grid on a --tile-unit pitch. Tiles span columns/rows via grid-column/-row
       defined per tile class in BaseLayout.astro. auto-flow:dense packs 1×1 tiles into
       holes left by 2×2 tiles so the layout fills uniformly instead of jagging.
       Width is capped to ~10 cols on wide viewports + margin auto so the whole
       tile block is visibly centered; on narrow viewports the cap takes 100% and
       the grid fills the panel. */
    display: grid;
    grid-template-columns: repeat(auto-fill, var(--tile-unit));
    grid-auto-rows: var(--tile-unit);
    grid-auto-flow: dense;
    gap: var(--tile-gap);
    padding: 1.5rem 1rem;
    align-content: start;
    width: min(100%, calc(10 * var(--tile-unit) + 11 * var(--tile-gap)));
    margin-inline: auto;
    box-sizing: border-box;
  }
  /* Mobile: lock to exactly 4 unit-tracks so 2 medium tiles (2×2 each) fill the
     row at half viewport width each. Grid is centered with 16px side padding.
     Featured wide (4×2) takes full row; stat/util (1×1) fit 4 per row. */
  @media (max-width: 540px) {
    .tiles-grid.start-tiles,
    .tiles-grid.browse-tiles {
      grid-template-columns: repeat(4, var(--tile-unit));
      width: calc(4 * var(--tile-unit) + 3 * var(--tile-gap));
      padding: var(--tile-gap) 0;
      justify-content: center;
    }
  }
  /* === Dish tile (browse panels) — single face, photo bg + name overlay === */
  .dish-tile {
    position: relative;
    overflow: hidden;
    display: block;
    text-decoration: none;
    color: #fff;
  }
  .dish-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.1) 60%, rgba(0,0,0,0) 100%);
    pointer-events: none;
  }
  .dish-no {
    position: absolute;
    top: 8px; right: 8px;
    font-family: var(--sans);
    font-size: var(--fs-body);
    font-weight: var(--fw-regular);
    color: #fff;
    background: rgba(0,0,0,0.45);
    padding: 2px 8px;
    z-index: 2;
    letter-spacing: 0.02em;
  }
  .dish-name {
    position: absolute;
    bottom: 10px; left: 10px; right: 10px;
    z-index: 2;
    font-family: var(--sans), var(--sans-zh);
    font-size: var(--fs-panel);
    font-weight: var(--fw-regular);
    color: #fff;
    text-shadow: 0 1px 3px rgba(0,0,0,0.55);
    word-break: keep-all;
    overflow-wrap: anywhere;
  }

  /* === Stat tile — big number + label, single face === */
  .stat-tile-mt {
    position: relative;
    display: block;
    overflow: hidden;
    color: #fff;
    text-decoration: none;
  }
  .stat-num {
    position: absolute;
    top: 12px; left: 14px;
    font-family: var(--sans);
    font-size: var(--fs-panorama);
    font-weight: var(--fw-light);
    color: #fff;
    line-height: 1;
  }
  .stat-label {
    position: absolute;
    bottom: 12px; left: 14px;
    font-family: var(--sans), var(--sans-zh);
    font-size: var(--fs-tiny);
    font-weight: var(--fw-regular);
    color: rgba(255,255,255,0.92);
    letter-spacing: 0.06em;
  }

  /* === Utility tile (search / theme / github) — centered icon, single face === */
  .util-tile {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    color: #fff;
    text-decoration: none;
    appearance: none;
    border: 0;
    cursor: pointer;
    padding: 0;
  }
  .util-tile .util-icon {
    font-size: 28px;
    color: #fff;
    line-height: 1;
  }
  .featured-tile {
    position: relative;
    overflow: hidden;
    color: #fff;
    text-decoration: none;
    display: block;
  }
  .featured-tile .slide.featured-slide {
    position: absolute;
    inset: 0;
  }
  .featured-tile .featured-img {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: center;
  }
  .featured-tile .featured-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.6), rgba(0,0,0,0));
  }
  .featured-tile .featured-name {
    position: absolute;
    bottom: 32px; left: 12px;
    font-family: var(--sans), var(--sans-zh);
    font-size: var(--fs-panel);
    color: #fff;
    text-shadow: 0 1px 3px rgba(0,0,0,0.5);
    z-index: 2;
  }
  .featured-tile .featured-label {
    position: absolute;
    bottom: 12px; left: 12px;
    font-size: var(--fs-caption);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    opacity: 0.85;
    z-index: 2;
  }
  /* Featured wide tile: label band picks up the user's accent on focus/active.
     Default state stays neutral so the underlying dish photo doesn't compete
     with the accent color. */
  .featured-tile:hover .featured-label,
  .featured-tile:focus-visible .featured-label {
    color: var(--accent);
  }
  /* Tile sizes now derive from --tile-unit + --tile-gap in BaseLayout.astro. No media-query fork needed. */

  /* ===== Tile defaults — all tiles are square WP10-style, no Metro radius ===== */
  .tiles-grid {
    /* 3D perspective for child tile flips */
    perspective: 1200px;
  }
  .tile-small,
  .tile-medium,
  .tile-2x1,
  .tile-wide,
  .tile-large,
  .cat-tile-v5,
  .stat-tile-mt,
  .util-tile,
  .dish-tile,
  .featured-tile {
    border-radius: 0 !important;
  }

  /* ===== WP10 Metro cat-tile with CSS 3D card-flip =====
     Each slide animates ITSELF (parent stays static). This avoids the
     Chrome bug where backface-visibility on slide children of a rotating
     parent fails to hide the back of a face — slides showed mirrored
     upside-down text when the parent was rotated. With slide-level
     rotation, each slide's transform applies directly, so backface-
     visibility:hidden works as spec'd. */
  .cat-tile-v5 {
    position: relative;
    color: #fff;
    text-decoration: none;
    display: block;
    overflow: hidden;
    /* Perspective provides 3D depth during slide rotateX animation.
       Without it, rotateX appears as flat scaleY fold (orthographic) instead
       of a card flip with depth cue. Match master's .live-tile { perspective: 800px }. */
    perspective: 800px;
  }
  .cat-tile-v5 .slide {
    position: absolute;
    inset: 0;
    padding: var(--sp-3);
    display: flex;
    flex-direction: column;
    background-size: cover;
    background-position: center;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }
  /* The back face starts pre-rotated 180° so it's invisible (its backface
     points at the viewer until the animation rotates it forward). */
  .cat-tile-v5 .slide--back {
    transform: rotateX(180deg);
  }
  .cat-tile-v5.has-back .slide--front {
    animation: cat-face-front 7s cubic-bezier(0.6, 0, 0.2, 1) infinite;
    animation-delay: var(--flip-delay, 0s);
    will-change: transform;
  }
  .cat-tile-v5.has-back .slide--back {
    animation: cat-face-back 7s cubic-bezier(0.6, 0, 0.2, 1) infinite;
    animation-delay: var(--flip-delay, 0s);
    will-change: transform;
  }
  @keyframes cat-face-front {
    0%, 40% { transform: rotateX(0deg); }
    50%     { transform: rotateX(-180deg); }
    90%     { transform: rotateX(-180deg); }
    100%    { transform: rotateX(-360deg); }
  }
  @keyframes cat-face-back {
    0%, 40% { transform: rotateX(180deg); }
    50%     { transform: rotateX(0deg); }
    90%     { transform: rotateX(0deg); }
    100%    { transform: rotateX(-180deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .cat-tile-v5.has-back .slide--front,
    .cat-tile-v5.has-back .slide--back { animation: none; }
  }
  .cat-tile-v5 .tile-icon {
    align-self: flex-start;
    color: #fff;
    line-height: 0;
  }
  .cat-tile-v5 .tile-name {
    margin-top: auto;
    font-family: var(--lang-font-primary);
    font-weight: var(--fw-regular);
    font-size: var(--fs-panel);
    line-height: 1.2;
    word-break: keep-all;
    overflow-wrap: anywhere;
    color: #fff;
  }
  .cat-tile-v5 .tile-name--back {
    position: relative;
    z-index: 2;
    text-shadow: 0 1px 3px rgba(0,0,0,0.6);
  }
  .cat-tile-v5 .tile-badge {
    position: absolute;
    top: 8px; right: 10px;
    font-family: var(--sans);
    font-size: var(--fs-panel);
    font-weight: var(--fw-medium);
    color: #fff;
    background: rgba(0, 0, 0, 0.28);
    padding: 1px 8px;
    line-height: 1.2;
    letter-spacing: var(--ls-meta);
    z-index: 2;
  }
  .cat-tile-v5 .dish-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.1) 60%, rgba(0,0,0,0) 100%);
    pointer-events: none;
    z-index: 1;
  }
</style>

<style is:global>
  /* Escape BaseLayout's main { max-width: 1200px; padding: 1.5rem 1.5rem 6rem }
     so Hub panels can fill the viewport. Astro's component scope means
     Hub's scoped <style> can't reach <main> in BaseLayout; is:global + :has()
     is the escape hatch. */
  main:has(#hub) {
    max-width: none;
    margin: 0;
    padding: 0;
  }
</style>
