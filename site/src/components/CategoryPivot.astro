---
import { getCollection } from 'astro:content';
import { getPivotNeighbors } from '~/lib/categoryOrder';

interface Props {
  currentId: string;
  locale: 'zh' | 'en' | 'yue';
}
const { currentId, locale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const all = await getCollection('category');
const { prev, curr, next } = getPivotNeighbors(currentId, all);
const nameOf = (c: typeof curr) =>
  locale === 'en' ? c.data.names.en : c.data.names.yue_hant;
---
<nav class="pivot-strip" aria-label="Category pivot">
  <a class="pivot pivot--dim"
     href={`${base}/${locale}/browse/${prev.id}`}
     data-dir="prev"
     rel="prev">{nameOf(prev)}</a>
  <div class="pivot pivot--current"
       aria-current="page"
       style="view-transition-name: pivot-title">{nameOf(curr)}</div>
  <a class="pivot pivot--dim"
     href={`${base}/${locale}/browse/${next.id}`}
     data-dir="next"
     rel="next">{nameOf(next)}</a>
</nav>

<div class="pivot-edge-hints" aria-hidden="true">
  <span class="pivot-hint pivot-hint--prev" data-name={nameOf(prev)}></span>
  <span class="pivot-hint pivot-hint--next" data-name={nameOf(next)}></span>
</div>

<style>
  /* Authentic WP10 Mobile Pivot proportions — current title BIG (weight 300),
     prev/next peeks small + dim at the current's baseline. Ratio ~3:1 like
     Windows Phone Hub. */
  .pivot-strip {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: baseline;
    gap: 1.25rem;
    padding: 1.5rem 0 0.5rem;
    font-family: var(--sans), var(--sans-zh);
    min-height: 4.5rem;
  }
  .pivot { text-decoration: none; color: inherit; }
  .pivot--dim {
    font-size: var(--fs-panel);
    font-weight: var(--fw-regular);
    opacity: 0.35;
    letter-spacing: 0.01em;
    transition: opacity var(--fluent-duration-fast, .15s) var(--fluent-curve-easy-ease, ease);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
    padding-bottom: 0.35rem;
  }
  .pivot--dim:hover { opacity: 0.75; }
  .pivot--dim[data-dir="prev"] { text-align: right; }
  .pivot--current {
    font-size: clamp(1.6rem, 7vw, 3.25rem);
    font-weight: var(--fw-regular);
    letter-spacing: -0.025em;
    margin: 0;
    line-height: 1;
    text-align: center;
    overflow-wrap: break-word;
    word-break: break-word;
    hyphens: auto;
    max-width: 100%;
    color: var(--t-ink);
  }
  @media (max-width: 540px) {
    .pivot-strip { min-height: 3.5rem; gap: 0.6rem; padding: 1rem 0 0.5rem; }
    .pivot--dim { font-size: var(--fs-tiny); padding-bottom: 0.25rem; }
  }

  /* Pivot 1:1 finger-tracking edge hints. Visible only when html.pivot-dragging. */
  .pivot-edge-hints {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 10;
    opacity: 0;
    transition: opacity 200ms ease;
  }
  html.pivot-dragging .pivot-edge-hints { opacity: 1; }
  .pivot-hint {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--lang-font-primary);
    font-size: clamp(1rem, 3vw, 1.5rem);
    font-weight: var(--lang-min-weight, 300);
    color: var(--t-ink-dim);
    letter-spacing: 0.01em;
    padding: 0.5rem 1rem;
  }
  .pivot-hint::before {
    content: attr(data-name);
  }
  .pivot-hint--prev { left: 1rem; }
  .pivot-hint--next { right: 1rem; }
  .pivot-hint--prev::after { content: ' ›'; opacity: 0.5; margin-left: 0.25rem; }
  .pivot-hint--next::before { content: '‹ '; opacity: 0.5; }
  .pivot-hint--next::after { content: attr(data-name); }
  .pivot-hint--next::before, .pivot-hint--next::after { display: inline; }
</style>

<script>
  // ClientRouter keeps document-level listeners across navigations, so each
  // handler bails fast on pages where the pivot strip isn't present.
  const hasPivot = () => !!document.querySelector('.pivot-strip');

  // Keyboard nav
  document.addEventListener('keydown', (e) => {
    if (!hasPivot()) return;
    const tag = (e.target as HTMLElement)?.tagName;
    if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return;
    if (e.key === 'ArrowLeft')
      document.querySelector<HTMLAnchorElement>('.pivot[data-dir="prev"]')?.click();
    if (e.key === 'ArrowRight')
      document.querySelector<HTMLAnchorElement>('.pivot[data-dir="next"]')?.click();
  });

  // 1:1 finger-tracking horizontal swipe. While user drags, translate <main>
  // by exactly the finger offset (with rubber-band attenuation near edges).
  // On release past threshold, animate to off-screen and trigger nav.
  let sx = 0, sy = 0, tracking = false, decided = false;
  const THRESH = 0.30; // 30% of viewport width
  const main = () => document.querySelector<HTMLElement>('main');

  document.addEventListener('touchstart', (e) => {
    if (!hasPivot()) return;
    sx = e.touches[0].clientX;
    sy = e.touches[0].clientY;
    tracking = true;
    decided = false;
    const m = main();
    if (m) m.style.transition = 'none';
  }, { passive: true });

  document.addEventListener('touchmove', (e) => {
    if (!tracking) return;
    const dx = e.touches[0].clientX - sx;
    const dy = e.touches[0].clientY - sy;
    if (!decided) {
      // Lock to horizontal vs vertical based on dominant direction in first 10px
      if (Math.abs(dx) < 10 && Math.abs(dy) < 10) return;
      if (Math.abs(dx) < Math.abs(dy)) {
        // Vertical scroll wins — abandon drag tracking
        tracking = false;
        return;
      }
      decided = true;
      document.documentElement.classList.add('pivot-dragging');
    }
    // Rubber-band: full 1:1 up to threshold, then sublinear past
    const w = window.innerWidth;
    let visible = dx;
    const thresholdPx = w * THRESH;
    if (Math.abs(dx) > thresholdPx) {
      const overshoot = Math.abs(dx) - thresholdPx;
      const damped = thresholdPx + overshoot * 0.4;
      visible = Math.sign(dx) * damped;
    }
    const m = main();
    if (m) m.style.transform = `translateX(${visible}px)`;
  }, { passive: true });

  document.addEventListener('touchend', (e) => {
    if (!tracking) return;
    tracking = false;
    document.documentElement.classList.remove('pivot-dragging');
    const dx = e.changedTouches[0].clientX - sx;
    const w = window.innerWidth;
    const m = main();
    if (!m) return;

    if (!decided) {
      // Never committed to a horizontal drag — just clear transform
      m.style.transform = '';
      return;
    }

    if (Math.abs(dx) >= w * THRESH) {
      // Commit nav — RESET inline transform first so the VT API snapshots
      // the page at its natural position (not mid-drag, which would make
      // the OLD snapshot's content look already half-off-screen). The
      // micro-snap is imperceptible because VT animation takes over
      // within ~16ms and slides the whole page cleanly.
      const dir = dx < 0 ? 'next' : 'prev';
      m.style.transition = 'none';
      m.style.transform = '';
      // Force a layout flush so the reset is applied before the click.
      void m.offsetHeight;
      const link = document.querySelector<HTMLAnchorElement>(`.pivot[data-dir="${dir}"]`);
      if (link) link.click();
    } else {
      // Spring back
      m.style.transition = `transform 320ms var(--fluent-curve-spring, ease-out)`;
      m.style.transform = '';
      setTimeout(() => { m.style.transition = ''; }, 350);
    }
  }, { passive: true });

  // Tag direction onto <html> for CSS-driven slide (capture phase so it runs
  // before ClientRouter intercepts the click). No hasPivot bail needed —
  // the selector itself only matches pivot anchors.
  document.addEventListener('click', (e) => {
    const a = (e.target as HTMLElement).closest<HTMLAnchorElement>('.pivot[data-dir]');
    if (!a) return;
    document.documentElement.classList.remove('nav-prev', 'nav-next');
    document.documentElement.classList.add(a.dataset.dir === 'prev' ? 'nav-prev' : 'nav-next');
  }, true);

  // After every navigation completes, clear the direction class so non-pivot
  // navigations that follow don't accidentally inherit the horizontal slide.
  // BUT: astro:page-load fires BEFORE the View Transition's `finished` promise
  // resolves. If we clear nav-prev/nav-next at page-load, the ::view-transition
  // pseudo-elements lose their matching rule mid-animation and the slide stops
  // visibly. Defer the cleanup until after the typical VT duration (gentle
  // duration is 420ms; pad to 600ms for safety).
  document.addEventListener('astro:page-load', () => {
    document.documentElement.classList.remove('pivot-dragging');
    const m = main();
    if (m) { m.style.transition = ''; m.style.transform = ''; }
    setTimeout(() => {
      document.documentElement.classList.remove('nav-prev', 'nav-next');
    }, 600);
  });
</script>
