---
import { getCollection } from 'astro:content';

interface Props {
  currentId: string;
  locale: 'zh' | 'en' | 'yue';
}
const { currentId, locale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const cats = (await getCollection('category'))
  .sort((a, b) => a.data.sort_order - b.data.sort_order);
const nameOf = (c: typeof cats[number]) =>
  locale === 'en' ? c.data.names.en : c.data.names.yue_hant;
---
<nav class="pivot-strip" aria-label="Category pivot">
  {cats.map((c) => (
    <a
      class={`pivot ${c.id === currentId ? 'pivot--current' : ''}`}
      href={`${base}/${locale}/browse/${c.id}`}
      data-cat={c.id}
      aria-current={c.id === currentId ? 'page' : undefined}
    >{nameOf(c)}</a>
  ))}
</nav>

<style>
  /* WP10 classic Pivot tab strip — all categories on one horizontally
     scrollable row, current one larger + red underline. Authentic
     Windows Phone hub-tab pattern. */
  .pivot-strip {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    padding: 1.25rem 1.5rem 0.75rem;
    margin: 0 -1.5rem 1.5rem;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    /* Hide scrollbar but keep scrollable */
    scrollbar-width: none;
    border-bottom: 1px solid var(--t-rule);
  }
  .pivot-strip::-webkit-scrollbar { display: none; }

  .pivot {
    font-family: var(--sans), var(--sans-zh);
    font-size: 1rem;
    font-weight: 300;
    color: var(--t-ink-dim);
    text-decoration: none;
    white-space: nowrap;
    flex: 0 0 auto;
    scroll-snap-align: center;
    padding-bottom: 0.5rem;
    transition: color var(--fluent-duration-fast) ease, font-size var(--fluent-duration-normal) ease;
    position: relative;
  }
  .pivot:hover { color: var(--t-ink); }
  .pivot--current {
    font-size: clamp(1.5rem, 5.5vw, 2.25rem);
    color: var(--t-ink);
    font-weight: 400;
    letter-spacing: -0.01em;
  }
  .pivot--current::after {
    content: '';
    position: absolute;
    left: 0; right: 0;
    bottom: -1px;
    height: 2px;
    background: var(--m-red);
  }

  @media (max-width: 540px) {
    .pivot-strip { gap: 1rem; padding: 1rem 1rem 0.625rem; margin: 0 -1rem 1rem; }
    .pivot { font-size: 0.875rem; }
  }
</style>

<script>
  // Auto-scroll the current pivot tab into view on every page-load.
  function centerCurrent() {
    const strip = document.querySelector<HTMLElement>('.pivot-strip');
    const current = strip?.querySelector<HTMLElement>('.pivot--current');
    if (!strip || !current) return;
    const target = current.offsetLeft + current.offsetWidth / 2 - strip.clientWidth / 2;
    strip.scrollTo({ left: Math.max(0, target), behavior: 'auto' });
  }
  centerCurrent();
  document.addEventListener('astro:page-load', centerCurrent);

  // Keyboard nav between adjacent tabs
  document.addEventListener('keydown', (e) => {
    const strip = document.querySelector<HTMLElement>('.pivot-strip');
    if (!strip) return;
    const tag = (e.target as HTMLElement)?.tagName;
    if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return;
    const tabs = Array.from(strip.querySelectorAll<HTMLAnchorElement>('.pivot'));
    const i = tabs.findIndex((t) => t.classList.contains('pivot--current'));
    if (i < 0) return;
    if (e.key === 'ArrowLeft' && i > 0) tabs[i - 1].click();
    if (e.key === 'ArrowRight' && i < tabs.length - 1) tabs[i + 1].click();
  });
</script>
