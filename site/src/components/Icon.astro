---
/**
 * Inline SVG icons replacing the 4 `mif-*` glyphs Cantopedia consumed from
 * Metro UI's icons.css (387 KB). Each icon uses currentColor and sizes
 * itself to 1em — matches `font-size`-driven sizing the Metro classes used.
 *
 * Add a new icon: drop its path/contents below in the `icons` map.
 */
interface Props {
  name: 'sun' | 'moon' | 'search' | 'github';
  class?: string;
  ariaHidden?: boolean;
}
const { name, class: className, ariaHidden = true } = Astro.props;

// Each entry is the SVG inner markup (no <svg> wrapper). Wrapper below applies
// width / height / viewBox / fill uniformly.
const icons: Record<Props['name'], string> = {
  sun: `<circle cx="12" cy="12" r="4"/><g stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"><path d="M12 2v3M12 19v3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M2 12h3M19 12h3M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1"/></g>`,
  moon: `<path d="M21 12.8a9 9 0 1 1-9.8-9.8 7 7 0 0 0 9.8 9.8z"/>`,
  search: `<g fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/></g>`,
  github: `<path d="M12 0a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.9 2.9 1.3 3.6 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2.9-.3 2-.4 3-.4s2.1.1 3 .4c2.3-1.5 3.3-1.2 3.3-1.2.6 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.7-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.3v3.4c0 .3.2.7.8.6A12 12 0 0 0 12 0z"/>`,
};
const inner = icons[name];
---
<svg
  width="1em"
  height="1em"
  viewBox="0 0 24 24"
  fill="currentColor"
  aria-hidden={ariaHidden ? 'true' : undefined}
  class={className}
  set:html={inner}
/>
