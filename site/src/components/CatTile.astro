---
/**
 * Live-tile with WP10-style card flip (front ↔ back via rotateX 180°).
 *
 * Front face: solid color + icon (slot) + category name + count badge.
 * Back face:  photo (if available) or solid color + BIG count number + label + name.
 *
 * JS driver in lib/hubScripts.ts (initCatTileCycle) toggles `.flipped` on
 * the tile every ~9 seconds with a 1.4s stagger per tile, matching the
 * master (cee6736) cadence that the user said "做得挺好".
 *
 * Props:
 *   size: 's' | '2x1' | 'm' | 'w' — see CSS below
 *   href, color, ariaLabel
 *   label: category name (e.g., "頭盤 / 小食")
 *   count: dish count (e.g., 7)
 *   countLabel: unit suffix (e.g., "道", "dishes")
 *   photo: optional URL for the back face background
 *   viewTransitionName: inline view-transition-name for Continuum morph
 */
export interface Props {
  size: 's' | '2x1' | 'm' | 'w';
  href: string;
  color: string;
  label: string;
  count?: number;
  countLabel?: string;
  photo?: string;
  viewTransitionName?: string;
  ariaLabel: string;
}
const { size, href, color, label, count, countLabel, photo, viewTransitionName, ariaLabel } = Astro.props;
const sizeClass = { s: 'tile-small', m: 'tile-medium', '2x1': 'tile-2x1', w: 'tile-wide' }[size];
const vtStyle = viewTransitionName ? `view-transition-name: ${viewTransitionName};` : '';
const backBg = photo
  ? `background-image: url('${photo}'); background-size: cover; background-position: center;`
  : `background: ${color};`;
---
<a class={`${sizeClass} cat-tile wp-tile`} href={href} aria-label={ariaLabel} style={vtStyle}>
  <div class="face front" style={`background: ${color};`}>
    <span class="tile-icon"><slot /></span>
    <span class="tile-name">{label}</span>
    {count != null && <span class="tile-badge">{count}</span>}
  </div>
  <div class="face back" style={backBg}>
    {photo && <span class="face-scrim" aria-hidden="true"></span>}
    {count != null && (
      <span class="back-num-block">
        <span class="back-num">{count}</span>
        {countLabel && <span class="back-num-label">{countLabel}</span>}
      </span>
    )}
    <span class="back-name">{label}</span>
  </div>
</a>

<style is:global>
  /* ============================================================
     Tile grid pitch (single source of truth for all tile sizes)
     ============================================================ */
  :root {
    --tile-unit: 70px;
    --tile-gap: 10px;
  }
  @media (max-width: 540px) {
    :root {
      --tile-unit: 56px;
      --tile-gap: 8px;
    }
  }

  /* Tile size classes — width/height for flex parents, grid-column/-row spans
     for CSS Grid parents (.tiles-grid uses display:grid). */
  .tile-small {
    width: var(--tile-unit) !important;
    height: var(--tile-unit) !important;
    grid-column: span 1;
    grid-row: span 1;
  }
  .tile-medium {
    width: calc(2 * var(--tile-unit) + var(--tile-gap)) !important;
    height: calc(2 * var(--tile-unit) + var(--tile-gap)) !important;
    grid-column: span 2;
    grid-row: span 2;
  }
  .tile-2x1 {
    width: calc(2 * var(--tile-unit) + var(--tile-gap));
    height: var(--tile-unit);
    grid-column: span 2;
    grid-row: span 1;
  }
  .tile-wide {
    /* 4 cols × 2 rows — Metro "wide" banner, for featured/hero tiles */
    width: calc(4 * var(--tile-unit) + 3 * var(--tile-gap)) !important;
    height: calc(2 * var(--tile-unit) + var(--tile-gap)) !important;
    grid-column: span 4;
    grid-row: span 2;
  }
  [class*="tile-"].cat-tile { border-radius: 0 !important; }

  /* ============================================================
     Cat-tile flip — rotateX 180° card-flip (matches master cee6736)
     ============================================================ */
  .cat-tile {
    position: relative;
    overflow: hidden;
    perspective: 1200px;
    color: #fff;
    text-decoration: none;
    display: block;
  }
  .cat-tile .face {
    position: absolute;
    inset: 0;
    padding: 10px;
    display: flex;
    flex-direction: column;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    background-size: cover;
    background-position: center;
  }
  /* Initial state: front facing viewer (rotateX 0), back rotated away (rotateX 180) */
  .cat-tile .face.back { transform: rotateX(180deg); }
  /* Flipped state: front rotates away, back rotates to viewer */
  .cat-tile.flipped .face.front { transform: rotateX(180deg); }
  .cat-tile.flipped .face.back  { transform: rotateX(360deg); }

  /* Photo back gets a bottom-up gradient so white text stays legible */
  .cat-tile .face-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.1) 60%, rgba(0,0,0,0) 100%);
    pointer-events: none;
    z-index: 1;
  }

  /* === Front face content === */
  .cat-tile .tile-icon {
    align-self: flex-start;
    color: #fff;
    line-height: 0;
  }
  .cat-tile .tile-name {
    margin-top: auto;
    font-family: var(--sans), var(--sans-zh);
    font-weight: 400;
    line-height: 1.2;
    word-break: keep-all;
    overflow-wrap: anywhere;
    color: #fff;
  }
  .cat-tile .tile-badge {
    position: absolute;
    top: 8px; right: 10px;
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 500;
    color: #fff;
    background: rgba(0, 0, 0, 0.28);
    padding: 1px 8px;
    line-height: 1.2;
    letter-spacing: 0.02em;
  }

  /* === Back face content (the big-number reveal) === */
  .cat-tile .back-num-block {
    position: relative;
    z-index: 2;
    margin-top: auto;
    display: flex;
    align-items: baseline;
    gap: 6px;
  }
  .cat-tile .back-num {
    font-family: var(--sans);
    font-weight: 200;
    line-height: 1;
    color: #fff;
  }
  .cat-tile .back-num-label {
    font-family: var(--sans);
    font-size: 0.78rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.92);
  }
  .cat-tile .back-name {
    position: absolute;
    top: 10px; left: 10px;
    z-index: 2;
    font-family: var(--sans), var(--sans-zh);
    font-size: 0.85rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.95);
    line-height: 1.15;
    text-shadow: 0 1px 3px rgba(0,0,0,0.6);
  }

  /* === Size-specific font tuning === */
  .cat-tile.tile-small .tile-icon { font-size: 22px; }
  .cat-tile.tile-small .tile-name { font-size: 0.7rem; line-height: 1.1; }
  .cat-tile.tile-small .tile-badge { font-size: 0.72rem; padding: 0 5px; top: 4px; right: 5px; }
  .cat-tile.tile-small .back-num { font-size: 1.6rem; }
  .cat-tile.tile-small .back-name { display: none; }
  .cat-tile.tile-small .back-num-label { display: none; }

  .cat-tile.tile-2x1 .tile-name { font-size: 0.95rem; }
  .cat-tile.tile-2x1 .tile-badge { font-size: 0.95rem; }
  .cat-tile.tile-2x1 .back-num { font-size: 2.2rem; }

  .cat-tile.tile-medium .tile-name { font-size: 1.1rem; }
  .cat-tile.tile-medium .tile-badge { font-size: 1rem; }
  .cat-tile.tile-medium .back-num { font-size: 3rem; }

  .cat-tile.tile-wide .tile-name { font-size: 1.45rem; font-weight: 300; }
  .cat-tile.tile-wide .tile-badge { font-size: 1.05rem; }
  .cat-tile.tile-wide .back-num { font-size: 3.5rem; }
  .cat-tile.tile-wide .back-num-block { gap: 10px; }

  @media (prefers-reduced-motion: reduce) {
    .cat-tile .face { transition: none; }
  }
</style>
